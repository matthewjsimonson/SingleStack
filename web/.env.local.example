# Copy to .env.local for local dev. These are PUBLIC (anon) values — safe in the
# browser. Find them at: Supabase dashboard → (your project) → Settings → API.
#
# THREE-TIER SETUP — each tier has its OWN Supabase project. Point local dev at
# the DEV project; Vercel injects the right values per environment (see below).
#
#   Tier         Git branch   Vercel env     Supabase project
#   ----------   ----------   ------------   -------------------------------
#   Dev          develop      Development    singlestack-dev   (no real data)
#   Demo         staging      Preview        singlestack-demo  (demo data)
#   Production   main         Production     singlestack-prod  (real data)
#
# In Vercel → Project → Settings → Environment Variables, set these two keys
# separately for each Environment (Development / Preview / Production), each
# pointing at that tier's Supabase project. Locally, fill in the DEV project's
# values below.

NEXT_PUBLIC_SUPABASE_URL=https://your-dev-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-dev-anon-key-eyJ...
