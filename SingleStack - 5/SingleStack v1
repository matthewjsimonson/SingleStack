  if(stateEl){
    stateEl.classList.remove('live','draft');
    stateEl.classList.add(c.state);
    stateEl.innerHTML = '<span class="dot"></span>'+c.stateLabel;
  }
  // Show sheet, hide list
  var list = document.getElementById('v-cm-list');
  var ws = document.getElementById('v-cm-ws');
