<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SingleStack</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;}
html,body{font-family:'Inter',sans-serif;background:#F7F6F3;height:100%;overflow:hidden;font-size:15px;color:#0F1115;font-feature-settings:'cv11','ss01','ss03';-webkit-font-smoothing:antialiased;letter-spacing:-0.005em;}
.tabular{font-variant-numeric:tabular-nums;}

:root{
  --bg:#F7F6F3;--sb:#0F1115;--sbb:#1F2126;--sbl:#5A5F6B;--sbt:#9BA0AB;--sa:#1A1D22;--sat:#5E8AFF;
  --tb:#FFFFFF;--tbb:#E8E6E1;--cb:#FFFFFF;--cbr:#E8E6E1;--s2:#F1EFEB;--s3:#E8E5E0;
  --tp:#0F1115;--ts:#52555E;--tm:#8B8F99;
  --ac:#5E8AFF;--al:#EEF2FF;--at:#3B5BCC;
  --am:#C97A1B;--aml:#FAF3E7;--amt:#7A4A0F;
  --rd:#D14343;--rdl:#FBEAEA;--rdt:#8A2727;
  --vl:#6B6FE0;--vll:#EDEEFB;--vlt:#4044A8;
  --bl:#3D7AC4;--bll:#E8F0FB;--blt:#1F4783;
  --gn:#3A8F66;--gnl:#E6F2EB;--gnt:#1F5C3B;
  --lyra:#5E8AFF;--lyra-bg:#EEF2FF;--lyra-bd:#CBD7FF;
}

.cap{display:flex;flex-direction:column;height:100vh;overflow:hidden;position:relative;}

/* TOPBAR */
.topbar{height:54px;min-height:54px;background:var(--tb);border-bottom:1px solid var(--tbb);display:flex;align-items:center;padding:0 24px;gap:14px;flex-shrink:0;z-index:30;}
.wm{font-weight:700;font-size:15px;letter-spacing:-0.01em;color:var(--tp);display:flex;align-items:center;gap:9px;}
.wmd{width:8px;height:8px;border-radius:50%;background:var(--ac);}
.vdiv{width:1px;height:22px;background:var(--tbb);}
.pp{display:flex;align-items:center;gap:6px;background:var(--s2);border:1px solid var(--cbr);border-radius:6px;padding:4px 10px;font-size:13px;font-weight:600;color:var(--ts);cursor:pointer;}
.ppd{width:6px;height:6px;border-radius:50%;background:var(--ac);}
.ltag{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--at);background:var(--al);border:1px solid var(--ac);border-radius:4px;padding:2px 7px;display:flex;align-items:center;gap:5px;}
.ld{width:5px;height:5px;border-radius:50%;background:var(--ac);animation:blink 2s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.spacer{flex:1;}

/* Agent activity pill in topbar — Lyra "currently working on" */
.agt-pill{display:flex;align-items:center;gap:8px;background:var(--lyra-bg);border:1px solid var(--lyra-bd);border-radius:7px;padding:5px 11px;font-size:12.5px;font-weight:500;color:var(--at);cursor:pointer;transition:all .12s;letter-spacing:-0.005em;}
.agt-pill:hover{background:#E5EBFF;}
.agt-pill-dot{width:6px;height:6px;border-radius:50%;background:var(--ac);animation:pulse 1.6s infinite;}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.3);opacity:.6}}
.agt-pill-count{font-family:'JetBrains Mono',monospace;font-weight:700;}

.lyrb{display:flex;align-items:center;gap:6px;background:var(--tp);color:#fff;border:none;border-radius:8px;padding:7px 14px;font-size:13px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif;transition:background .15s;letter-spacing:-0.005em;}
.lyrb:hover{background:#2C3035;}
.lyrb.open{background:var(--ac);color:#fff;}

/* BODY */
.body{display:flex;flex:1;overflow:hidden;position:relative;}

/* SIDEBAR — new 4-group structure with badges */
.sidebar{width:230px;min-width:230px;background:var(--sb);border-right:1px solid var(--sbb);overflow-y:auto;padding:20px 0;flex-shrink:0;}
.nl{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:600;letter-spacing:.12em;color:var(--sbl);padding:0 22px;margin-bottom:8px;margin-top:18px;text-transform:uppercase;}
.nl:first-child{margin-top:0;}
.ni{display:flex;align-items:center;gap:10px;padding:8px 22px;font-size:13.5px;font-weight:500;color:var(--sbt);cursor:pointer;border-left:2px solid transparent;transition:all .12s;letter-spacing:-0.005em;}
.ni:hover{background:var(--sa);color:#C8D0D9;}
.ni.active{background:var(--sa);color:var(--sat);border-left:2px solid var(--sat);}
.ni i{font-size:16px;opacity:.8;}
.ni.active i{opacity:1;}
.ni-meta{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--sbl);font-weight:600;}
.ni.active .ni-meta{color:var(--sat);}
/* Pending review badge — orange dot for HITL signal */
.ni-pend{margin-left:auto;display:flex;align-items:center;gap:4px;}
.ni-pend-dot{width:6px;height:6px;border-radius:50%;background:var(--am);}
.ni-pend-num{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--am);font-weight:700;}
.ndv{height:1px;background:var(--sbb);margin:14px 16px;}

/* MAIN */
.main{flex:1;overflow-y:auto;display:flex;flex-direction:column;background:var(--bg);transition:margin-right .25s;}
.main.lo{margin-right:clamp(260px,22vw,340px);}

/* MODULE HEADER */
.mhdr{background:var(--cb);border-bottom:1px solid var(--cbr);padding:18px clamp(20px,2.5vw,40px) 14px;display:flex;align-items:flex-start;justify-content:space-between;gap:24px;flex-wrap:wrap;flex-shrink:0;}
.mhdr-left{flex:1;min-width:0;}
.mhdr-eyebrow{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--tm);font-weight:600;margin-bottom:6px;text-transform:uppercase;}
.mhdr-title{font-size:clamp(22px,1.8vw,28px);font-weight:700;color:var(--tp);letter-spacing:-0.02em;line-height:1.15;margin-bottom:4px;}
.mhdr-sub{font-size:13.5px;color:var(--ts);line-height:1.55;max-width:740px;}
.mhdr-right{display:flex;align-items:center;gap:8px;flex-shrink:0;}

/* AGENT INBOX BAR — sits at top of every module, surfaces what Lyra is doing here */
.agt-inbox{background:linear-gradient(0deg,var(--lyra-bg),#F5F8FF);border-bottom:1px solid var(--lyra-bd);padding:10px clamp(20px,2.5vw,40px);display:flex;align-items:center;gap:14px;flex-shrink:0;}

/* Record attribution — who maintains this record */
.rec-attr{display:flex;align-items:center;gap:10px;padding:8px 14px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;margin-bottom:14px;}
.rec-attr-av-group{display:flex;align-items:center;flex-shrink:0;}
.rec-attr-av-group .rec-attr-av:not(:first-child){margin-left:-7px;}
.rec-attr-av{width:24px;height:24px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-family:'Fraunces',Georgia,serif;font-size:13px;font-weight:600;flex-shrink:0;border:1.5px solid var(--cb);}
.rec-attr-av.cpo{background:var(--al);color:var(--at);}
.rec-attr-av.cro{background:var(--vll);color:var(--vlt);}
.rec-attr-av.ceo{background:var(--gnl);color:var(--gnt);}
.rec-attr-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.rec-attr-name{font-size:12.5px;color:var(--tp);font-weight:600;letter-spacing:-0.005em;}
.rec-attr-meta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;margin-left:auto;}
.rec-attr-cta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--at);font-weight:700;cursor:pointer;}
.rec-attr-cta:hover{text-decoration:underline;}
.agt-inbox-icon{width:28px;height:28px;border-radius:7px;background:var(--cb);border:1px solid var(--lyra-bd);display:flex;align-items:center;justify-content:center;color:var(--at);font-size:14px;flex-shrink:0;}
.agt-inbox-body{flex:1;display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.agt-inbox-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--at);font-weight:700;}
.agt-inbox-text{font-size:13px;color:var(--tp);letter-spacing:-0.005em;}
.agt-inbox-text strong{font-weight:600;}
.agt-inbox-actions{display:flex;gap:6px;}
.agt-inbox-btn{background:var(--cb);border:1px solid var(--lyra-bd);border-radius:6px;padding:5px 11px;font-size:12px;font-weight:600;color:var(--at);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.agt-inbox-btn:hover{background:#F5F8FF;}
.agt-inbox-btn-prim{background:var(--at);color:#fff;border-color:var(--at);}
.agt-inbox-btn-prim:hover{background:#2F4AB5;color:#fff;}
.agt-inbox-dismiss{background:none;border:none;color:var(--at);cursor:pointer;font-size:14px;padding:4px;}

/* HEADER PILLS */
.hpill{display:flex;align-items:center;gap:6px;font-size:12px;font-weight:600;padding:5px 10px;border-radius:6px;border:1px solid transparent;letter-spacing:-0.005em;}
.hpill i{font-size:12px;}
.hpill-lock{background:#F1EFEB;color:#52555E;border-color:#E0DDD7;}
.hpill-pend{background:var(--aml);color:var(--amt);border-color:#EBD9B8;}
.hpill-sig{background:var(--al);color:var(--at);border-color:#CBD7FF;}
.hbtn{display:flex;align-items:center;gap:6px;background:transparent;border:1px solid var(--cbr);border-radius:6px;padding:5px 10px;font-size:12px;font-weight:600;color:var(--ts);cursor:pointer;font-family:'Inter',sans-serif;transition:background .12s;}
.hbtn:hover{background:var(--s2);color:var(--tp);}

/* CANVAS */
.cv{flex:1;overflow-y:auto;padding:24px clamp(22px,2.4vw,44px) 60px;}

/* CORNERSTONE-VIEW NAV (Structure / Signals / Incoming) */
.csv-nav{display:flex;border-bottom:1px solid var(--cbr);margin-bottom:24px;gap:0;}
.csv-btn{display:flex;align-items:center;gap:7px;background:transparent;border:none;padding:11px 18px 13px;font-size:13.5px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .12s;}
.csv-btn:hover{color:var(--ts);}
.csv-btn.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);}
.csv-btn i{font-size:14px;}
.csv-pill{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;background:var(--aml);color:var(--amt);padding:2px 7px;border-radius:10px;margin-left:3px;}
.csv-btn.active .csv-pill{background:var(--am);color:#fff;}

/* SECTION HEADER */
.sec-hdr{display:flex;align-items:flex-start;justify-content:space-between;gap:24px;margin-bottom:22px;padding-bottom:18px;border-bottom:1px solid var(--cbr);}
.sec-hdr-left{flex:1;max-width:760px;}
.sec-title{font-family:'Fraunces',Georgia,serif;font-size:26px;font-weight:600;color:var(--tp);letter-spacing:-0.025em;margin-bottom:8px;line-height:1.1;}
.sec-eyebrow{font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:6px;}
.sec-lead{font-size:13.5px;color:var(--ts);line-height:1.6;}
.sec-hdr-right{flex-shrink:0;}

/* CORNERSTONE TREE */
.tree{display:flex;flex-direction:column;align-items:center;}
.cstone{width:100%;max-width:880px;background:var(--cb);border:1px solid var(--cbr);border-top:3px solid var(--tp);border-radius:12px;box-shadow:0 1px 3px rgba(15,17,21,.04);position:relative;overflow:hidden;}
.cstone-tag{position:absolute;top:0;left:0;background:var(--tp);color:#fff;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;font-weight:700;padding:5px 14px;border-radius:0 0 8px 0;}
.cstone-body{padding:36px 28px 22px;}
.cstone-head{display:flex;align-items:flex-start;gap:14px;margin-bottom:20px;padding-bottom:18px;border-bottom:1px solid var(--cbr);}
.cstone-icon{width:48px;height:48px;border-radius:10px;background:var(--s2);color:var(--tp);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.cstone-icon i{font-size:24px;}
.cstone-tblock{flex:1;display:flex;flex-direction:column;gap:5px;min-width:0;}
.cstone-name{font-family:'Fraunces',Georgia,serif;font-size:30px;font-weight:600;color:var(--tp);letter-spacing:-0.025em;line-height:1.05;}
.cstone-status{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.cstone-ver{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:600;background:var(--s2);padding:2px 7px;border-radius:4px;}
.cstone-owner{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);}
.cstone-edit{background:transparent;border:1px solid var(--cbr);border-radius:7px;width:34px;height:34px;display:flex;align-items:center;justify-content:center;color:var(--ts);cursor:pointer;transition:all .12s;}
.cstone-edit:hover{background:var(--s2);color:var(--tp);}
.cstone-edit i{font-size:15px;}

.cstone-fields{display:flex;flex-direction:column;gap:14px;}
.cstone-field{position:relative;padding-right:130px;}
.cstone-field-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--tm);font-weight:600;margin-bottom:4px;}
.cstone-field-val{font-size:14.5px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;}
/* Provenance footer — who/what wrote this field */
.cstone-field-prov{display:flex;align-items:center;gap:6px;margin-top:6px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);}
.cstone-field-prov i{font-size:11px;}
.cstone-field-prov-human{color:var(--ts);}
.cstone-field-prov-lyra{color:var(--at);}
.cstone-field-pend{position:absolute;top:0;right:0;display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;color:var(--amt);background:var(--aml);border:1px solid #EBD9B8;padding:3px 9px;border-radius:5px;cursor:pointer;transition:all .12s;}
.cstone-field-pend:hover{background:#F7E9C8;}
.cstone-field-pend i{font-size:11px;}

.cstone-meta{display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-top:18px;padding-top:16px;border-top:1px solid var(--cbr);}
.cstone-meta-item{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:500;letter-spacing:.02em;}
.cstone-meta-item i{font-size:12px;}
.cstone-meta-pend{color:var(--amt);font-weight:700;}
.cstone-meta-pend i{color:var(--am);}

/* TREE CONNECTOR */
.tree-conn{position:relative;width:100%;max-width:1100px;height:80px;display:flex;justify-content:center;}
.tree-trunk{position:absolute;top:0;left:50%;transform:translateX(-50%);width:2px;height:24px;background:var(--cbr);}
.tree-branches{position:absolute;top:24px;left:10%;right:10%;height:2px;background:var(--cbr);}
.tree-br{position:absolute;top:0;width:2px;height:54px;background:var(--cbr);}
.tree-branches .tree-br:nth-child(1){left:0;}
.tree-branches .tree-br:nth-child(2){left:25%;}
.tree-branches .tree-br:nth-child(3){left:50%;transform:translateX(-50%);}
.tree-branches .tree-br:nth-child(4){left:75%;}
.tree-branches .tree-br:nth-child(5){right:0;}
.tree-br-lbl{position:absolute;top:30px;left:50%;transform:translateX(-50%);background:var(--bg);padding:0 12px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.16em;color:var(--tm);font-weight:600;}

/* MODULE NODES */
.tree-mods{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;width:100%;max-width:1100px;}
.tmod{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:14px 14px 12px;display:flex;flex-direction:column;gap:8px;cursor:pointer;transition:all .15s;min-height:160px;position:relative;}
.tmod:hover{border-color:var(--tp);transform:translateY(-2px);box-shadow:0 4px 12px rgba(15,17,21,.06);}
.tmod-icon{width:34px;height:34px;border-radius:8px;background:var(--s2);color:var(--tp);display:flex;align-items:center;justify-content:center;}
.tmod-icon i{font-size:18px;}
.tmod-name{font-size:14px;font-weight:700;color:var(--tp);letter-spacing:-0.01em;line-height:1.25;}
.tmod-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.tmod-status{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;}
.tmod-status-ga{background:#E6F2EB;color:#1F5C3B;}
.tmod-status-beta{background:var(--aml);color:var(--amt);}
.tmod-status-ea{background:var(--al);color:var(--at);}
.tmod-count{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;letter-spacing:.02em;}
.tmod-desc{font-size:12px;color:var(--ts);line-height:1.45;flex:1;}
.tmod-foot{display:flex;align-items:center;justify-content:space-between;gap:8px;padding-top:8px;border-top:1px solid var(--cbr);}
.tmod-ver{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.tmod-pend{display:flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;color:var(--amt);background:var(--aml);padding:2px 7px;border-radius:4px;}
.tmod-pend i{font-size:11px;}

.cs-foot{display:flex;align-items:flex-start;gap:14px;margin-top:32px;padding:16px 22px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:10px;max-width:1100px;}
.cs-foot-lbl{flex-shrink:0;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--tm);font-weight:700;padding-top:1px;}
.cs-foot-text{flex:1;font-size:12.5px;color:var(--ts);line-height:1.6;}
.cs-foot-text strong{color:var(--tp);font-weight:600;}

@media (max-width: 1100px){
  .tree-mods{grid-template-columns:repeat(3,1fr);}
  .tree-branches .tree-br:nth-child(2),
  .tree-branches .tree-br:nth-child(4){display:none;}
}

/* ============ SIGNALS / RECOMMENDATION CARDS ============ */
.sig-cards{display:flex;flex-direction:column;gap:8px;}
.sig-card{background:var(--cb);border:1px solid var(--cbr);border-left:3px solid var(--am);border-radius:9px;padding:11px 14px;display:flex;flex-direction:column;gap:8px;}
.sig-card-hdr{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;}
.sig-card-left{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.sig-branch{display:flex;align-items:center;gap:6px;font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.sig-branch i{font-size:13px;color:var(--ts);}
.sig-conf{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:600;color:var(--tm);}
.sig-conf-high{color:var(--gnt);}
.sig-conf-med{color:var(--amt);}
.sig-conf-dot{width:7px;height:7px;border-radius:50%;background:var(--gn);}
.sig-conf-med .sig-conf-dot{background:var(--am);}
.sig-age{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);}
.sig-title{font-size:13.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;}

.sig-diff{display:flex;align-items:center;gap:8px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:7px;padding:8px 11px;flex-wrap:wrap;}
.sig-diff-col{display:inline-flex;align-items:baseline;gap:5px;min-width:0;}
.sig-diff-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.1em;font-weight:700;flex-shrink:0;}
.sig-diff-lbl-old{color:var(--rdt);}
.sig-diff-lbl-new{color:var(--at);}
.sig-diff-val{font-size:12.5px;line-height:1.4;color:var(--tp);letter-spacing:-0.005em;}
.sig-diff-val-old{color:var(--ts);text-decoration:line-through;text-decoration-color:rgba(209,67,67,.4);}
.sig-diff-val-new{color:var(--at);font-weight:600;}
.sig-diff-arrow{display:inline-flex;align-items:center;color:var(--tm);font-size:12px;flex-shrink:0;}

.sig-why{display:flex;gap:8px;align-items:flex-start;}
.sig-why-lbl{flex-shrink:0;font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;color:var(--tm);padding-top:2px;}
.sig-why-text{font-size:12px;color:var(--ts);line-height:1.5;letter-spacing:-0.005em;}
.sig-sources{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.sig-src-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;color:var(--tm);}
.sig-src-chip{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--ts);background:var(--s2);border:1px solid var(--cbr);border-radius:4px;padding:2px 7px;}
.sig-src-chip i{font-size:11px;}
.sig-impact{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.sig-impact-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;color:var(--tm);}
.sig-impact-chip{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--ts);background:var(--al);border:1px solid #CBD7FF;border-radius:4px;padding:2px 7px;}
.sig-impact-chip i{font-size:11px;color:var(--at);}

/* PR PROPOSALS — product-spec framing (structured field diffs, not marketing copy) */
/* PR PROPOSAL — compact spec rows (one line each) */
.sig-spec{display:flex;flex-direction:column;gap:4px;}
.sig-spec-row{background:#FBFAF8;border:1px solid var(--cbr);border-radius:7px;padding:8px 11px;display:grid;grid-template-columns:auto 1fr auto;gap:11px;align-items:center;min-height:0;}
.sig-spec-row > *{align-self:center;min-height:0;}
.sig-spec-icon{width:22px;height:22px;border-radius:5px;background:var(--s2);color:var(--ts);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;}
.sig-spec-mid{min-width:0;display:flex;flex-direction:column;gap:2px;}
.sig-spec-path{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:700;letter-spacing:.04em;text-transform:uppercase;}
.sig-spec-path strong{color:var(--tp);text-transform:none;letter-spacing:0;font-family:'Inter',sans-serif;font-size:12.5px;font-weight:600;}
.sig-spec-change{font-size:12.5px;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.sig-spec-old{color:var(--ts);text-decoration:line-through;text-decoration-color:rgba(209,67,67,.4);}
.sig-spec-arrow{color:var(--tm);font-size:11px;}
.sig-spec-new{color:var(--at);font-weight:600;}
.sig-spec-kind{display:inline-flex;align-items:center;align-self:center;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;font-weight:700;padding:3px 7px;border-radius:4px;text-transform:uppercase;flex-shrink:0;line-height:1;height:auto;width:auto;max-height:22px;}
.sig-spec-kind.status{background:var(--gnl);color:var(--gnt);}
.sig-spec-kind.scope{background:var(--al);color:var(--at);}
.sig-spec-kind.cap{background:var(--vll);color:var(--vlt);}
.sig-spec-kind.field{background:var(--s2);color:var(--tm);}

.sig-actions{display:flex;justify-content:flex-end;gap:6px;padding-top:7px;border-top:1px solid var(--cbr);}
.sig-act{background:var(--cb);border:1px solid var(--cbr);border-radius:5px;padding:4px 10px;font-size:11.5px;font-weight:500;color:var(--ts);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;display:flex;align-items:center;gap:4px;}
.sig-act:hover{background:var(--s2);color:var(--tp);}
.sig-act-rej:hover{color:var(--rdt);border-color:#E8B5B5;background:var(--rdl);}
.sig-act-acc{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.sig-act-acc:hover{background:#2C3035;color:#fff;}
.sig-act-acc i{font-size:13px;}

.sig-filter{display:flex;background:var(--s2);border-radius:7px;padding:3px;gap:2px;}
.sig-filter-btn{background:transparent;border:none;border-radius:5px;padding:6px 11px;font-size:12px;font-weight:500;color:var(--ts);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;display:flex;align-items:center;gap:6px;}
.sig-filter-btn:hover{color:var(--tp);}
.sig-filter-btn.active{background:var(--cb);color:var(--tp);font-weight:600;box-shadow:0 1px 2px rgba(15,17,21,.06);}
.sig-filter-btn span{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);}
.sig-filter-btn.active span{color:var(--tp);}

/* ============ INCOMING RELEASES ============ */
.inc-list{display:flex;flex-direction:column;gap:14px;}
.inc-card{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.inc-top{display:flex;justify-content:space-between;gap:24px;padding:18px 22px;border-bottom:1px solid var(--cbr);background:#FBFAF8;}
.inc-top-left{flex:1;min-width:0;}
.inc-ver-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;}
.inc-ver-tag{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;background:var(--tp);color:#fff;padding:3px 8px;border-radius:4px;letter-spacing:.02em;}
.inc-ver-status{font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;padding:3px 8px;border-radius:4px;letter-spacing:.08em;text-transform:uppercase;}
.inc-status-soon{background:var(--gnl);color:var(--gnt);}
.inc-status-mid{background:var(--aml);color:var(--amt);}
.inc-status-far{background:var(--s2);color:var(--tm);}
.inc-title{font-size:16px;font-weight:700;color:var(--tp);letter-spacing:-0.01em;line-height:1.3;margin-bottom:6px;}
.inc-summary{font-size:13px;color:var(--ts);line-height:1.55;}
.inc-stat{display:flex;flex-direction:column;align-items:flex-end;gap:2px;padding:8px 16px;background:var(--cb);border:1px solid var(--cbr);border-radius:8px;min-width:90px;flex-shrink:0;}
.inc-stat-val{font-family:'Fraunces',Georgia,serif;font-size:22px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1.1;}
.inc-stat-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--tm);font-weight:600;}

.inc-impact{padding:16px 22px;}
.inc-impact-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;font-weight:700;color:var(--tm);margin-bottom:10px;}
.inc-impact-row{display:grid;grid-template-columns:220px 1fr 170px;gap:14px;padding:10px 0;border-bottom:1px solid var(--cbr);align-items:center;}
.inc-impact-row:last-child{border-bottom:none;}
.inc-impact-branch{display:flex;align-items:center;gap:6px;font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.inc-impact-branch i{font-size:13px;color:var(--ts);}
.inc-impact-change{font-size:12.5px;color:var(--ts);line-height:1.5;}
.inc-impact-state{font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;padding:4px 9px;border-radius:5px;text-align:center;letter-spacing:.02em;justify-self:end;white-space:nowrap;}
.inc-state-draft{background:var(--gnl);color:var(--gnt);}
.inc-state-stage{background:var(--aml);color:var(--amt);}
.inc-state-block{background:var(--rdl);color:var(--rdt);}
.inc-state-far{background:var(--al);color:var(--at);}

.inc-foot{display:flex;justify-content:flex-end;align-items:center;gap:10px;padding:12px 22px;border-top:1px solid var(--cbr);background:#FBFAF8;}
.inc-foot-btn{background:var(--cb);border:1px solid var(--cbr);border-radius:7px;padding:7px 13px;font-size:12.5px;font-weight:500;color:var(--ts);cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:6px;letter-spacing:-0.005em;}
.inc-foot-btn:hover{background:var(--s2);color:var(--tp);}
.inc-foot-btn i{font-size:13px;}
.inc-foot-btn-prim{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.inc-foot-btn-prim:hover{background:#2C3035;color:#fff;}
.inc-far-note{display:flex;align-items:center;gap:7px;font-size:12px;color:var(--tm);font-style:italic;}

/* ============ SIGNALS MODULE (new consolidated) ============ */
.sg-statebar{display:flex;align-items:center;gap:16px;margin-bottom:24px;flex-wrap:wrap;}
.sg-toggle{display:flex;background:var(--s2);border-radius:8px;padding:3px;gap:2px;}
.sg-toggle-btn{background:transparent;border:none;border-radius:6px;padding:8px 14px;font-size:13px;font-weight:500;color:var(--ts);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;display:flex;align-items:center;gap:7px;}
.sg-toggle-btn:hover{color:var(--tp);}
.sg-toggle-btn.active{background:var(--cb);color:var(--tp);font-weight:600;box-shadow:0 1px 3px rgba(15,17,21,.08);}
.sg-toggle-btn i{font-size:14px;}
.sg-toggle-btn span{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:600;}
.sg-toggle-btn.active span{color:var(--at);}

.sg-tabs{display:flex;border-bottom:1px solid var(--cbr);gap:0;margin-bottom:24px;}
.sg-tab{background:transparent;border:none;padding:10px 16px 12px;font-size:13.5px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;}
.sg-tab:hover{color:var(--ts);}
.sg-tab.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);}

/* BRIDGE CARDS (Cross-cutting Product↔GTM) */
.bridge-list{display:flex;flex-direction:column;gap:14px;margin-bottom:32px;}
.bridge-card{background:var(--cb);border:1px solid var(--cbr);border-radius:14px;padding:20px 22px;}
.bridge-hdr{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:6px;flex-wrap:wrap;}
.bridge-title{font-size:15.5px;font-weight:600;color:var(--tp);letter-spacing:-0.01em;line-height:1.35;flex:1;min-width:0;}
.bridge-meta{display:flex;align-items:center;gap:10px;flex-shrink:0;}
.bridge-owner{font-size:12px;color:var(--tm);font-weight:500;font-family:'JetBrains Mono',monospace;}
.bridge-lyra{display:inline-flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:var(--at);background:var(--lyra-bg);border:1px solid var(--lyra-bd);padding:2px 7px;border-radius:4px;}
.bridge-lyra i{font-size:11px;}
.bridge-desc{font-size:13px;color:var(--ts);line-height:1.5;margin-bottom:16px;max-width:760px;}
.bridge-grid{display:grid;grid-template-columns:1fr auto 1fr;gap:0;margin-bottom:14px;align-items:stretch;}
.bridge-side{background:var(--bg);border:1px solid var(--cbr);border-radius:10px;padding:13px 15px;display:flex;flex-direction:column;gap:10px;}
.bridge-side-head{display:flex;align-items:center;gap:8px;}
.bridge-side-kind{font-size:10.5px;font-weight:600;padding:2px 7px;border-radius:5px;letter-spacing:.04em;text-transform:uppercase;font-family:'JetBrains Mono',monospace;}
.bridge-side.prod .bridge-side-kind{background:var(--al);color:var(--at);}
.bridge-side.gtm .bridge-side-kind{background:var(--vll);color:var(--vlt);}
.bridge-side-name{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.bridge-viz{flex:1;display:flex;flex-direction:column;justify-content:center;min-height:60px;}
.bridge-viz-labels{display:flex;justify-content:space-between;margin-top:4px;font-size:11px;color:var(--tm);font-variant-numeric:tabular-nums;}
.bridge-viz-r{font-weight:700;color:var(--tp);}
.bridge-stat-row{display:flex;gap:24px;}
.bridge-stat-val{font-family:'Fraunces',Georgia,serif;font-size:24px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1;font-variant-numeric:tabular-nums;}
.bridge-stat-lbl{font-size:11px;color:var(--tm);margin-top:2px;}
.bridge-side-foot{font-size:11.5px;color:var(--tm);line-height:1.4;letter-spacing:-0.005em;}
.bridge-conn{display:flex;align-items:center;justify-content:center;padding:0 12px;color:var(--tm);font-size:20px;font-weight:300;}
.bridge-insight{background:#FBFAF8;border:1px solid var(--cbr);border-left:3px solid var(--ac);border-radius:8px;padding:12px 14px;display:flex;gap:10px;align-items:flex-start;}
.bridge-insight-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.1em;color:var(--at);padding:3px 8px;background:var(--al);border-radius:4px;flex-shrink:0;}
.bridge-insight-text{font-size:13px;color:var(--ts);line-height:1.55;}

/* Sparkbars */
.sparkbars{display:flex;align-items:flex-end;gap:3px;height:46px;}
.sb-bar{flex:1;border-radius:2px 2px 0 0;opacity:0.85;transition:opacity .15s;}

/* Winrate compare */
.wr-compare{display:flex;flex-direction:column;gap:6px;padding:4px 0;}
.wr-row{display:grid;grid-template-columns:30px 1fr 40px;align-items:center;gap:10px;}
.wr-lbl{font-size:11px;color:var(--tm);font-weight:500;}
.wr-track{height:9px;background:var(--s2);border-radius:5px;overflow:hidden;}
.wr-fill{height:100%;border-radius:5px;}
.wr-val{font-size:12px;font-weight:700;color:var(--tp);font-variant-numeric:tabular-nums;text-align:right;}

/* MARKET PANE — outside-in scanning */
.mk-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px;margin-bottom:24px;}
.mk-lane{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;}
.mk-lane-hdr{padding:12px 16px;border-bottom:1px solid var(--cbr);display:flex;align-items:center;gap:10px;background:#FBFAF8;}
.mk-lane-icon{width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.mk-lane-icon i{font-size:14px;}
.mk-lane.analyst .mk-lane-icon{background:var(--vll);color:var(--vlt);}
.mk-lane.trend .mk-lane-icon{background:var(--bll);color:var(--blt);}
.mk-lane.adj .mk-lane-icon{background:var(--aml);color:var(--amt);}
.mk-lane.fund .mk-lane-icon{background:var(--gnl);color:var(--gnt);}
.mk-lane-title{flex:1;font-size:13px;font-weight:700;color:var(--tp);letter-spacing:-0.005em;}
.mk-lane-count{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.mk-lane-body{flex:1;display:flex;flex-direction:column;}
.mk-item{padding:12px 16px;border-bottom:1px solid var(--cbr);display:flex;flex-direction:column;gap:5px;cursor:pointer;transition:background .12s;}
.mk-item:last-child{border-bottom:none;}
.mk-item:hover{background:#FBFAF8;}
.mk-item-meta{display:flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);letter-spacing:.04em;text-transform:uppercase;font-weight:600;}
.mk-item-source{color:var(--at);}
.mk-item-title{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;}
.mk-item-text{font-size:12px;color:var(--ts);line-height:1.5;}
.mk-item-foot{display:flex;align-items:center;gap:8px;margin-top:3px;flex-wrap:wrap;}
.mk-item-tag{display:inline-flex;align-items:center;gap:5px;font-size:11px;color:var(--ts);background:var(--s2);border-radius:4px;padding:2px 7px;}
.mk-item-tag.lyra{background:var(--lyra-bg);color:var(--at);border:1px solid var(--lyra-bd);}
.mk-item-tag i{font-size:11px;}
.mk-item-promote{margin-left:auto;display:inline-flex;align-items:center;gap:4px;font-family:'Inter',sans-serif;font-size:11px;font-weight:600;color:var(--at);background:none;border:none;cursor:pointer;padding:2px 6px;border-radius:4px;}
.mk-item-promote:hover{background:var(--al);}

/* MARKET — pipeline strip showing flow Market → Candidates → Current */
.mk-flow{display:flex;align-items:stretch;gap:0;background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:14px 18px;margin-bottom:20px;}
.mk-flow-stage{flex:1;display:flex;flex-direction:column;gap:4px;padding:4px 14px;}
.mk-flow-stage:first-child{padding-left:0;}
.mk-flow-stage:last-child{padding-right:0;}
.mk-flow-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--tm);font-weight:700;}
.mk-flow-val{display:flex;align-items:baseline;gap:8px;}
.mk-flow-num{font-family:'Fraunces',Georgia,serif;font-size:24px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1;}
.mk-flow-desc{font-size:11.5px;color:var(--ts);line-height:1.4;}
.mk-flow-arrow{display:flex;align-items:center;color:var(--tm);font-size:18px;padding:0 4px;}
.mk-flow-stage.active{background:var(--lyra-bg);border-radius:8px;padding:8px 14px;}
.mk-flow-stage.active .mk-flow-lbl{color:var(--at);}

/* ============ GTM RECORD · PERSONA-CONTEXT GRID ============ */
.persona-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:14px;margin-bottom:24px;}
.persona-card{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;}
.persona-hdr{padding:14px 16px;border-bottom:1px solid var(--cbr);display:flex;align-items:flex-start;gap:12px;background:#FBFAF8;}
.persona-avatar{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;}
.persona-avatar.primary{background:var(--al);color:var(--at);}
.persona-avatar.secondary{background:var(--vll);color:var(--vlt);}
.persona-avatar.influencer{background:var(--aml);color:var(--amt);}
.persona-id{flex:1;min-width:0;}
.persona-role{font-size:14px;font-weight:700;color:var(--tp);letter-spacing:-0.005em;line-height:1.2;}
.persona-context{font-size:11.5px;color:var(--ts);margin-top:2px;font-family:'JetBrains Mono',monospace;}
.persona-rank{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;font-weight:700;padding:3px 7px;border-radius:4px;text-transform:uppercase;}
.persona-rank.primary{background:var(--al);color:var(--at);}
.persona-rank.secondary{background:var(--vll);color:var(--vlt);}
.persona-rank.influencer{background:var(--aml);color:var(--amt);}

.persona-pressure-bar{padding:10px 16px;border-bottom:1px solid var(--cbr);}
.persona-pressure-lbl{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.persona-pressure-name{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.persona-pressure-val{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;}
.persona-pressure-val.high{color:var(--rdt);}
.persona-pressure-val.med{color:var(--amt);}
.persona-pressure-val.low{color:var(--gnt);}
.persona-pressure-track{height:5px;background:var(--s2);border-radius:3px;overflow:hidden;}
.persona-pressure-fill{height:100%;border-radius:3px;}
.persona-pressure-fill.high{background:var(--rd);}
.persona-pressure-fill.med{background:var(--am);}
.persona-pressure-fill.low{background:var(--gn);}

.persona-ctx{padding:12px 16px;flex:1;}
.persona-ctx-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:8px;}
.persona-ctx-list{display:flex;flex-direction:column;gap:8px;}
.persona-ctx-item{display:flex;gap:9px;align-items:flex-start;font-size:12.5px;color:var(--tp);line-height:1.45;letter-spacing:-0.005em;}
.persona-ctx-item-icon{width:20px;height:20px;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;margin-top:1px;}
.persona-ctx-item-icon.ext{background:var(--vll);color:var(--vlt);}
.persona-ctx-item-icon.int{background:var(--al);color:var(--at);}
.persona-ctx-item-icon.rel{background:var(--gnl);color:var(--gnt);}
.persona-ctx-item-icon.risk{background:var(--rdl);color:var(--rdt);}
.persona-ctx-item-body{flex:1;min-width:0;}
.persona-ctx-item-body strong{font-weight:600;}
.persona-ctx-item-src{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);margin-top:2px;display:flex;align-items:center;gap:5px;}
.persona-ctx-item-src .sgref{font-size:9.5px;padding:1px 5px;}

.persona-msg{padding:11px 16px;border-top:1px solid var(--cbr);background:#FBFAF8;}
.persona-msg-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:5px;}
.persona-msg-quote{font-family:'Fraunces',Georgia,serif;font-size:13.5px;font-style:italic;color:var(--tp);line-height:1.45;letter-spacing:-0.01em;}
.persona-msg-foot{display:flex;align-items:center;justify-content:space-between;margin-top:7px;}
.persona-msg-prov{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);display:flex;align-items:center;gap:5px;}
.persona-msg-prov i{font-size:11px;}
.persona-msg-action{background:var(--cb);border:1px solid var(--cbr);border-radius:5px;padding:3px 8px;font-family:'Inter',sans-serif;font-size:11px;font-weight:600;color:var(--at);cursor:pointer;}
.persona-msg-action:hover{background:var(--al);border-color:#CBD7FF;}

/* ============ PRODUCT RECORD · TECHNICAL DRILL ============ */
.pr-tech-section{margin-top:28px;}
.pr-tech-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.pr-tech-card{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.pr-tech-card.full{grid-column:1/-1;}
.pr-tech-card-hdr{padding:11px 16px;border-bottom:1px solid var(--cbr);display:flex;align-items:center;gap:10px;background:#FBFAF8;}
.pr-tech-card-icon{width:26px;height:26px;border-radius:6px;background:var(--s2);color:var(--tp);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.pr-tech-card-title{flex:1;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.1em;color:var(--tp);font-weight:700;text-transform:uppercase;}
.pr-tech-card-meta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.pr-tech-card-body{padding:14px 16px;}

/* Architecture stack */
.arch-stack{display:flex;flex-direction:column;gap:6px;}
.arch-layer{display:grid;grid-template-columns:90px 1fr auto;align-items:center;gap:12px;padding:9px 12px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;}
.arch-layer-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.1em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.arch-layer-tech{display:flex;gap:5px;flex-wrap:wrap;}
.arch-tech-chip{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;color:var(--tp);background:var(--cb);border:1px solid var(--cbr);border-radius:5px;padding:3px 8px;font-weight:500;letter-spacing:-0.005em;}
.arch-tech-chip i{font-size:11px;color:var(--ts);}
.arch-layer-health{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;}
.arch-layer-health.ok{background:var(--gnl);color:var(--gnt);}
.arch-layer-health.warn{background:var(--aml);color:var(--amt);}

/* Dependencies / data sources */
.dep-list{display:flex;flex-direction:column;gap:6px;}
.dep-row{display:grid;grid-template-columns:auto 1fr auto auto;gap:10px;align-items:center;padding:8px 11px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:7px;}
.dep-icon{width:24px;height:24px;border-radius:5px;background:var(--cb);border:1px solid var(--cbr);display:flex;align-items:center;justify-content:center;color:var(--ts);font-size:12px;}
.dep-body{min-width:0;}
.dep-name{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.dep-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);margin-top:1px;}
.dep-latency{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--ts);font-weight:600;}
.dep-status-dot{width:8px;height:8px;border-radius:50%;}
.dep-status-dot.ok{background:var(--gn);}
.dep-status-dot.warn{background:var(--am);}
.dep-status-dot.crit{background:var(--rd);}

/* Capability map */
.cap-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:8px;}
.cap-tile{background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;padding:11px 13px;}
.cap-name{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-bottom:6px;}
.cap-bar{height:6px;background:var(--s2);border-radius:3px;overflow:hidden;margin-bottom:5px;}
.cap-fill{height:100%;border-radius:3px;}
.cap-fill.strong{background:var(--gn);}
.cap-fill.parity{background:var(--am);}
.cap-fill.weak{background:var(--rd);}
.cap-meta{display:flex;align-items:center;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.cap-meta-val{color:var(--tp);}

/* Tech debt / known issues list */
.issue-list{display:flex;flex-direction:column;gap:5px;}
.issue-row{display:flex;align-items:flex-start;gap:9px;padding:7px 10px;border-radius:6px;cursor:pointer;}
.issue-row:hover{background:#FBFAF8;}
.issue-sev{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.08em;font-weight:700;padding:3px 6px;border-radius:4px;flex-shrink:0;margin-top:1px;}
.issue-sev.p0{background:var(--rdl);color:var(--rdt);}
.issue-sev.p1{background:var(--aml);color:var(--amt);}
.issue-sev.p2{background:var(--s2);color:var(--tm);}
.issue-body{flex:1;min-width:0;}
.issue-title{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.35;}
.issue-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);margin-top:2px;}

/* ============ SIGNALS · INTELLIGENCE CENTER ============ */
.intel-scoreboard{display:grid;grid-template-columns:repeat(6,1fr);gap:0;background:#0F1115;border:1px solid var(--sbb);border-radius:12px;overflow:hidden;margin-bottom:18px;}
.intel-score{padding:14px 16px;border-right:1px solid #1F2126;display:flex;flex-direction:column;gap:5px;position:relative;}
.intel-score:last-child{border-right:none;}
.intel-score-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:#5A5F6B;font-weight:700;text-transform:uppercase;}
.intel-score-val{font-family:'Fraunces',Georgia,serif;font-size:28px;font-weight:600;color:#fff;letter-spacing:-0.025em;line-height:1;font-variant-numeric:tabular-nums;}
.intel-score-delta{font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;display:flex;align-items:center;gap:4px;}
.intel-score-delta.up{color:#7AC987;}
.intel-score-delta.dn{color:#E0B96C;}
.intel-score-delta.alert{color:#E08B7A;}
.intel-score-delta i{font-size:11px;}
.intel-score-pulse{position:absolute;top:14px;right:14px;width:7px;height:7px;border-radius:50%;background:var(--ac);animation:pulse 1.6s infinite;}

.intel-row{display:grid;grid-template-columns:1fr 380px;gap:14px;margin-bottom:18px;}

/* Density heatmap */
.intel-heat{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.intel-heat-hdr{padding:12px 16px;border-bottom:1px solid var(--cbr);display:flex;align-items:center;gap:10px;background:#FBFAF8;}
.intel-heat-icon{width:26px;height:26px;border-radius:6px;background:var(--s2);color:var(--tp);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.intel-heat-title{flex:1;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.1em;color:var(--tp);font-weight:700;text-transform:uppercase;}
.intel-heat-legend{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);}
.intel-heat-legend-dots{display:flex;gap:2px;}
.intel-heat-legend-dot{width:10px;height:10px;border-radius:2px;}
.intel-heat-body{padding:14px 16px;}
.intel-heat-axis{display:grid;grid-template-columns:100px repeat(5,1fr);gap:4px;align-items:center;}
.intel-heat-row-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.06em;color:var(--tm);font-weight:700;text-align:right;padding-right:8px;text-transform:uppercase;}
.intel-heat-col-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.06em;color:var(--tm);font-weight:700;text-align:center;padding:6px 4px;text-transform:uppercase;border-bottom:1px solid var(--cbr);}
.intel-heat-cell{aspect-ratio:1.6/1;border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;cursor:pointer;transition:all .12s;position:relative;}
.intel-heat-cell:hover{transform:scale(1.05);box-shadow:0 2px 8px rgba(15,17,21,.12);z-index:2;}
.intel-heat-cell.h0{background:#F1EFEB;color:#8B8F99;}
.intel-heat-cell.h1{background:#E0E5F6;color:#3B5BCC;}
.intel-heat-cell.h2{background:#A8B6E8;color:#fff;}
.intel-heat-cell.h3{background:#5E8AFF;color:#fff;}
.intel-heat-cell.h4{background:#C97A1B;color:#fff;}
.intel-heat-cell.h5{background:#D14343;color:#fff;}
.intel-heat-cell-pulse{position:absolute;top:3px;right:3px;width:5px;height:5px;border-radius:50%;background:#fff;animation:pulse 1.6s infinite;}

/* Live feed (right column) */
.intel-feed{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;display:flex;flex-direction:column;max-height:420px;overflow:hidden;}
.intel-feed-hdr{padding:12px 16px;border-bottom:1px solid var(--cbr);display:flex;align-items:center;gap:10px;background:#FBFAF8;flex-shrink:0;}
.intel-feed-icon{width:26px;height:26px;border-radius:6px;background:var(--lyra-bg);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.intel-feed-title{flex:1;font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.1em;color:var(--tp);font-weight:700;text-transform:uppercase;}
.intel-feed-live{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--gnt);font-weight:700;}
.intel-feed-live-dot{width:6px;height:6px;border-radius:50%;background:var(--gn);animation:pulse 1.6s infinite;}
.intel-feed-body{flex:1;overflow-y:auto;}
.intel-feed-item{padding:10px 16px;border-bottom:1px solid var(--cbr);display:flex;gap:10px;align-items:flex-start;cursor:pointer;transition:background .12s;}
.intel-feed-item:hover{background:#FBFAF8;}
.intel-feed-item:last-child{border-bottom:none;}
.intel-feed-time{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;flex-shrink:0;width:36px;padding-top:1px;}
.intel-feed-icon-sm{width:20px;height:20px;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:11px;}
.intel-feed-icon-sm.ext{background:var(--vll);color:var(--vlt);}
.intel-feed-icon-sm.int{background:var(--al);color:var(--at);}
.intel-feed-icon-sm.rel{background:var(--gnl);color:var(--gnt);}
.intel-feed-icon-sm.alert{background:var(--rdl);color:var(--rdt);}
.intel-feed-body-text{flex:1;min-width:0;font-size:12px;color:var(--tp);line-height:1.4;letter-spacing:-0.005em;}
.intel-feed-body-text strong{font-weight:600;}
.intel-feed-tag{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);margin-top:2px;}

/* Profile callouts — top of mind */
.intel-profiles{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:18px;}
.intel-profile{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;cursor:pointer;transition:all .12s;border-top:3px solid;}
.intel-profile:hover{transform:translateY(-2px);box-shadow:0 4px 14px rgba(15,17,21,.06);}
.intel-profile.threat{border-top-color:var(--rd);}
.intel-profile.persona{border-top-color:var(--at);}
.intel-profile.shift{border-top-color:var(--am);}
.intel-profile-hdr{padding:11px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--cbr);}
.intel-profile-tag{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;font-weight:700;padding:3px 7px;border-radius:4px;text-transform:uppercase;}
.intel-profile-tag.threat{background:var(--rdl);color:var(--rdt);}
.intel-profile-tag.persona{background:var(--al);color:var(--at);}
.intel-profile-tag.shift{background:var(--aml);color:var(--amt);}
.intel-profile-time{margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.intel-profile-body{padding:12px 14px;}
.intel-profile-name{font-family:'Fraunces',Georgia,serif;font-size:18px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1.15;margin-bottom:6px;}
.intel-profile-text{font-size:12.5px;color:var(--ts);line-height:1.5;margin-bottom:10px;}
.intel-profile-text strong{color:var(--tp);font-weight:600;}
.intel-profile-stats{display:flex;gap:14px;padding-top:10px;border-top:1px solid var(--cbr);}
.intel-profile-stat{display:flex;flex-direction:column;gap:1px;}
.intel-profile-stat-val{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;color:var(--tp);}
.intel-profile-stat-val.up{color:var(--rdt);}
.intel-profile-stat-val.dn{color:var(--gnt);}
.intel-profile-stat-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.06em;color:var(--tm);text-transform:uppercase;font-weight:600;}

/* BACK BAR — appears on drilled-in views */
.backbar{display:flex;align-items:center;gap:10px;padding:8px 14px;background:var(--cb);border:1px solid var(--cbr);border-radius:8px;margin-bottom:14px;}
.backbar-btn{background:transparent;border:1px solid var(--cbr);border-radius:6px;width:28px;height:28px;display:flex;align-items:center;justify-content:center;color:var(--ts);cursor:pointer;flex-shrink:0;}
.backbar-btn:hover{background:var(--s2);color:var(--tp);border-color:var(--tp);}
.backbar-btn i{font-size:14px;}
.backbar-crumbs{display:flex;align-items:center;gap:6px;flex:1;min-width:0;flex-wrap:wrap;}
.backbar-crumb{font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.06em;color:var(--tm);font-weight:600;text-transform:uppercase;cursor:pointer;}
.backbar-crumb:hover{color:var(--tp);}
.backbar-crumb.current{color:var(--tp);cursor:default;}
.backbar-crumb-sep{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--cbr);}
.backbar-meta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}

/* THEME CARDS */
.th-list{display:flex;flex-direction:column;gap:10px;}
.th-card{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;overflow:hidden;}
.th-card-hdr{display:flex;align-items:center;justify-content:space-between;gap:14px;padding:12px 18px;flex-wrap:wrap;}
.th-card-left{display:flex;align-items:center;gap:11px;min-width:0;flex:1;}
.th-status{font-size:11px;font-weight:600;padding:3px 8px;border-radius:5px;letter-spacing:-0.005em;font-family:'JetBrains Mono',monospace;text-transform:uppercase;letter-spacing:.04em;}
.th-status.active{background:#E8F2EC;color:#1F7A4A;}
.th-status.watch{background:#FAF3E7;color:#7A4A0F;}
.th-status.dropped{background:var(--s2);color:var(--tm);}
.th-kind{font-size:10.5px;font-weight:600;color:var(--tm);padding:3px 7px;border-radius:5px;background:var(--s2);text-transform:uppercase;letter-spacing:.04em;font-family:'JetBrains Mono',monospace;}
.th-kind.prod{background:var(--al);color:var(--at);}
.th-kind.gtm{background:var(--vll);color:var(--vlt);}
.th-name{font-size:14.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.th-right{display:flex;align-items:center;gap:14px;}
.th-count{font-family:'JetBrains Mono',monospace;font-size:11.5px;color:var(--tm);}
.th-owner{font-size:11.5px;color:var(--ts);font-weight:500;font-family:'JetBrains Mono',monospace;}
.th-action{background:none;border:none;color:var(--tm);cursor:pointer;font-size:16px;padding:0 4px;}
.th-action:hover{color:var(--tp);}

/* THEME PROFILES — deep view (Palantir-style intel profile per theme) */
.thp-list{display:flex;flex-direction:column;gap:14px;}
.thp{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;border-left:3px solid var(--cbr);}
.thp.active{border-left-color:var(--gn);}
.thp.watch{border-left-color:var(--am);}
.thp.escalating{border-left-color:var(--rd);}
.thp-hdr{display:grid;grid-template-columns:1fr auto;gap:18px;padding:14px 18px;border-bottom:1px solid var(--cbr);align-items:flex-start;background:#FBFAF8;}
.thp-id{min-width:0;}
.thp-id-row{display:flex;align-items:center;gap:9px;margin-bottom:5px;flex-wrap:wrap;}
.thp-code{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.08em;color:var(--tm);font-weight:700;background:var(--s2);padding:2px 6px;border-radius:4px;}
.thp-status{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;padding:3px 7px;border-radius:4px;text-transform:uppercase;}
.thp-status.active{background:var(--gnl);color:var(--gnt);}
.thp-status.watch{background:var(--aml);color:var(--amt);}
.thp-status.escalating{background:var(--rdl);color:var(--rdt);}
.thp-trend{display:inline-flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;}
.thp-trend.up{color:var(--rdt);}
.thp-trend.dn{color:var(--gnt);}
.thp-trend.flat{color:var(--tm);}
.thp-trend i{font-size:12px;}
.thp-name{font-family:'Fraunces',Georgia,serif;font-size:18px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1.2;}
.thp-tagline{font-size:12.5px;color:var(--ts);line-height:1.5;margin-top:4px;max-width:640px;}
.thp-mini{display:flex;flex-direction:column;gap:8px;align-items:flex-end;}
.thp-mini-stat{display:flex;align-items:baseline;gap:6px;}
.thp-mini-val{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;color:var(--tp);}
.thp-mini-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.06em;color:var(--tm);text-transform:uppercase;}
.thp-owner{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--ts);font-weight:600;}

.thp-body{display:grid;grid-template-columns:280px 1fr;}
.thp-trend-col{padding:14px 18px;border-right:1px solid var(--cbr);background:#FBFAF8;}
.thp-trend-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:8px;}
.thp-spark{display:flex;align-items:flex-end;gap:2px;height:50px;}
.thp-spark-bar{flex:1;border-radius:2px 2px 0 0;opacity:.85;}
.thp-trend-x{display:flex;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);margin-top:5px;}
.thp-impact{margin-top:14px;display:flex;flex-direction:column;gap:5px;}
.thp-impact-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.thp-impact-row{display:flex;align-items:center;gap:7px;font-size:11.5px;color:var(--ts);letter-spacing:-0.005em;}
.thp-impact-row i{font-size:12px;color:var(--at);}
.thp-impact-row strong{color:var(--tp);font-weight:600;}

.thp-evidence{padding:12px 18px;}
.thp-evidence-lbl{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.thp-evidence-lbl-text{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.thp-evidence-filter{display:flex;gap:4px;}
.thp-evidence-filter-btn{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.06em;font-weight:700;color:var(--tm);background:var(--s2);border:none;border-radius:4px;padding:3px 7px;cursor:pointer;text-transform:uppercase;}
.thp-evidence-filter-btn.active{background:var(--tp);color:#fff;}
.thp-evidence-list{display:flex;flex-direction:column;gap:4px;}
.thp-ev{display:grid;grid-template-columns:50px 20px 1fr auto;gap:9px;align-items:center;padding:7px 10px;border-radius:6px;cursor:pointer;transition:background .12s;}
.thp-ev:hover{background:#FBFAF8;}
.thp-ev-id{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--at);font-weight:700;letter-spacing:.04em;}
.thp-ev-icon{width:18px;height:18px;border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:10px;}
.thp-ev-icon.int{background:var(--al);color:var(--at);}
.thp-ev-icon.ext{background:var(--vll);color:var(--vlt);}
.thp-ev-icon.alert{background:var(--rdl);color:var(--rdt);}
.thp-ev-icon.rel{background:var(--gnl);color:var(--gnt);}
.thp-ev-text{font-size:12px;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;min-width:0;}
.thp-ev-text strong{font-weight:600;}
.thp-ev-meta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;text-align:right;}

.thp-foot{padding:10px 18px;border-top:1px solid var(--cbr);background:#FBFAF8;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.thp-foot-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.thp-foot-tie{display:inline-flex;align-items:center;gap:5px;font-size:11px;color:var(--ts);background:var(--cb);border:1px solid var(--cbr);border-radius:5px;padding:3px 8px;letter-spacing:-0.005em;cursor:pointer;transition:all .12s;}
.thp-foot-tie:hover{background:var(--al);color:var(--at);border-color:#CBD7FF;}
.thp-foot-tie i{font-size:11px;}
.thp-foot-tie.proposal{background:var(--lyra-bg);color:var(--at);border-color:#CBD7FF;font-weight:600;}
.thp-foot-tie.release{background:var(--gnl);color:var(--gnt);border-color:#B8DBC5;font-weight:600;}
.thp-foot-cta{margin-left:auto;}

/* Signal reference chip — used inline elsewhere in the app to point back to Signals */
.sgref{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--at);background:var(--al);border:1px solid #CBD7FF;border-radius:4px;padding:2px 7px;cursor:pointer;font-weight:600;letter-spacing:.02em;text-decoration:none;transition:all .12s;}
.sgref:hover{background:#DCE5FF;}
.sgref i{font-size:11px;}

/* CANDIDATE THEMES */
.cand-list{display:flex;flex-direction:column;background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.cand-row{display:grid;grid-template-columns:100px 1fr auto;align-items:flex-start;gap:18px;padding:14px 20px;border-bottom:1px solid var(--cbr);transition:background .12s;}
.cand-row:last-child{border-bottom:none;}
.cand-row:hover{background:#FBFAF8;}
.cand-row.proposed{background:linear-gradient(0deg,var(--lyra-bg),#FCFDFF);border-left:3px solid var(--ac);padding-left:17px;}
.cand-row.dropped{opacity:0.55;}
.cand-status{font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding-top:3px;}
.cand-status.evaluating{color:var(--amt);}
.cand-status.exploring{color:var(--at);}
.cand-status.validated{color:var(--gnt);}
.cand-status.dropped{color:var(--tm);}
.cand-status.proposed{color:var(--at);}
.cand-body{min-width:0;}
.cand-title{font-size:14px;font-weight:600;color:var(--tp);letter-spacing:-0.01em;line-height:1.35;margin-bottom:3px;}
.cand-desc{font-size:13px;color:var(--ts);line-height:1.5;margin-bottom:8px;}
.cand-drivers{display:flex;gap:6px;flex-wrap:wrap;}
.cand-driver{display:inline-flex;align-items:center;gap:6px;font-size:11.5px;color:var(--ts);background:var(--s2);border-radius:5px;padding:3px 8px;letter-spacing:-0.005em;}
.cand-driver-dot{width:6px;height:6px;border-radius:50%;}
.cand-driver-dot.persona{background:#3D7AC4;}
.cand-driver-dot.comp{background:#C97A1B;}
.cand-driver-dot.trend{background:#6B6FE0;}
.cand-meta{display:flex;flex-direction:column;align-items:flex-end;gap:6px;font-size:11.5px;color:var(--tm);min-width:90px;}
.cand-owner{font-weight:500;color:var(--ts);font-family:'JetBrains Mono',monospace;}
.cand-updated{font-family:'JetBrains Mono',monospace;}
.cand-actions{display:flex;gap:6px;}
.cand-accept{background:var(--tp);color:#fff;border:none;border-radius:5px;padding:4px 10px;font-family:'Inter',sans-serif;font-size:11.5px;font-weight:600;cursor:pointer;}
.cand-reject{background:transparent;border:1px solid var(--cbr);color:var(--ts);border-radius:5px;padding:4px 10px;font-family:'Inter',sans-serif;font-size:11.5px;font-weight:500;cursor:pointer;}

/* ============ COMPETITORS ============ */
.comp-types{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px;}
.comp-type{background:var(--cb);border:1px solid var(--cbr);border-radius:14px;padding:28px;cursor:pointer;transition:all .15s;display:flex;flex-direction:column;gap:14px;}
.comp-type:hover{border-color:var(--ac);transform:translateY(-2px);box-shadow:0 4px 12px rgba(15,17,21,.05);}
.comp-type.gc{border-top:3px solid var(--at);}
.comp-type.fr{border-top:3px solid var(--vl);}
.comp-type-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;}
.comp-type-icon.gc{background:var(--al);color:var(--at);}
.comp-type-icon.fr{background:var(--vll);color:var(--vlt);}
.comp-type-icon i{font-size:22px;}
.comp-type-name{font-size:20px;font-weight:700;color:var(--tp);letter-spacing:-0.015em;}
.comp-type-desc{font-size:13.5px;color:var(--ts);line-height:1.55;}
.comp-type-count{font-family:'JetBrains Mono',monospace;font-size:11.5px;font-weight:700;color:var(--at);background:var(--al);padding:3px 9px;border-radius:4px;display:inline-block;width:fit-content;}
.comp-type.fr .comp-type-count{color:var(--vlt);background:var(--vll);}

.comp-list{display:flex;flex-direction:column;background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.comp-row{display:grid;grid-template-columns:auto 1fr auto auto;align-items:center;gap:18px;padding:14px 20px;border-bottom:1px solid var(--cbr);cursor:pointer;transition:background .12s;}
.comp-row:last-child{border-bottom:none;}
.comp-row:hover{background:#FBFAF8;}
.comp-row.empty{opacity:.65;cursor:default;}
.comp-row.empty:hover{background:transparent;}
.comp-mark{width:34px;height:34px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;flex-shrink:0;}
.comp-mark.gc{background:var(--al);color:var(--at);}
.comp-mark.fr{background:var(--vll);color:var(--vlt);}
.comp-mark.mu{background:var(--s2);color:var(--tm);}
.comp-body{min-width:0;}
.comp-name{font-size:14.5px;font-weight:600;color:var(--tp);letter-spacing:-0.01em;margin-bottom:2px;}
.comp-desc{font-size:12.5px;color:var(--ts);line-height:1.4;}
.comp-threat{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;padding:3px 8px;border-radius:5px;letter-spacing:.04em;text-transform:uppercase;}
.comp-threat.high{background:var(--rdl);color:var(--rdt);}
.comp-threat.mid{background:var(--aml);color:var(--amt);}
.comp-threat.emerging{background:var(--vll);color:var(--vlt);}
.comp-threat.none{background:var(--s2);color:var(--tm);}
.comp-status{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--ts);font-weight:600;}
.comp-status.empty{color:var(--tm);}

/* TOOLBAR */
.toolbar{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:20px;flex-wrap:wrap;}
.toolbar-left{display:flex;gap:8px;align-items:center;flex-wrap:wrap;}
.toolbar-right{display:flex;gap:8px;align-items:center;}
.btn-add{background:var(--tp);color:#fff;border:none;border-radius:7px;padding:7px 14px;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.btn-add:hover{background:#2A2D33;}
.btn-add i{font-size:14px;}
.btn-back{background:transparent;border:1px solid var(--cbr);border-radius:7px;padding:6px 12px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.btn-back:hover{color:var(--tp);border-color:var(--tp);}

/* ============ COMPETITOR ANALYST AREA ============ */
.an-header{display:grid;grid-template-columns:auto 1fr auto;gap:18px;align-items:center;background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:18px 20px;margin-bottom:18px;}
.an-logo{width:56px;height:56px;border-radius:10px;background:var(--al);color:var(--at);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700;}
.an-id{display:flex;flex-direction:column;gap:6px;min-width:0;}
.an-name-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.an-name{font-family:'Fraunces',Georgia,serif;font-size:24px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1;}
.an-domain{font-family:'JetBrains Mono',monospace;font-size:11.5px;color:var(--tm);}
.an-tagline{font-size:13px;color:var(--ts);line-height:1.45;}
.an-stats{display:flex;gap:18px;align-items:center;flex-shrink:0;}
.an-stat{display:flex;flex-direction:column;gap:2px;text-align:right;}
.an-stat-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);text-transform:uppercase;font-weight:600;}
.an-stat-val{font-family:'Fraunces',Georgia,serif;font-size:18px;font-weight:600;color:var(--tp);letter-spacing:-0.015em;line-height:1;}
.an-stat-val.high{color:var(--rdt);}
.an-stat-val.up{color:var(--rdt);}
.an-stat-val.dn{color:var(--gnt);}

.an-tabs{display:flex;border-bottom:1px solid var(--cbr);margin-bottom:22px;gap:0;}
.an-tab{display:flex;align-items:center;gap:7px;background:transparent;border:none;padding:11px 18px 13px;font-size:13.5px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .12s;}
.an-tab:hover{color:var(--ts);}
.an-tab.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);}
.an-tab i{font-size:14px;}

/* BATTLECARD */
.bc-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.bc-card{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:16px 18px;}
.bc-card.full{grid-column:1/-1;}
.bc-card-hdr{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
.bc-card-icon{width:26px;height:26px;border-radius:6px;background:var(--s2);color:var(--tp);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.bc-card-icon.win{background:var(--gnl);color:var(--gnt);}
.bc-card-icon.lose{background:var(--rdl);color:var(--rdt);}
.bc-card-icon.diff{background:var(--al);color:var(--at);}
.bc-card-icon.obj{background:var(--aml);color:var(--amt);}
.bc-card-icon.mine{background:var(--vll);color:var(--vlt);}
.bc-card-title{font-size:13.5px;font-weight:700;color:var(--tp);letter-spacing:-0.005em;}
.bc-list{list-style:none;padding:0;display:flex;flex-direction:column;gap:9px;}
.bc-li{display:flex;gap:9px;align-items:flex-start;font-size:13px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;}
.bc-li-bullet{flex-shrink:0;width:6px;height:6px;border-radius:50%;margin-top:7px;}
.bc-li-bullet.win{background:var(--gn);}
.bc-li-bullet.lose{background:var(--rd);}
.bc-li-bullet.diff{background:var(--ac);}
.bc-li-bullet.obj{background:var(--am);}
.bc-li-bullet.mine{background:var(--vl);}
.bc-li-text{flex:1;}
.bc-li-text strong{font-weight:600;}
.bc-positioning{font-size:14px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;font-style:italic;}
.bc-pos-quote{display:block;padding:8px 14px;background:#FBFAF8;border-left:3px solid var(--ac);border-radius:0 8px 8px 0;margin-top:8px;font-size:13.5px;line-height:1.55;color:var(--ts);}

/* PRODUCT MATRIX */
.pm-overview{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:16px 18px;margin-bottom:18px;}
.pm-overview-hdr{font-size:13.5px;font-weight:700;color:var(--tp);margin-bottom:10px;letter-spacing:-0.005em;}
.pm-overview-text{font-size:13px;color:var(--ts);line-height:1.55;}
.pm-overview-text strong{color:var(--tp);font-weight:600;}
.pm-table{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;overflow:hidden;}
.pm-row{display:grid;grid-template-columns:200px 1fr 1fr;align-items:stretch;border-bottom:1px solid var(--cbr);}
.pm-row:last-child{border-bottom:none;}
.pm-row.head{background:#FBFAF8;font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--tm);font-weight:700;}
.pm-row.head .pm-cell{padding:10px 16px;}
.pm-cell{padding:12px 16px;font-size:13px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;}
.pm-cell.feat{font-weight:600;background:#FBFAF8;border-right:1px solid var(--cbr);}
.pm-cell.us{border-right:1px solid var(--cbr);}
.pm-cell-mark{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-family:'JetBrains Mono',monospace;font-weight:700;padding:2px 7px;border-radius:4px;margin-bottom:4px;letter-spacing:.04em;text-transform:uppercase;}
.pm-mark-strong{background:var(--gnl);color:var(--gnt);}
.pm-mark-parity{background:var(--s2);color:var(--ts);}
.pm-mark-weak{background:var(--rdl);color:var(--rdt);}
.pm-mark-gap{background:var(--aml);color:var(--amt);}

/* SCOPED INTERNAL SIGNALS */
.an-sig-list{display:flex;flex-direction:column;gap:10px;}
.an-sig{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:14px 18px;display:grid;grid-template-columns:1fr auto;gap:14px;align-items:center;}
.an-sig-body{min-width:0;}
.an-sig-name{font-size:13.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-bottom:4px;}
.an-sig-text{font-size:12.5px;color:var(--ts);line-height:1.5;}
.an-sig-text strong{color:var(--tp);font-weight:600;}
.an-sig-meta{display:flex;flex-direction:column;align-items:flex-end;gap:4px;flex-shrink:0;}
.an-sig-trend{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:11.5px;font-weight:700;}
.an-sig-trend.bad{color:var(--rdt);}
.an-sig-trend.good{color:var(--gnt);}
.an-sig-trend.flat{color:var(--tm);}
.an-sig-trend i{font-size:13px;}
.an-sig-source{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);}

/* CI FEED */
.ci-groups{display:flex;flex-direction:column;gap:18px;}
.ci-group{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;overflow:hidden;}
.ci-group-hdr{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;background:#FBFAF8;border-bottom:1px solid var(--cbr);}
.ci-group-title{display:flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--tp);font-weight:700;}
.ci-group-title i{font-size:13px;}
.ci-group-count{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.ci-item{padding:12px 16px;display:grid;grid-template-columns:90px 1fr;gap:14px;border-bottom:1px solid var(--cbr);align-items:flex-start;}
.ci-item:last-child{border-bottom:none;}
.ci-item-when{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:600;padding-top:1px;}
.ci-item-body{min-width:0;}
.ci-item-title{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;margin-bottom:3px;}
.ci-item-text{font-size:12.5px;color:var(--ts);line-height:1.5;}
.ci-item-foot{display:flex;align-items:center;gap:8px;margin-top:5px;flex-wrap:wrap;}
.ci-item-source{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--at);font-weight:700;}
.ci-item-tag{display:inline-flex;align-items:center;gap:5px;font-size:11px;color:var(--ts);background:var(--s2);border-radius:4px;padding:2px 7px;}
.ci-item-tag.lyra{background:var(--lyra-bg);color:var(--at);}

/* ============ RELEASES TIMELINE ============ */
.rel-list{display:flex;flex-direction:column;gap:14px;}
.rel-card{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;border-left:3px solid;}
.rel-card.shipped{border-left-color:var(--gn);}
.rel-card.flight{border-left-color:var(--ac);}
.rel-card.planning{border-left-color:var(--am);}
.rel-card.future{border-left-color:var(--tm);}
.rel-top{display:flex;justify-content:space-between;gap:18px;padding:16px 20px;flex-wrap:wrap;}
.rel-top-left{flex:1;min-width:0;}
.rel-ver-row{display:flex;align-items:center;gap:10px;margin-bottom:8px;flex-wrap:wrap;}
.rel-ver{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;background:var(--tp);color:#fff;padding:3px 9px;border-radius:4px;}
.rel-status{font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;padding:3px 8px;border-radius:4px;letter-spacing:.08em;text-transform:uppercase;}
.rel-status.shipped{background:var(--gnl);color:var(--gnt);}
.rel-status.flight{background:var(--al);color:var(--at);}
.rel-status.planning{background:var(--aml);color:var(--amt);}
.rel-status.future{background:var(--s2);color:var(--tm);}
.rel-date{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);}
.rel-title{font-size:15.5px;font-weight:700;color:var(--tp);letter-spacing:-0.01em;line-height:1.35;margin-bottom:5px;}
.rel-summary{font-size:13px;color:var(--ts);line-height:1.55;}
.rel-tabs{display:flex;gap:0;padding:0 20px;border-top:1px solid var(--cbr);background:#FBFAF8;}
.rel-tab{background:transparent;border:none;padding:9px 14px 11px;font-size:12.5px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;display:flex;align-items:center;gap:6px;}
.rel-tab:hover{color:var(--ts);}
.rel-tab.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);background:var(--cb);}
.rel-tab i{font-size:13px;}
.rel-pane{padding:16px 20px;}

.rel-stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:10px;margin-bottom:16px;}
.rel-stat-tile{background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;padding:12px 14px;}
.rel-stat-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--tm);font-weight:600;margin-bottom:4px;}
.rel-stat-val{font-family:'Fraunces',Georgia,serif;font-size:24px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1;}
.rel-stat-delta{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;margin-top:3px;}
.rel-stat-delta.up{color:var(--gnt);}
.rel-stat-delta.dn{color:var(--rdt);}

/* RELEASES · PR + GTM IMPACT DIFFS */
.imp-split{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.imp-col{background:#FBFAF8;border:1px solid var(--cbr);border-radius:10px;overflow:hidden;}
.imp-col-hdr{padding:9px 14px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--cbr);}
.imp-col.pr .imp-col-hdr{background:linear-gradient(0deg,var(--al),#F5F8FF);border-bottom-color:#CBD7FF;}
.imp-col.gtm .imp-col-hdr{background:linear-gradient(0deg,var(--vll),#F4F5FC);border-bottom-color:#C6CAEC;}
.imp-col-icon{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:13px;}
.imp-col.pr .imp-col-icon{background:var(--cb);color:var(--at);border:1px solid #CBD7FF;}
.imp-col.gtm .imp-col-icon{background:var(--cb);color:var(--vlt);border:1px solid #C6CAEC;}
.imp-col-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;font-weight:700;flex:1;}
.imp-col.pr .imp-col-lbl{color:var(--at);}
.imp-col.gtm .imp-col-lbl{color:var(--vlt);}
.imp-col-count{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.imp-col-body{padding:8px;}

.imp-diff{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:11px 13px;margin-bottom:6px;}
.imp-diff:last-child{margin-bottom:0;}
.imp-diff-target{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.imp-diff-target-icon{width:22px;height:22px;border-radius:5px;background:var(--s2);color:var(--ts);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;}
.imp-diff-path{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:600;flex:1;letter-spacing:.02em;}
.imp-diff-path strong{color:var(--tp);}
.imp-diff-state{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.08em;font-weight:700;padding:2px 6px;border-radius:4px;text-transform:uppercase;}
.imp-diff-state.auto{background:var(--gnl);color:var(--gnt);}
.imp-diff-state.draft{background:var(--aml);color:var(--amt);}
.imp-diff-state.block{background:var(--rdl);color:var(--rdt);}
.imp-diff-rows{display:flex;flex-direction:column;gap:4px;}
.imp-diff-row{display:grid;grid-template-columns:50px 1fr;gap:9px;align-items:start;font-size:12px;line-height:1.45;letter-spacing:-0.005em;}
.imp-diff-row-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.1em;font-weight:700;padding-top:2px;}
.imp-diff-row.old .imp-diff-row-lbl{color:var(--rdt);}
.imp-diff-row.new .imp-diff-row-lbl{color:var(--at);}
.imp-diff-row.old .imp-diff-row-val{color:var(--ts);text-decoration:line-through;text-decoration-color:rgba(209,67,67,.4);}
.imp-diff-row.new .imp-diff-row-val{color:var(--tp);background:linear-gradient(0deg,rgba(94,138,255,.08),rgba(94,138,255,.08));padding:1px 5px;margin:-1px -5px;border-radius:3px;}
.imp-diff-row-val{font-size:12.5px;}
.imp-diff-row-val strong{font-weight:600;}

.imp-summary-strip{display:flex;align-items:center;gap:14px;padding:10px 14px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;margin-bottom:14px;flex-wrap:wrap;}
.imp-summary-stat{display:flex;align-items:center;gap:6px;font-size:12.5px;color:var(--ts);}
.imp-summary-stat strong{color:var(--tp);font-weight:700;font-family:'JetBrains Mono',monospace;font-size:13px;}
.imp-summary-stat i{font-size:13px;}
.imp-summary-stat.pr strong{color:var(--at);}
.imp-summary-stat.gtm strong{color:var(--vlt);}
.imp-summary-vdiv{width:1px;height:18px;background:var(--cbr);}
.imp-summary-cta{margin-left:auto;display:flex;gap:6px;}
.imp-summary-btn{background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:5px 11px;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--ts);cursor:pointer;display:flex;align-items:center;gap:5px;letter-spacing:-0.005em;}
.imp-summary-btn:hover{background:var(--s2);color:var(--tp);}
.imp-summary-btn.prim{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.imp-summary-btn.prim:hover{background:#2A2D33;color:#fff;}
.imp-summary-btn i{font-size:13px;}

/* PROTOTYPE TILES (list view) */
.pt-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;}
.pt-card{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:16px 18px;display:flex;flex-direction:column;gap:10px;cursor:pointer;transition:all .12s;}
.pt-card:hover{border-color:#D9D5CC;background:#FBFAF8;}
.pt-card-hdr{display:flex;align-items:center;gap:9px;}
.pt-card-icon{width:32px;height:32px;border-radius:7px;background:var(--lyra-bg);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.pt-card-title{flex:1;font-size:14px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.pt-card-active{font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;color:var(--at);background:var(--al);padding:2px 7px;border-radius:4px;}
.pt-card-desc{font-size:12.5px;color:var(--ts);line-height:1.55;}
.pt-card-foot{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);padding-top:8px;border-top:1px solid var(--cbr);margin-top:auto;}

/* ============ ROADMAP — breathing intent layer ============ */

/* View-mode tabs (Horizons / Releases) */
.rm-modes{display:flex;border-bottom:1px solid var(--cbr);gap:0;margin-bottom:18px;}
.rm-mode-btn{background:transparent;border:none;padding:10px 18px 12px;font-size:13.5px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;display:flex;align-items:center;gap:7px;}
.rm-mode-btn:hover{color:var(--ts);}
.rm-mode-btn.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);}
.rm-mode-btn i{font-size:14px;}
.rm-mode-pill{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.rm-mode-btn.active .rm-mode-pill{color:var(--at);}
.rm-horizons{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.rm-horizon{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:14px 16px;display:flex;flex-direction:column;gap:10px;min-height:280px;}
.rm-horizon-hdr{display:flex;align-items:center;justify-content:space-between;padding-bottom:9px;border-bottom:1px solid var(--cbr);}
.rm-horizon-name{font-family:'Fraunces',Georgia,serif;font-size:17px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;}
.rm-horizon-meta{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.1em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.rm-item{background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;padding:9px 12px;border-left:3px solid;}
.rm-item.capture{border-left-color:var(--at);}
.rm-item.proposal{border-left-color:var(--vlt);}
.rm-item.compliance{border-left-color:var(--gnt);}
.rm-item.pricing{border-left-color:var(--amt);}
.rm-item-theme{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.1em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:3px;}
.rm-item-name{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.35;margin-bottom:3px;}
.rm-item-meta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}


/* ============ AGENTS — extends the existing design system ============ */
/* Pulse keyframe for live indicator */
@keyframes ag-pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.55;transform:scale(.85);}}

/* CARD GRID */
.ag-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:14px;}

/* CARD — same surface as everywhere, with subtle accent presence */
.ag-card{background:var(--cb);border:1px solid var(--cbr);border-radius:14px;padding:0;display:flex;flex-direction:column;cursor:pointer;transition:all .18s ease;position:relative;overflow:hidden;}
.ag-card::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent,var(--ac));opacity:.5;transition:opacity .18s, height .18s;}
.ag-card::after{content:"";position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(120% 60% at 0% 0%, var(--accent-wash,rgba(94,138,255,.04)) 0%, transparent 60%);pointer-events:none;opacity:1;}
.ag-card.cpo{--accent:var(--at);--accent-wash:rgba(94,138,255,.05);}
.ag-card.cro{--accent:var(--vlt);--accent-wash:rgba(64,68,168,.045);}
.ag-card.ceo{--accent:var(--gnt);--accent-wash:rgba(45,128,84,.045);}
.ag-card:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(15,17,21,.06);border-color:#D9D5CC;}
.ag-card:hover::before{height:3px;opacity:1;}

/* TOP — avatar + identity + live indicator */
.ag-top{padding:16px 18px 10px;display:grid;grid-template-columns:36px 1fr auto;gap:12px;align-items:center;position:relative;}
.ag-av{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:'Fraunces',Georgia,serif;font-size:17px;font-weight:600;letter-spacing:-0.01em;}
.ag-card.cpo .ag-av{background:var(--al);color:var(--at);}
.ag-card.cro .ag-av{background:var(--vll);color:var(--vlt);}
.ag-card.ceo .ag-av{background:var(--gnl);color:var(--gnt);}
.ag-id{min-width:0;}
.ag-role{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;line-height:1;}
.ag-name{font-family:'Fraunces',Georgia,serif;font-size:17px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;margin-top:4px;line-height:1.15;}
.ag-live{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;color:var(--accent,var(--at));letter-spacing:.1em;text-transform:uppercase;}
.ag-live-dot{width:6px;height:6px;border-radius:50%;background:var(--accent,var(--at));animation:ag-pulse 2.2s ease-in-out infinite;}

/* ACTIVITY — single-line what it's doing right now */
.ag-now{padding:2px 18px 14px;display:flex;align-items:center;gap:7px;}
.ag-now-ic{font-size:12px;color:var(--accent,var(--at));flex-shrink:0;}
.ag-now-text{font-size:12.5px;color:var(--ts);line-height:1.4;letter-spacing:-0.005em;}
.ag-now-text strong{color:var(--tp);font-weight:600;}

/* STATS strip — big mono numerics, tiny labels */
.ag-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:1px solid var(--cbr);border-bottom:1px solid var(--cbr);background:#FBFAF8;}
.ag-stat{padding:10px 0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;border-right:1px solid var(--cbr);position:relative;}
.ag-stat:last-child{border-right:none;}
.ag-stat-val{font-family:'JetBrains Mono',monospace;font-size:17px;font-weight:700;color:var(--tp);letter-spacing:-0.015em;line-height:1;}
.ag-stat-lbl{font-family:'JetBrains Mono',monospace;font-size:8.5px;letter-spacing:.1em;color:var(--tm);font-weight:600;text-transform:uppercase;}

/* SCOPE — soft inline strip, no boxes */
.ag-scope{padding:10px 18px;display:flex;gap:10px;align-items:baseline;}
.ag-scope-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.14em;color:var(--tm);font-weight:700;text-transform:uppercase;flex-shrink:0;}
.ag-scope-val{font-size:11.5px;color:var(--ts);line-height:1.5;letter-spacing:-0.005em;}
.ag-scope-val span{color:var(--tp);font-weight:600;}

/* LATEST observation — single emphasized line */
.ag-latest{padding:0 18px 14px;display:flex;flex-direction:column;gap:5px;border-top:1px dashed var(--cbr);margin-top:0;padding-top:11px;}
.ag-latest-top{display:flex;align-items:center;justify-content:space-between;}
.ag-latest-lbl{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.14em;color:var(--accent,var(--at));font-weight:700;text-transform:uppercase;}
.ag-latest-lbl i{font-size:11px;}
.ag-latest-time{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;}
.ag-latest-text{font-size:12.5px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;}
.ag-latest-text strong{font-weight:600;}

/* FOOT — two actions, restrained */
.ag-foot{padding:10px 12px;display:grid;grid-template-columns:1fr 1fr;gap:6px;border-top:1px solid var(--cbr);background:#FBFAF8;}

/* Needs your attention — the only signal block on the card */
.ag-needs{padding:11px 16px 14px;display:flex;align-items:center;gap:10px;border-top:1px solid var(--cbr);}
.ag-needs-count{font-family:'JetBrains Mono',monospace;font-size:22px;font-weight:700;color:var(--tp);letter-spacing:-0.02em;line-height:1;}
.ag-needs-body{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px;}
.ag-needs-lbl{font-size:12.5px;color:var(--tp);font-weight:600;letter-spacing:-0.005em;line-height:1.3;}
.ag-needs-meta{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.ag-needs.zero .ag-needs-count{color:var(--tm);}
.ag-needs.zero .ag-needs-lbl{color:var(--ts);font-weight:500;}
.ag-foot-btn{background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:7px 0;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;justify-content:center;gap:5px;transition:all .12s;}
.ag-foot-btn:hover{background:var(--s2);color:var(--tp);border-color:#D9D5CC;}
.ag-foot-btn i{font-size:13px;}
.ag-foot-btn.talk{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.ag-foot-btn.talk:hover{background:#2A2D33;border-color:#2A2D33;color:#fff;}

/* CUSTOM / NEW agent card */
.ag-card.custom{cursor:pointer;border-style:dashed;align-items:center;justify-content:center;text-align:center;min-height:260px;padding:24px;}
.ag-card.custom::before{display:none;}
.ag-card.custom::after{display:none;}
.ag-card.custom:hover{background:#FBFAF8;border-color:var(--ac);}
.ag-custom-icon{width:44px;height:44px;border-radius:11px;background:var(--s2);color:var(--tm);display:flex;align-items:center;justify-content:center;font-size:22px;margin-bottom:10px;transition:all .15s;}
.ag-card.custom:hover .ag-custom-icon{background:var(--al);color:var(--at);}
.ag-custom-name{font-family:'Fraunces',Georgia,serif;font-size:17px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;margin-bottom:4px;}
.ag-custom-desc{font-size:12px;color:var(--ts);line-height:1.5;max-width:220px;}


/* ============ AGENT PROFILE — same surface, more density ============ */
.agp-hdr{background:var(--cb);border:1px solid var(--cbr);border-radius:14px;padding:18px 22px;display:grid;grid-template-columns:54px 1fr auto;gap:16px;align-items:center;margin-bottom:14px;position:relative;overflow:hidden;}
.agp-hdr::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent,var(--ac));opacity:.7;}
.agp-hdr::after{content:"";position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(100% 100% at 0% 0%, var(--accent-wash,rgba(94,138,255,.04)) 0%, transparent 50%);pointer-events:none;}
.agp-hdr.cpo{--accent:var(--at);--accent-wash:rgba(94,138,255,.05);}
.agp-hdr.cro{--accent:var(--vlt);--accent-wash:rgba(64,68,168,.045);}
.agp-hdr.ceo{--accent:var(--gnt);--accent-wash:rgba(45,128,84,.045);}
.agp-avatar{width:54px;height:54px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-family:'Fraunces',Georgia,serif;font-size:24px;font-weight:600;position:relative;z-index:1;letter-spacing:-0.02em;}
.agp-hdr.cpo .agp-avatar{background:var(--al);color:var(--at);}
.agp-hdr.cro .agp-avatar{background:var(--vll);color:var(--vlt);}
.agp-hdr.ceo .agp-avatar{background:var(--gnl);color:var(--gnt);}
.agp-name{font-family:'Fraunces',Georgia,serif;font-size:22px;font-weight:600;color:var(--tp);letter-spacing:-0.025em;line-height:1.1;}
.agp-role{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-top:4px;}
.agp-summary{font-size:12.5px;color:var(--ts);line-height:1.55;margin-top:8px;letter-spacing:-0.005em;max-width:580px;}
.agp-state-col{display:flex;flex-direction:column;gap:8px;align-items:flex-end;position:relative;z-index:1;}
.agp-state-pill{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;color:var(--accent,var(--at));letter-spacing:.1em;text-transform:uppercase;padding:4px 10px;background:var(--cb);border:1px solid var(--accent,var(--at));border-radius:5px;}
.agp-state-pill .ag-state-dot-circle{width:6px;height:6px;border-radius:50%;background:var(--accent,var(--at));animation:ag-pulse 2.2s ease-in-out infinite;}
.agp-talk{background:var(--tp);color:#fff;border:none;border-radius:7px;padding:7px 13px;font-family:'Inter',sans-serif;font-size:12px;font-weight:600;cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;transition:all .12s;}
.agp-talk:hover{background:#2A2D33;}
.agp-talk i{font-size:13px;}

/* Profile two-column grid */
.agp-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.agp-col{display:flex;flex-direction:column;gap:12px;}

/* Card shell */
.agp-card{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.agp-card-hdr{padding:11px 14px;border-bottom:1px solid var(--cbr);display:flex;align-items:center;justify-content:space-between;background:#FBFAF8;}
.agp-card-title{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.14em;color:var(--tp);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:6px;}
.agp-card-title i{font-size:12px;color:var(--tm);}
.agp-card-cta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--at);background:transparent;border:none;cursor:pointer;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.agp-card-cta:hover{color:var(--tp);}

/* Scope chips — light, consistent with rest of app */
.agp-scope-grid{padding:11px 14px;display:flex;flex-wrap:wrap;gap:5px;}
.agp-scope-pill{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ts);background:#FBFAF8;border:1px solid var(--cbr);border-radius:5px;padding:4px 8px;font-weight:600;letter-spacing:.04em;}
.agp-scope-pill i{font-size:11px;color:var(--at);}
.agp-scope-add{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--at);background:transparent;border:1px dashed var(--cbr);border-radius:5px;padding:4px 8px;font-weight:600;cursor:pointer;letter-spacing:.04em;}
.agp-scope-add:hover{border-color:var(--ac);background:var(--lyra-bg);}

/* Skills tiles */
.agp-skills-grid{padding:11px 14px;display:grid;grid-template-columns:repeat(2,1fr);gap:6px;}
.agp-skill-tile{background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;padding:9px 11px;cursor:pointer;transition:all .12s;}
.agp-skill-tile:hover{border-color:#D9D5CC;background:var(--cb);}
.agp-skill-tile-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px;}
.agp-skill-tile-name{font-size:11.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.agp-skill-tile-uses{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;}
.agp-skill-tile-bar{height:3px;background:var(--cbr);border-radius:2px;overflow:hidden;}
.agp-skill-tile-bar-fill{height:100%;background:var(--accent,var(--at));border-radius:2px;}

/* Connections */
.agp-conn-list{padding:6px 14px 10px;display:flex;flex-direction:column;}
.agp-conn{display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:center;padding:8px 0;border-bottom:1px dashed var(--cbr);}
.agp-conn:last-child{border-bottom:none;}
.agp-conn-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.agp-conn-dot.live{background:var(--gn);box-shadow:0 0 0 3px rgba(74,166,108,.15);}
.agp-conn-dot.warn{background:var(--am);box-shadow:0 0 0 3px rgba(212,152,62,.15);}
.agp-conn-dot.idle{background:var(--cbr);}
.agp-conn-body{min-width:0;display:flex;align-items:baseline;gap:8px;}
.agp-conn-name{font-size:12px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.agp-conn-name i{font-size:13px;color:var(--tm);}
.agp-conn-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.agp-conn-cta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--at);background:transparent;border:none;cursor:pointer;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.agp-conn-cta:hover{color:var(--tp);}

/* Workflow knobs */
.agp-knobs{padding:6px 14px 10px;display:flex;flex-direction:column;}
.agp-knob{display:grid;grid-template-columns:auto 1fr auto;gap:12px;align-items:center;padding:9px 0;border-bottom:1px dashed var(--cbr);}
.agp-knob:last-child{border-bottom:none;}
.agp-knob-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.agp-knob-val{font-size:12px;color:var(--tp);font-weight:600;letter-spacing:-0.005em;}
.agp-knob-val em{font-style:normal;color:var(--ts);font-weight:500;}
.agp-knob-edit{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--at);background:transparent;border:none;cursor:pointer;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:0;}
.agp-knob-edit:hover{color:var(--tp);}

/* Internal workflows — trigger-action pairs */
.agp-wf-list{padding:8px 14px 12px;display:flex;flex-direction:column;gap:8px;}
.agp-wf{background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;gap:6px;}
.agp-wf-top{display:flex;align-items:center;justify-content:space-between;gap:8px;}
.agp-wf-trigger{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:700;text-transform:uppercase;letter-spacing:.1em;}
.agp-wf-trigger i{font-size:11px;color:var(--at);}
.agp-wf-toggle{position:relative;width:28px;height:16px;background:var(--cbr);border-radius:9px;border:none;cursor:pointer;flex-shrink:0;transition:background .15s;padding:0;}
.agp-wf-toggle::after{content:"";position:absolute;top:2px;left:2px;width:12px;height:12px;background:#fff;border-radius:50%;transition:left .15s;box-shadow:0 1px 2px rgba(0,0,0,.1);}
.agp-wf-toggle.on{background:var(--gn);}
.agp-wf-toggle.on::after{left:14px;}
.agp-wf-rule{display:grid;grid-template-columns:1fr auto 1fr;gap:8px;align-items:center;}
.agp-wf-when{font-size:11.5px;color:var(--tp);letter-spacing:-0.005em;line-height:1.3;}
.agp-wf-when strong{font-weight:600;}
.agp-wf-arrow{color:var(--tm);font-size:13px;}
.agp-wf-then{font-size:11.5px;color:var(--tp);letter-spacing:-0.005em;line-height:1.3;text-align:right;}
.agp-wf-then strong{font-weight:600;color:var(--at);}
.agp-wf-add{margin-top:0;background:transparent;border:1px dashed var(--cbr);border-radius:7px;padding:8px 12px;font-family:'Inter',sans-serif;font-size:11.5px;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;justify-content:center;gap:5px;}
.agp-wf-add:hover{border-color:var(--ac);color:var(--at);}
.agp-wf-add i{font-size:13px;}

/* Data access — what internal data this agent can read/write */
.agp-data-list{padding:6px 14px 10px;display:flex;flex-direction:column;}
.agp-data{display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:center;padding:8px 0;border-bottom:1px dashed var(--cbr);}
.agp-data:last-child{border-bottom:none;}
.agp-data-ic{width:24px;height:24px;border-radius:5px;background:var(--s2);color:var(--ts);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.agp-data-body{min-width:0;display:flex;align-items:baseline;gap:8px;}
.agp-data-name{font-size:12px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.agp-data-perm{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;letter-spacing:.06em;}
.agp-data-perm.write{color:var(--at);}
.agp-data-cta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--at);background:transparent;border:none;cursor:pointer;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.agp-data-cta:hover{color:var(--tp);}

/* Drafts list */
.agp-drafts-list{padding:6px 14px 10px;display:flex;flex-direction:column;}
.agp-draft-row{display:grid;grid-template-columns:auto 1fr auto auto;gap:12px;align-items:center;padding:10px 0;border-bottom:1px dashed var(--cbr);cursor:pointer;transition:background .12s;margin:0 -14px;padding-left:14px;padding-right:14px;}
.agp-draft-row:last-child{border-bottom:none;}
.agp-draft-row:hover{background:#FBFAF8;}
.agp-draft-row:hover .agp-draft-headline{color:var(--at);}
.agp-draft-tag{font-family:'JetBrains Mono',monospace;font-size:8.5px;font-weight:700;color:var(--tm);background:var(--s2);border-radius:4px;padding:3px 7px;letter-spacing:.08em;text-transform:uppercase;}
.agp-draft-headline{font-size:12.5px;font-weight:500;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;transition:color .12s;}
.agp-draft-conf{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.agp-draft-age{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}




/* ============ ENABLEMENT — sales floor brain ============ */
/* Sub-tab strip */
.en-tabs{display:flex;border-bottom:1px solid var(--cbr);gap:0;margin-bottom:18px;}
.en-tab-btn{background:transparent;border:none;padding:10px 18px 12px;font-size:13.5px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;display:flex;align-items:center;gap:7px;}
.en-tab-btn:hover{color:var(--ts);}
.en-tab-btn.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);}
.en-tab-btn i{font-size:14px;}
.en-tab-count{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;background:var(--s2);padding:1px 6px;border-radius:4px;}
.en-tab-btn.active .en-tab-count{color:var(--at);background:var(--al);}

/* Artifact grid */
.en-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(360px,1fr));gap:12px;}

/* Artifact card — battlecard, messaging doc, talk track */
.en-card{background:var(--cb);border:1px solid var(--cbr);border-radius:11px;padding:0;display:flex;flex-direction:column;overflow:hidden;cursor:pointer;transition:all .15s;}
.en-card:hover{border-color:#D9D5CC;transform:translateY(-1px);box-shadow:0 4px 14px rgba(15,17,21,.05);}
.en-card-hdr{padding:13px 16px 10px;display:flex;align-items:flex-start;gap:12px;}
.en-card-ic{width:32px;height:32px;border-radius:8px;background:var(--al);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.en-card-ic.vlt{background:var(--vll);color:var(--vlt);}
.en-card-ic.gnt{background:var(--gnl);color:var(--gnt);}
.en-card-ic.amt{background:var(--aml);color:var(--amt);}
.en-card-id{flex:1;min-width:0;}
.en-card-eyebrow{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;line-height:1;}
.en-card-title{font-family:'Fraunces',Georgia,serif;font-size:16px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;margin-top:4px;line-height:1.2;}
.en-card-status{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:3px 8px;border-radius:4px;flex-shrink:0;}
.en-card-status.fresh{background:var(--gnl);color:var(--gnt);}
.en-card-status.stale{background:var(--aml);color:var(--amt);}
.en-card-status.draft{background:var(--al);color:var(--at);}

.en-card-body{padding:0 16px 12px;flex:1;}
.en-card-meta{font-size:12px;color:var(--ts);line-height:1.5;letter-spacing:-0.005em;}
.en-card-meta strong{color:var(--tp);font-weight:600;}

/* Source lineage strip */
.en-sources{padding:10px 16px;border-top:1px dashed var(--cbr);display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.en-sources-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;flex-shrink:0;}
.en-src-chip{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ts);background:#FBFAF8;border:1px solid var(--cbr);border-radius:4px;padding:2px 7px;font-weight:600;}
.en-src-chip i{font-size:11px;color:var(--at);}

/* Footer with metrics + action */
.en-card-foot{padding:9px 16px;display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--cbr);background:#FBFAF8;}
.en-card-foot-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.en-card-foot-cta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--at);font-weight:700;letter-spacing:.06em;text-transform:uppercase;display:flex;align-items:center;gap:4px;}
.en-card-foot-cta i{font-size:12px;}

/* Battlecard specifics — three pillars */
.en-bc-pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:0;padding:0 16px 12px;}
.en-bc-pillar{padding:8px 10px;border-right:1px dashed var(--cbr);}
.en-bc-pillar:last-child{border-right:none;}
.en-bc-pillar-lbl{font-family:'JetBrains Mono',monospace;font-size:8.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:3px;}
.en-bc-pillar-val{font-size:11.5px;color:var(--tp);font-weight:600;letter-spacing:-0.005em;line-height:1.4;}


/* ============ CAMPAIGNS — simple, intuitive, downstream of build ============ */
/* Section labels and shared header style */
.cm-section-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--tm);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.cm-section-lbl-count{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:var(--tp);background:var(--s2);padding:1px 6px;border-radius:4px;}

/* TRIGGERS row — things upstream that could become campaigns */
.cm-triggers{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:10px;margin-bottom:24px;}
.cm-trig{background:var(--cb);border:1px solid var(--cbr);border-radius:11px;padding:13px 15px;display:flex;flex-direction:column;gap:8px;cursor:pointer;transition:all .15s;position:relative;overflow:hidden;border-left:3px solid var(--accent,var(--at));}
.cm-trig:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(15,17,21,.06);border-color:#D9D5CC;border-left-color:var(--accent,var(--at));}
.cm-trig.release{--accent:var(--vlt);}
.cm-trig.build{--accent:var(--at);}
.cm-trig.signal{--accent:var(--amt);}
.cm-trig.competitor{--accent:var(--rdt);}
.cm-trig-top{display:flex;align-items:center;justify-content:space-between;gap:8px;}
.cm-trig-typ{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--accent,var(--at));font-weight:700;text-transform:uppercase;}
.cm-trig-typ i{font-size:11px;}
.cm-trig-when{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.cm-trig-name{font-size:14px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.3;}
.cm-trig-meta{font-size:11.5px;color:var(--ts);line-height:1.45;letter-spacing:-0.005em;}
.cm-trig-meta strong{color:var(--tp);font-weight:600;}
.cm-trig-cta{display:flex;align-items:center;justify-content:space-between;padding-top:6px;border-top:1px dashed var(--cbr);}
.cm-trig-suggest{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;}
.cm-trig-suggest strong{color:var(--tp);}
.cm-trig-go{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--accent,var(--at));font-weight:700;letter-spacing:.06em;text-transform:uppercase;display:flex;align-items:center;gap:4px;}
.cm-trig-go i{font-size:13px;}

/* From-scratch tile */
.cm-scratch{background:transparent;border:1px dashed var(--cbr);border-radius:11px;padding:13px 15px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;cursor:pointer;transition:all .12s;text-align:center;min-height:130px;}
.cm-scratch:hover{background:#FBFAF8;border-color:var(--ac);}
.cm-scratch-ic{width:30px;height:30px;border-radius:7px;background:var(--s2);color:var(--tm);display:flex;align-items:center;justify-content:center;font-size:14px;}
.cm-scratch:hover .cm-scratch-ic{background:var(--al);color:var(--at);}
.cm-scratch-name{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.cm-scratch-desc{font-size:11px;color:var(--ts);line-height:1.4;}

/* Filter tabs */
.cm-tabs{display:flex;border-bottom:1px solid var(--cbr);gap:0;margin-bottom:14px;}
.cm-tab-btn{background:transparent;border:none;padding:9px 16px 11px;font-size:13px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;display:flex;align-items:center;gap:7px;}
.cm-tab-btn:hover{color:var(--ts);}
.cm-tab-btn.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);}
.cm-tab-btn i{font-size:13px;}
.cm-tab-count{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.cm-tab-btn.active .cm-tab-count{color:var(--at);}

/* Campaign list — compact rows */
.cm-list{display:flex;flex-direction:column;gap:8px;}
.cm-row{background:var(--cb);border:1px solid var(--cbr);border-left:3px solid var(--accent,var(--at));border-radius:10px;padding:12px 15px;display:grid;grid-template-columns:1fr auto auto;gap:14px;align-items:center;cursor:pointer;transition:all .12s;}
.cm-row:hover{background:#FBFAF8;border-color:#D9D5CC;border-left-color:var(--accent,var(--at));}
.cm-row.major{--accent:var(--vlt);}
.cm-row.minor{--accent:var(--at);}
.cm-row.response{--accent:var(--rdt);}
.cm-row.abm{--accent:var(--gnt);}
.cm-row.bugfix{--accent:var(--tm);}
.cm-row-body{min-width:0;display:flex;flex-direction:column;gap:4px;}
.cm-row-name{font-size:13.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.3;display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.cm-row-meta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.cm-playbook{display:inline-flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.1em;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;}
.cm-playbook.major{background:var(--vll);color:var(--vlt);}
.cm-playbook.minor{background:var(--al);color:var(--at);}
.cm-playbook.response{background:#FFE5E5;color:var(--rdt);}
.cm-playbook.abm{background:var(--gnl);color:var(--gnt);}
.cm-playbook.bugfix{background:var(--s2);color:var(--tm);}
.cm-row-pipe{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--tp);font-weight:700;letter-spacing:-0.01em;text-align:right;}
.cm-row-pipe-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--tm);font-weight:700;letter-spacing:.1em;text-transform:uppercase;display:block;margin-top:1px;}
.cm-row-state{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 9px;border-radius:5px;flex-shrink:0;}
.cm-row-state.live{background:var(--gnl);color:var(--gnt);}
.cm-row-state.draft{background:var(--al);color:var(--at);}
.cm-row-state.queued{background:#FBFAF8;color:var(--tm);border:1px solid var(--cbr);}
.cm-row-state.done{background:var(--s2);color:var(--tm);}
.cm-row-state .dot{width:6px;height:6px;border-radius:50%;background:currentColor;}

/* ===== CAMPAIGN SHEET (single page, scrollable, adapts to playbook) ===== */
.cm-sheet-hdr{background:var(--cb);border:1px solid var(--cbr);border-radius:14px;padding:18px 22px;margin-bottom:14px;position:relative;overflow:hidden;}
.cm-sheet-hdr::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:var(--accent,var(--vlt));opacity:.7;}
.cm-sheet-hdr.major{--accent:var(--vlt);}
.cm-sheet-hdr.minor{--accent:var(--at);}
.cm-sheet-hdr.response{--accent:var(--rdt);}
.cm-sheet-hdr.abm{--accent:var(--gnt);}
.cm-sheet-hdr.bugfix{--accent:var(--tm);}
.cm-sheet-hdr-top{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:8px;}
.cm-sheet-name{font-family:'Fraunces',Georgia,serif;font-size:24px;font-weight:600;color:var(--tp);letter-spacing:-0.025em;line-height:1.15;}
.cm-sheet-meta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-top:6px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.cm-sheet-state{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:5px 10px;border-radius:5px;flex-shrink:0;}
.cm-sheet-state.live{background:var(--gnl);color:var(--gnt);}
.cm-sheet-state.draft{background:var(--al);color:var(--at);}
.cm-sheet-state .dot{width:6px;height:6px;border-radius:50%;background:currentColor;}
.cm-sheet-actions{display:flex;gap:8px;padding-top:14px;border-top:1px dashed var(--cbr);margin-top:12px;}
.cm-sheet-act{background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:7px 13px;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.cm-sheet-act:hover{background:var(--s2);color:var(--tp);}
.cm-sheet-act.primary{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.cm-sheet-act.primary:hover{background:#2A2D33;color:#fff;}
.cm-sheet-act i{font-size:13px;}

/* Lineage trail in sheet header */
.cm-sheet-lineage{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.cm-sheet-lineage-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.cm-lineage-chip{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tp);background:#FBFAF8;border:1px solid var(--cbr);border-radius:5px;padding:3px 8px;font-weight:600;}
.cm-lineage-chip i{font-size:11px;color:var(--at);}

/* Sheet sections — single-page scroll */
.cm-sec{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:16px 20px;margin-bottom:12px;}
.cm-sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.cm-sec-title{display:flex;align-items:center;gap:8px;}
.cm-sec-title-text{font-family:'Fraunces',Georgia,serif;font-size:16px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;}
.cm-sec-title-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.cm-sec-cta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--at);background:transparent;border:none;cursor:pointer;font-weight:700;letter-spacing:.08em;text-transform:uppercase;}
.cm-sec-cta:hover{color:var(--tp);}
.cm-sec-cta i{font-size:12px;margin-right:4px;}

/* CRO agent attribution badge (small, contextual) */
.cm-cro-tag{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.1em;color:var(--vlt);font-weight:700;background:var(--vll);padding:2px 7px;border-radius:4px;text-transform:uppercase;}
.cm-cro-tag .cro-av{width:12px;height:12px;border-radius:3px;background:var(--vlt);color:#fff;display:inline-flex;align-items:center;justify-content:center;font-family:'Fraunces',Georgia,serif;font-size:9px;font-weight:600;}

/* Brief grid (What / Who / Goal / Wedge) */
.cm-brief-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;}
.cm-brief-cell{display:flex;flex-direction:column;gap:4px;}
.cm-brief-cell-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.cm-brief-cell-val{font-size:13px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;}
.cm-brief-cell-val strong{font-weight:600;}

/* Audience compact row */
.cm-aud-row{display:flex;align-items:center;gap:14px;padding:9px 0;border-bottom:1px dashed var(--cbr);}
.cm-aud-row:last-child{border-bottom:none;}
.cm-aud-count{font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700;color:var(--tp);letter-spacing:-0.02em;min-width:50px;}
.cm-aud-body{flex:1;min-width:0;}
.cm-aud-name{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.cm-aud-filt{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ts);margin-top:2px;font-weight:600;}
.cm-aud-src{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;display:flex;align-items:center;gap:5px;flex-shrink:0;}
.cm-aud-src i{font-size:11px;color:var(--at);}

/* Asset grid — simpler than before */
.cm-asset-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:8px;}
.cm-asset-row{display:grid;grid-template-columns:auto 1fr auto auto;gap:10px;align-items:center;padding:9px 12px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;cursor:pointer;transition:all .12s;}
.cm-asset-row:hover{background:var(--cb);border-color:#D9D5CC;}
.cm-asset-ic{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.cm-asset-ic.eml{background:var(--al);color:var(--at);}
.cm-asset-ic.ads{background:var(--vll);color:var(--vlt);}
.cm-asset-ic.web{background:var(--gnl);color:var(--gnt);}
.cm-asset-ic.vid{background:var(--aml);color:var(--amt);}
.cm-asset-ic.con{background:#EDEEFB;color:#4044A8;}
.cm-asset-ic.lp{background:#F0E8FB;color:#7B3FBF;}
.cm-asset-name{font-size:12px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.3;}
.cm-asset-from{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;margin-top:1px;}
.cm-asset-state{font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:2px 6px;border-radius:4px;flex-shrink:0;}
.cm-asset-state.ready{background:var(--gnl);color:var(--gnt);}
.cm-asset-state.draft{background:var(--al);color:var(--at);}
.cm-asset-state.gen{background:var(--aml);color:var(--amt);}
.cm-asset-state.missing{background:#FFE5E5;color:var(--rdt);}
.cm-asset-cta{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--at);font-weight:700;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;}

/* Channels — compact */
.cm-ch-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:8px;}
.cm-ch-row{display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:center;padding:10px 12px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;}
.cm-ch-ic{width:26px;height:26px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.cm-ch-body{min-width:0;}
.cm-ch-name{font-size:12px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.cm-ch-meta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;margin-top:1px;}
.cm-ch-toggle{position:relative;width:28px;height:16px;background:var(--cbr);border-radius:9px;border:none;cursor:pointer;flex-shrink:0;transition:background .15s;padding:0;}
.cm-ch-toggle::after{content:"";position:absolute;top:2px;left:2px;width:12px;height:12px;background:#fff;border-radius:50%;transition:left .15s;box-shadow:0 1px 2px rgba(0,0,0,.1);}
.cm-ch-toggle.on{background:var(--gn);}
.cm-ch-toggle.on::after{left:14px;}

/* Timeline — compact list */
.cm-tl{display:flex;flex-direction:column;}
.cm-tl-step{display:grid;grid-template-columns:80px 1fr auto;gap:12px;align-items:center;padding:8px 0;border-bottom:1px dashed var(--cbr);}
.cm-tl-step:last-child{border-bottom:none;}
.cm-tl-when{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:700;letter-spacing:.06em;text-transform:uppercase;}
.cm-tl-step.done .cm-tl-when{color:var(--gnt);}
.cm-tl-step.live .cm-tl-when{color:var(--at);}
.cm-tl-what{font-size:12.5px;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;}
.cm-tl-what strong{font-weight:600;}
.cm-tl-tag{font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;color:var(--tm);background:var(--s2);border-radius:4px;padding:2px 6px;letter-spacing:.08em;text-transform:uppercase;}

/* Metrics — only when live */
.cm-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:12px;}
.cm-metric{background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;padding:10px 12px;display:flex;flex-direction:column;gap:3px;}
.cm-metric-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.cm-metric-val{font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700;color:var(--tp);letter-spacing:-0.015em;line-height:1;}
.cm-metric-delta{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:var(--gnt);}
.cm-metric-delta.dn{color:var(--rdt);}

/* CRO Agent learning row — what it has improved */
.cm-learning{background:linear-gradient(0deg,var(--vll),#FAFAFE);border:1px solid #D9DAF5;border-radius:10px;padding:12px 15px;display:flex;align-items:flex-start;gap:12px;}
.cm-learning-ic{width:30px;height:30px;border-radius:7px;background:var(--cb);border:1px solid #D9DAF5;color:var(--vlt);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.cm-learning-body{flex:1;}
.cm-learning-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--vlt);font-weight:700;text-transform:uppercase;}
.cm-learning-text{font-size:12.5px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;margin-top:3px;}
.cm-learning-text strong{font-weight:600;}

/* ===== CAMPAIGN WORKFLOW · the 5-step guided flow ===== */
/* Stepbar — sits below the header, above the active pane */
.cm-stepbar{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:6px;margin-bottom:14px;}
.cm-step{background:transparent;border:1px solid transparent;border-radius:8px;padding:11px 13px;display:flex;flex-direction:column;gap:5px;cursor:pointer;transition:all .12s;position:relative;text-align:left;font-family:inherit;}
.cm-step:hover{background:#FBFAF8;}
.cm-step.done{background:#F4FBF6;border-color:#C4DDC9;}
.cm-step.active{background:var(--lyra-bg);border-color:var(--lyra-bd);}
.cm-step-top{display:flex;align-items:center;gap:7px;}
.cm-step-marker{width:18px;height:18px;border-radius:50%;background:var(--s2);color:var(--tm);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;flex-shrink:0;}
.cm-step.done .cm-step-marker{background:var(--gn);color:#fff;}
.cm-step.active .cm-step-marker{background:var(--at);color:#fff;}
.cm-step-marker i{font-size:11px;}
.cm-step-name{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.cm-step-state{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;letter-spacing:.06em;text-transform:uppercase;}
.cm-step.done .cm-step-state{color:var(--gnt);}
.cm-step.active .cm-step-state{color:var(--at);}

/* Step pane — the single visible screen at a time */
.cm-flow-pane{display:flex;flex-direction:column;gap:12px;}

/* Step header — what this step is for, what CRO did, what user does */
.cm-step-hdr{background:var(--cb);border:1px solid var(--cbr);border-radius:11px;padding:14px 18px;display:grid;grid-template-columns:1fr auto;gap:14px;align-items:center;}
.cm-step-hdr-body{min-width:0;}
.cm-step-hdr-eyebrow{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.14em;color:var(--at);font-weight:700;text-transform:uppercase;}
.cm-step-hdr-title{font-family:'Fraunces',Georgia,serif;font-size:19px;font-weight:600;color:var(--tp);letter-spacing:-0.025em;margin-top:4px;line-height:1.2;}
.cm-step-hdr-sub{font-size:12.5px;color:var(--ts);line-height:1.5;letter-spacing:-0.005em;margin-top:6px;}
.cm-step-hdr-sub strong{color:var(--tp);font-weight:600;}
.cm-step-hdr-actions{display:flex;gap:7px;flex-shrink:0;align-items:center;}
.cm-step-prev{background:transparent;border:1px solid var(--cbr);border-radius:7px;padding:8px 12px;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.cm-step-prev:hover{background:var(--s2);color:var(--tp);}
.cm-step-next{background:var(--tp);color:#fff;border:none;border-radius:7px;padding:8px 14px;font-family:'Inter',sans-serif;font-size:12.5px;font-weight:600;cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.cm-step-next:hover{background:#2A2D33;}
.cm-step-next i{font-size:13px;}

/* CRO did-this banner — small, contextual, makes the AI assist visible */
.cm-cro-banner{background:linear-gradient(0deg,var(--vll),#FAFAFE);border:1px solid #D9DAF5;border-radius:9px;padding:10px 14px;display:flex;align-items:center;gap:11px;}
.cm-cro-banner-ic{width:26px;height:26px;border-radius:6px;background:var(--cb);border:1px solid #D9DAF5;color:var(--vlt);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.cm-cro-banner-body{flex:1;min-width:0;}
.cm-cro-banner-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--vlt);font-weight:700;text-transform:uppercase;}
.cm-cro-banner-text{font-size:12px;color:var(--tp);line-height:1.45;letter-spacing:-0.005em;margin-top:1px;}
.cm-cro-banner-text strong{font-weight:600;}
.cm-cro-banner-cta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--vlt);font-weight:700;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;flex-shrink:0;}
.cm-cro-banner-cta:hover{color:var(--tp);}

/* ===== COPY EDITOR · drawer for editing ad/email/post copy ===== */
.ce-back{position:fixed;inset:0;background:rgba(15,17,21,.35);z-index:50;opacity:0;pointer-events:none;transition:opacity .2s;}
.ce-back.open{opacity:1;pointer-events:auto;}
.ce-pane{position:fixed;top:0;right:0;bottom:0;width:min(720px,80vw);background:var(--bg);z-index:51;transform:translateX(100%);transition:transform .25s;display:flex;flex-direction:column;}
.ce-pane.open{transform:translateX(0);box-shadow:-12px 0 32px rgba(15,17,21,.18);}

/* Header */
.ce-hdr{background:var(--cb);border-bottom:1px solid var(--cbr);padding:12px 20px;display:flex;align-items:center;gap:14px;flex-shrink:0;}
.ce-hdr-ic{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.ce-hdr-ic.eml{background:var(--al);color:var(--at);}
.ce-hdr-ic.ads{background:var(--vll);color:var(--vlt);}
.ce-hdr-ic.post{background:var(--gnl);color:var(--gnt);}
.ce-hdr-body{flex:1;min-width:0;}
.ce-hdr-eyebrow{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.14em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.ce-hdr-title{font-size:14px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-top:2px;}
.ce-hdr-close{background:transparent;border:1px solid var(--cbr);border-radius:7px;width:32px;height:32px;display:flex;align-items:center;justify-content:center;color:var(--ts);cursor:pointer;flex-shrink:0;}
.ce-hdr-close:hover{background:var(--s2);color:var(--tp);}

/* Body — scrollable */
.ce-body{flex:1;overflow-y:auto;padding:16px 20px 22px;display:flex;flex-direction:column;gap:14px;}

/* Variant switcher — chips at top */
.ce-variants{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.ce-var-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;flex-shrink:0;}
.ce-var{display:inline-flex;align-items:center;gap:5px;font-family:'Inter',sans-serif;font-size:11.5px;font-weight:500;color:var(--ts);background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:5px 11px;cursor:pointer;letter-spacing:-0.005em;}
.ce-var:hover{background:#FBFAF8;color:var(--tp);}
.ce-var.active{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.ce-var-add{display:inline-flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--at);background:transparent;border:1px dashed var(--cbr);border-radius:6px;padding:5px 10px;cursor:pointer;font-weight:700;letter-spacing:.06em;text-transform:uppercase;}
.ce-var-add:hover{border-color:var(--ac);background:var(--lyra-bg);}

/* CRO context — what informed this + projected performance */
.ce-context{background:linear-gradient(0deg,var(--vll),#FAFAFE);border:1px solid #D9DAF5;border-radius:10px;padding:11px 14px;display:flex;align-items:center;gap:12px;}
.ce-context-ic{width:28px;height:28px;border-radius:7px;background:var(--cb);border:1px solid #D9DAF5;color:var(--vlt);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.ce-context-body{flex:1;min-width:0;}
.ce-context-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--vlt);font-weight:700;text-transform:uppercase;}
.ce-context-text{font-size:12px;color:var(--tp);line-height:1.45;letter-spacing:-0.005em;margin-top:2px;}
.ce-context-text strong{font-weight:600;}
.ce-context-score{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--gnt);font-weight:700;background:var(--gnl);padding:4px 9px;border-radius:5px;flex-shrink:0;}

/* Field block — label + editable input */
.ce-field{display:flex;flex-direction:column;gap:6px;}
.ce-field-top{display:flex;align-items:center;justify-content:space-between;}
.ce-field-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.ce-field-meta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;}
.ce-field-meta.over{color:var(--rdt);}
.ce-field-input{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:10px 13px;font-family:'Inter',sans-serif;font-size:13px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;width:100%;box-sizing:border-box;outline:none;resize:vertical;font-weight:500;}
.ce-field-input:focus{border-color:var(--at);background:#FBFAFE;}
.ce-field-input.short{min-height:42px;}
.ce-field-input.med{min-height:80px;}
.ce-field-input.long{min-height:150px;}

/* Quick-rewrite chips */
.ce-rewrites{display:flex;align-items:center;gap:6px;flex-wrap:wrap;padding-top:6px;}
.ce-rewrites-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--vlt);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:5px;}
.ce-rewrites-lbl i{font-size:11px;}
.ce-rewrite{font-family:'Inter',sans-serif;font-size:11px;color:var(--vlt);background:var(--vll);border:1px solid #D9DAF5;border-radius:5px;padding:3px 9px;cursor:pointer;font-weight:600;letter-spacing:-0.005em;}
.ce-rewrite:hover{background:var(--vlt);color:#fff;border-color:var(--vlt);}

/* Preview card — what it'll look like in the channel */
.ce-preview{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:13px 16px;display:flex;flex-direction:column;gap:8px;}
.ce-preview-hdr{display:flex;align-items:center;gap:8px;padding-bottom:8px;border-bottom:1px dashed var(--cbr);}
.ce-preview-avatar{width:28px;height:28px;border-radius:50%;background:var(--s2);color:var(--tm);display:flex;align-items:center;justify-content:center;font-family:'Fraunces',Georgia,serif;font-size:13px;font-weight:600;}
.ce-preview-from{font-size:12px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.ce-preview-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;margin-top:1px;}
.ce-preview-sub{font-size:14px;font-weight:600;color:var(--tp);letter-spacing:-0.01em;line-height:1.4;}
.ce-preview-pre{font-size:12px;color:var(--ts);line-height:1.5;font-style:italic;}
.ce-preview-body{font-size:13px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;white-space:pre-wrap;}
.ce-preview-cta{display:inline-block;background:var(--at);color:#fff;border-radius:6px;padding:8px 16px;font-size:13px;font-weight:600;letter-spacing:-0.005em;align-self:flex-start;}

/* Footer actions */
.ce-foot{background:var(--cb);border-top:1px solid var(--cbr);padding:12px 20px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-shrink:0;}
.ce-foot-left{display:flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.ce-foot-right{display:flex;gap:7px;}
.ce-btn{background:var(--cb);border:1px solid var(--cbr);border-radius:7px;padding:8px 13px;font-family:'Inter',sans-serif;font-size:12.5px;font-weight:500;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.ce-btn:hover{background:var(--s2);color:var(--tp);}
.ce-btn.regen{color:var(--vlt);}
.ce-btn.regen:hover{background:var(--vll);color:var(--vlt);}
.ce-btn.primary{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.ce-btn.primary:hover{background:#2A2D33;color:#fff;}
.ce-btn i{font-size:13px;}


/* ============ CONTENT · generation surface (RAG + signals → drafts) ============ */
/* Hero band — explains what the module does */
.ct-hero{background:linear-gradient(0deg,var(--lyra-bg),#F5F8FF);border:1px solid var(--lyra-bd);border-radius:12px;padding:16px 20px;margin-bottom:18px;display:grid;grid-template-columns:1fr auto;gap:18px;align-items:center;}
.ct-hero-body{min-width:0;}
.ct-hero-eyebrow{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--at);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:7px;}
.ct-hero-eyebrow i{font-size:12px;}
.ct-hero-title{font-family:'Fraunces',Georgia,serif;font-size:19px;font-weight:600;color:var(--tp);letter-spacing:-0.025em;margin-top:5px;line-height:1.25;}
.ct-hero-sub{font-size:12.5px;color:var(--ts);line-height:1.55;letter-spacing:-0.005em;margin-top:5px;max-width:640px;}
.ct-hero-sub strong{color:var(--tp);font-weight:600;}
.ct-hero-flow{display:flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:700;letter-spacing:.06em;text-transform:uppercase;flex-shrink:0;background:var(--cb);border:1px solid var(--cbr);border-radius:9px;padding:9px 13px;}
.ct-hero-flow strong{color:var(--tp);}
.ct-hero-flow i{color:var(--at);font-size:13px;}

/* Active drafts strip — what CRO is working on right now */
.ct-draft{background:var(--cb);border:1px solid var(--cbr);border-radius:11px;padding:14px 16px;display:grid;grid-template-columns:auto 1fr auto auto;gap:14px;align-items:center;cursor:pointer;transition:all .15s;margin-bottom:8px;border-left:3px solid var(--accent,var(--at));}
.ct-draft:hover{background:#FBFAF8;border-color:#D9D5CC;border-left-color:var(--accent,var(--at));}
.ct-draft.gen{--accent:var(--vlt);}
.ct-draft.review{--accent:var(--at);}
.ct-draft.stale{--accent:var(--amt);}
.ct-draft-ic{width:34px;height:34px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.ct-draft-ic.gen{background:var(--vll);color:var(--vlt);}
.ct-draft-ic.review{background:var(--al);color:var(--at);}
.ct-draft-ic.stale{background:var(--aml);color:var(--amt);}
.ct-draft-body{min-width:0;display:flex;flex-direction:column;gap:4px;}
.ct-draft-typ{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.ct-draft-title{font-size:13.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.3;}
.ct-draft-rag{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;display:flex;align-items:center;gap:6px;margin-top:2px;}
.ct-draft-rag strong{color:var(--at);}
.ct-draft-progress{display:flex;flex-direction:column;align-items:flex-end;gap:4px;font-family:'JetBrains Mono',monospace;}
.ct-draft-prog-val{font-size:13px;font-weight:700;color:var(--tp);letter-spacing:-0.01em;}
.ct-draft-prog-bar{width:80px;height:4px;background:var(--cbr);border-radius:2px;overflow:hidden;}
.ct-draft-prog-fill{height:100%;background:var(--at);border-radius:2px;}
.ct-draft-prog-fill.gen{background:var(--vlt);}
.ct-draft-prog-fill.stale{background:var(--amt);}
.ct-draft-state{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 9px;border-radius:5px;flex-shrink:0;}
.ct-draft-state.gen{background:var(--vll);color:var(--vlt);}
.ct-draft-state.review{background:var(--al);color:var(--at);}
.ct-draft-state.stale{background:var(--aml);color:var(--amt);}
.ct-draft-state .dot{width:6px;height:6px;border-radius:50%;background:currentColor;}

/* Destination chip on draft rows */
.ct-dest{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--ts);background:#FBFAF8;border:1px solid var(--cbr);border-radius:4px;padding:2px 7px;font-weight:600;}
.ct-dest i{font-size:11px;color:var(--at);}
.ct-dest-arrow{color:var(--tm);font-size:10px;margin:0 3px;}

/* RAG context preview tile — shows what gets retrieved into a draft */
.ct-rag-preview{background:#FBFAF8;border:1px solid var(--cbr);border-radius:11px;padding:14px 16px;margin-bottom:12px;}
.ct-rag-preview-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.ct-rag-preview-title{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--tp);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:7px;}
.ct-rag-preview-title i{font-size:12px;color:var(--at);}
.ct-rag-preview-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.ct-rag-sources{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:8px;}
.ct-rag-src{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:9px 12px;display:flex;align-items:center;gap:10px;}
.ct-rag-src-ic{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;}
.ct-rag-src-ic.pr{background:var(--al);color:var(--at);}
.ct-rag-src-ic.gtm{background:var(--vll);color:var(--vlt);}
.ct-rag-src-ic.sig{background:var(--aml);color:var(--amt);}
.ct-rag-src-ic.ext{background:var(--gnl);color:var(--gnt);}
.ct-rag-src-ic.cust{background:#EDEEFB;color:#4044A8;}
.ct-rag-src-body{min-width:0;flex:1;}
.ct-rag-src-typ{font-family:'JetBrains Mono',monospace;font-size:8.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.ct-rag-src-name{font-size:11.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.3;margin-top:1px;}
.ct-rag-src-weight{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--at);font-weight:700;flex-shrink:0;}

/* Signal sources strip (external + internal RAG transparency) */
.ct-sources-band{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:14px 18px;margin-bottom:18px;}
.ct-sources-band-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.ct-sources-band-title{font-family:'Fraunces',Georgia,serif;font-size:15px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;}
.ct-sources-band-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.ct-sources-band-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:10px;}
.ct-source-pool{display:flex;align-items:center;gap:11px;padding:10px 12px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:9px;}
.ct-source-pool-ic{width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.ct-source-pool-ic.pr{background:var(--al);color:var(--at);}
.ct-source-pool-ic.gtm{background:var(--vll);color:var(--vlt);}
.ct-source-pool-ic.sig{background:var(--aml);color:var(--amt);}
.ct-source-pool-ic.ext{background:var(--gnl);color:var(--gnt);}
.ct-source-pool-ic.cust{background:#EDEEFB;color:#4044A8;}
.ct-source-pool-body{min-width:0;flex:1;}
.ct-source-pool-name{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.ct-source-pool-meta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;margin-top:1px;}
.ct-source-pool-count{font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:700;color:var(--tp);letter-spacing:-0.015em;}

/* Destinations strip — where content gets pushed */
.ct-dests{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.ct-dest-chip{display:inline-flex;align-items:center;gap:6px;font-family:'Inter',sans-serif;font-size:12px;color:var(--ts);background:#FBFAF8;border:1px solid var(--cbr);border-radius:6px;padding:6px 11px;font-weight:500;letter-spacing:-0.005em;}
.ct-dest-chip i{font-size:13px;color:var(--at);}
.ct-dest-chip.connected{background:var(--gnl);border-color:#C4DDC9;color:var(--gnt);}
.ct-dest-chip.connected i{color:var(--gnt);}


/* ============ CONTENT · drafting surface (the writing workspace) ============ */
/* Header band */
.cd-hdr{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:14px 20px;margin-bottom:14px;display:grid;grid-template-columns:auto 1fr auto;gap:16px;align-items:center;position:relative;overflow:hidden;}
.cd-hdr::before{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:var(--at);opacity:.7;}
.cd-hdr-ic{width:44px;height:44px;border-radius:10px;background:#EDEEFB;color:#4044A8;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.cd-hdr-body{min-width:0;}
.cd-hdr-eyebrow{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.14em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.cd-hdr-title{font-family:'Fraunces',Georgia,serif;font-size:20px;font-weight:600;color:var(--tp);letter-spacing:-0.025em;margin-top:4px;line-height:1.2;}
.cd-hdr-meta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-top:5px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.cd-hdr-meta strong{color:var(--tp);}
.cd-hdr-actions{display:flex;gap:7px;align-items:center;flex-shrink:0;}
.cd-hdr-act{background:var(--cb);border:1px solid var(--cbr);border-radius:7px;padding:7px 12px;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.cd-hdr-act:hover{background:var(--s2);color:var(--tp);}
.cd-hdr-act.primary{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.cd-hdr-act.primary:hover{background:#2A2D33;}
.cd-hdr-act i{font-size:13px;}

/* CRO learning context banner — what informed this draft */
.cd-learning{background:linear-gradient(0deg,var(--vll),#FAFAFE);border:1px solid #D9DAF5;border-radius:10px;padding:11px 14px;margin-bottom:14px;display:flex;align-items:center;gap:12px;}
.cd-learning-ic{width:28px;height:28px;border-radius:7px;background:var(--cb);border:1px solid #D9DAF5;color:var(--vlt);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.cd-learning-body{flex:1;min-width:0;}
.cd-learning-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--vlt);font-weight:700;text-transform:uppercase;}
.cd-learning-text{font-size:12px;color:var(--tp);line-height:1.45;letter-spacing:-0.005em;margin-top:2px;}
.cd-learning-text strong{font-weight:600;}

/* Two-column drafting layout */
.cd-grid{display:grid;grid-template-columns:1fr 380px;gap:14px;align-items:flex-start;}

/* Draft column (left) */
.cd-draft{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:0;display:flex;flex-direction:column;overflow:hidden;}

/* Section block within draft */
.cd-section{padding:18px 24px;border-bottom:1px solid var(--cbr);position:relative;}
.cd-section:last-child{border-bottom:none;}
.cd-section:hover{background:#FDFCFA;}
.cd-section-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.cd-section-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.14em;color:var(--tm);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:7px;}
.cd-section-lbl i{font-size:11px;color:var(--at);}
.cd-section-controls{display:flex;align-items:center;gap:5px;opacity:0;transition:opacity .15s;}
.cd-section:hover .cd-section-controls{opacity:1;}
.cd-section-ctrl{background:transparent;border:1px solid var(--cbr);border-radius:5px;padding:3px 8px;font-family:'JetBrains Mono',monospace;font-size:9px;font-weight:700;color:var(--vlt);cursor:pointer;letter-spacing:.06em;text-transform:uppercase;background:var(--cb);}
.cd-section-ctrl:hover{background:var(--vll);}
.cd-section-ctrl i{font-size:10px;margin-right:3px;}

/* Editable prose styling */
.cd-h1{font-family:'Fraunces',Georgia,serif;font-size:28px;font-weight:600;color:var(--tp);letter-spacing:-0.03em;line-height:1.15;outline:none;}
.cd-h1:focus{background:var(--lyra-bg);border-radius:4px;}
.cd-h2{font-family:'Fraunces',Georgia,serif;font-size:20px;font-weight:600;color:var(--tp);letter-spacing:-0.022em;line-height:1.2;outline:none;}
.cd-h2:focus{background:var(--lyra-bg);border-radius:4px;}
.cd-dek{font-size:15px;color:var(--ts);line-height:1.55;letter-spacing:-0.005em;font-style:italic;outline:none;margin-top:8px;}
.cd-dek:focus{background:var(--lyra-bg);border-radius:4px;}
.cd-body-p{font-size:14.5px;color:var(--tp);line-height:1.65;letter-spacing:-0.005em;outline:none;margin-top:10px;}
.cd-body-p:focus{background:var(--lyra-bg);border-radius:4px;}
.cd-body-p[contenteditable]{cursor:text;}

/* Inline grounding strip — shows which chunks fed this paragraph */
.cd-grounding{display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-top:10px;padding-top:9px;border-top:1px dashed var(--cbr);}
.cd-grounding-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:4px;}
.cd-grounding-lbl i{font-size:10px;color:var(--at);}
.cd-chunk{display:inline-flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--ts);background:#FBFAF8;border:1px solid var(--cbr);border-radius:4px;padding:2px 7px;font-weight:600;cursor:pointer;}
.cd-chunk:hover{background:var(--al);color:var(--at);border-color:var(--ac);}
.cd-chunk-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.cd-chunk-dot.pr{background:var(--at);}
.cd-chunk-dot.gtm{background:var(--vlt);}
.cd-chunk-dot.sig{background:var(--amt);}
.cd-chunk-dot.ext{background:var(--gnt);}
.cd-chunk-dot.cust{background:#4044A8;}

/* Sources panel (right) — RAG transparency */
.cd-sources{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:0;display:flex;flex-direction:column;position:sticky;top:14px;max-height:calc(100vh - 80px);overflow:hidden;}
.cd-sources-hdr{padding:13px 16px;border-bottom:1px solid var(--cbr);background:#FBFAF8;}
.cd-sources-title{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--tp);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:7px;}
.cd-sources-title i{font-size:12px;color:var(--at);}
.cd-sources-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;margin-top:3px;}
.cd-sources-body{flex:1;overflow-y:auto;padding:10px 14px 14px;display:flex;flex-direction:column;gap:14px;}

.cd-src-group{display:flex;flex-direction:column;gap:5px;}
.cd-src-group-hdr{display:flex;align-items:center;justify-content:space-between;}
.cd-src-group-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;display:flex;align-items:center;gap:6px;}
.cd-src-group-lbl .cd-chunk-dot{width:7px;height:7px;}
.cd-src-group-count{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tp);font-weight:700;}
.cd-src-item{display:grid;grid-template-columns:1fr auto;gap:8px;align-items:center;padding:6px 9px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:6px;cursor:pointer;transition:all .12s;}
.cd-src-item:hover{background:var(--cb);border-color:#D9D5CC;}
.cd-src-item-name{font-size:11.5px;color:var(--tp);font-weight:600;letter-spacing:-0.005em;line-height:1.3;}
.cd-src-item-meta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:600;margin-top:1px;}
.cd-src-weight{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--at);font-weight:700;flex-shrink:0;}
.cd-src-weight.hi{color:var(--vlt);}

.cd-sources-foot{padding:10px 14px;border-top:1px solid var(--cbr);background:#FBFAF8;display:flex;gap:6px;}
.cd-sources-ctrl{flex:1;background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:6px 9px;font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--ts);font-weight:700;cursor:pointer;letter-spacing:.06em;text-transform:uppercase;display:flex;align-items:center;justify-content:center;gap:5px;}
.cd-sources-ctrl:hover{background:var(--s2);color:var(--tp);}
.cd-sources-ctrl i{font-size:11px;}



.build-stepbar{display:grid;grid-template-columns:repeat(6,1fr);gap:6px;background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:6px;margin-bottom:18px;}
.build-step{background:transparent;border:1px solid transparent;border-radius:8px;padding:11px 12px;display:flex;flex-direction:column;gap:4px;cursor:pointer;transition:all .12s;position:relative;text-align:left;font-family:inherit;}
.build-step:hover{background:#FBFAF8;}
.build-step.active{background:var(--lyra-bg);border-color:var(--lyra-bd);}
.build-step.done{background:#F4FBF6;border-color:#C4DDC9;}
.build-step-num{display:flex;align-items:center;gap:6px;}
.build-step-dot{width:18px;height:18px;border-radius:50%;background:var(--s2);color:var(--tm);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;}
.build-step.active .build-step-dot{background:var(--ac);color:#fff;}
.build-step.done .build-step-dot{background:var(--gn);color:#fff;}
.build-step-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;color:var(--tm);text-transform:uppercase;}
.build-step.active .build-step-lbl{color:var(--at);}
.build-step.done .build-step-lbl{color:var(--gnt);}
.build-step-name{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.2;}
.build-step-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;margin-top:1px;}

.build-section{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.build-section-hdr{padding:14px 18px;border-bottom:1px solid var(--cbr);display:flex;align-items:center;gap:14px;background:#FBFAF8;}
.build-section-eyebrow{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--at);font-weight:700;}
.build-section-title{font-family:'Fraunces',Georgia,serif;font-size:20px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1.1;}
.build-section-sub{font-size:12.5px;color:var(--ts);margin-top:2px;}
.build-section-mid{flex:1;}
.build-section-cta{display:flex;gap:8px;}

.build-track-pick{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;padding:18px;}
.build-track{background:#FBFAF8;border:1px solid var(--cbr);border-radius:10px;padding:16px 18px;cursor:pointer;transition:all .12s;border-top:3px solid;display:flex;flex-direction:column;gap:10px;}
.build-track:hover{transform:translateY(-2px);box-shadow:0 4px 12px rgba(15,17,21,.06);}
.build-track.signal{border-top-color:var(--vlt);}
.build-track.organic{border-top-color:var(--at);}
.build-track.release{border-top-color:var(--gnt);}
.build-track-icon{width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;}
.build-track.signal .build-track-icon{background:var(--vll);color:var(--vlt);}
.build-track.organic .build-track-icon{background:var(--al);color:var(--at);}
.build-track.release .build-track-icon{background:var(--gnl);color:var(--gnt);}
.build-track-icon i{font-size:18px;}
.build-track-name{font-family:'Fraunces',Georgia,serif;font-size:18px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1.1;}
.build-track-desc{font-size:12.5px;color:var(--ts);line-height:1.5;flex:1;}
.build-track-foot{display:flex;align-items:center;justify-content:space-between;padding-top:8px;border-top:1px solid var(--cbr);font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}

.build-active{padding:18px;}
.build-active-list{display:flex;flex-direction:column;gap:10px;}
.build-active-row{background:#FBFAF8;border:1px solid var(--cbr);border-radius:10px;padding:12px 16px;display:grid;grid-template-columns:auto 1fr auto auto;gap:14px;align-items:center;cursor:pointer;transition:all .12s;}
.build-active-row:hover{border-color:#D9D5CC;background:var(--cb);}
.build-active-mark{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:700;}
.build-active-mark-dot{width:8px;height:8px;border-radius:50%;}
.build-active-mark-dot.signal{background:var(--vlt);}
.build-active-mark-dot.organic{background:var(--at);}
.build-active-mark-dot.release{background:var(--gnt);}
.build-active-body{min-width:0;}
.build-active-title{font-size:14px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-bottom:2px;}
.build-active-meta{font-size:12px;color:var(--ts);line-height:1.4;}
.build-active-stage{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;background:var(--al);color:var(--at);padding:3px 9px;border-radius:5px;letter-spacing:.04em;text-transform:uppercase;}
.build-active-stage i{font-size:12px;}
.build-active-cta{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--at);font-weight:600;display:flex;align-items:center;gap:5px;}

/* Generic step canvas — for Analysis, Test, Ship, Learn placeholders */
.build-canvas{padding:22px;display:flex;flex-direction:column;gap:18px;}
.build-canvas-block{background:#FBFAF8;border:1px solid var(--cbr);border-radius:10px;padding:14px 16px;}
.build-canvas-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:8px;}
.build-canvas-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;}
.build-canvas-field{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:12px;}
.build-canvas-field-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:6px;}
.build-canvas-field-val{font-size:13px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;}
.build-canvas-field-val strong{font-weight:600;}
.build-canvas-pill{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase;}
.build-canvas-pill.gn{background:var(--gnl);color:var(--gnt);}
.build-canvas-pill.am{background:var(--aml);color:var(--amt);}
.build-canvas-pill.lyra{background:var(--al);color:var(--at);}
.build-canvas-list{display:flex;flex-direction:column;gap:6px;}
.build-canvas-list-item{display:flex;align-items:flex-start;gap:9px;font-size:12.5px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;}
.build-canvas-list-item i{font-size:13px;color:var(--at);flex-shrink:0;margin-top:2px;}

/* BUILD LIST — module home shows in-flight builds */
.bls-list{display:flex;flex-direction:column;gap:8px;}
.bls-row{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:12px 16px;display:grid;grid-template-columns:auto 1fr auto auto auto;gap:14px;align-items:center;cursor:pointer;transition:all .12s;border-left:3px solid var(--cbr);}
.bls-row:hover{border-color:#D9D5CC;background:#FBFAF8;}
.bls-row.feature{border-left-color:var(--at);}
.bls-row.enhance{border-left-color:var(--vlt);}
.bls-row.bug{border-left-color:var(--rdt);}
.bls-row.spike{border-left-color:var(--amt);}
.bls-row.product{border-left-color:var(--gnt);}
.bls-type{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;letter-spacing:.08em;padding:3px 8px;border-radius:4px;text-transform:uppercase;}
.bls-type.feature{background:var(--al);color:var(--at);}
.bls-type.enhance{background:var(--vll);color:var(--vlt);}
.bls-type.bug{background:var(--rdl);color:var(--rdt);}
.bls-type.spike{background:var(--aml);color:var(--amt);}
.bls-type.product{background:var(--gnl);color:var(--gnt);}
.bls-body{min-width:0;}
.bls-title{font-size:14px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-bottom:3px;}
.bls-meta{display:flex;align-items:center;gap:10px;flex-wrap:wrap;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.bls-meta-sep{color:var(--cbr);}
.bls-stage{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;padding:4px 9px;border-radius:5px;letter-spacing:.04em;text-transform:uppercase;background:var(--s2);color:var(--tm);}
.bls-stage.active{background:var(--al);color:var(--at);}
.bls-stage i{font-size:12px;}
.bls-age{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.bls-arrow{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--at);}

.bls-filter{display:flex;border-bottom:1px solid var(--cbr);gap:0;margin-bottom:18px;}
.bls-filter-btn{background:transparent;border:none;padding:10px 16px 12px;font-size:13px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;display:flex;align-items:center;gap:6px;}
.bls-filter-btn:hover{color:var(--ts);}
.bls-filter-btn.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);}
.bls-filter-btn span.tabular{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);}
.bls-filter-btn.active span.tabular{color:var(--at);}

/* BUILD WORKSPACE — opens when a build is clicked */
.bws{display:flex;flex-direction:column;gap:14px;}

/* Build header — title, type, status meta */
.bws-hdr{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:14px 18px;display:grid;grid-template-columns:1fr auto;gap:14px;align-items:start;}
.bws-hdr-left{min-width:0;}
.bws-hdr-meta-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;flex-wrap:wrap;}
.bws-hdr-name{font-family:'Fraunces',Georgia,serif;font-size:22px;font-weight:600;color:var(--tp);letter-spacing:-0.025em;line-height:1.1;margin-bottom:4px;}
.bws-hdr-sub{font-size:13px;color:var(--ts);letter-spacing:-0.005em;}
.bws-hdr-right{display:flex;flex-direction:column;gap:8px;align-items:flex-end;}
.bws-hdr-cta-row{display:flex;gap:6px;}

/* Stepbar — adapts to build type */
.bws-stepbar{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:6px;display:grid;gap:4px;}
.bws-stepbar.full{grid-template-columns:repeat(6,1fr);}
.bws-stepbar.enhance{grid-template-columns:repeat(5,1fr);}
.bws-stepbar.bug{grid-template-columns:repeat(4,1fr);}
.bws-stepbar.spike{grid-template-columns:repeat(3,1fr);}
.bws-step{background:transparent;border:1px solid transparent;border-radius:8px;padding:9px 11px;cursor:pointer;transition:all .12s;text-align:left;font-family:inherit;position:relative;display:flex;flex-direction:column;gap:3px;}
.bws-step:hover{background:#FBFAF8;}
.bws-step.done{background:#F4FBF6;border-color:#C4DDC9;}
.bws-step.active{background:var(--lyra-bg);border-color:var(--lyra-bd);}
.bws-step.bounced{background:#FAF3E7;border-color:#E7CFA0;}
.bws-step.pending{}
.bws-step-row{display:flex;align-items:center;gap:6px;}
.bws-step-dot{width:18px;height:18px;border-radius:50%;background:var(--s2);color:var(--tm);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;flex-shrink:0;}
.bws-step.done .bws-step-dot{background:var(--gn);color:#fff;}
.bws-step.active .bws-step-dot{background:var(--ac);color:#fff;}
.bws-step.bounced .bws-step-dot{background:var(--am);color:#fff;}
.bws-step-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;color:var(--tm);text-transform:uppercase;}
.bws-step.done .bws-step-lbl{color:var(--gnt);}
.bws-step.active .bws-step-lbl{color:var(--at);}
.bws-step.bounced .bws-step-lbl{color:var(--amt);}
.bws-step-name{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.2;}
.bws-step-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.bws-step.bounced .bws-step-meta{color:var(--amt);}
.bws-step-bouncetag{display:inline-flex;align-items:center;gap:3px;font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--amt);font-weight:700;}
.bws-step-bouncetag i{font-size:10px;}

/* HISTORY strip — actual path taken (forward + backward arrows) */
.bws-history{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:9px 14px;display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.bws-history-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-right:6px;}
.bws-hist-event{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tp);font-weight:600;background:var(--s2);padding:3px 8px;border-radius:5px;}
.bws-hist-event.bounce{background:var(--aml);color:var(--amt);}
.bws-hist-event-date{color:var(--tm);font-weight:500;}
.bws-hist-arrow{color:var(--cbr);font-size:11px;}
.bws-hist-arrow.bounce{color:var(--am);transform:rotate(180deg);display:inline-block;}

/* Step canvas content — fills the area below stepbar */
.bws-canvas{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.bws-canvas-hdr{padding:14px 18px;border-bottom:1px solid var(--cbr);display:flex;align-items:center;gap:14px;background:#FBFAF8;}
.bws-canvas-eyebrow{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--at);font-weight:700;}
.bws-canvas-title{font-family:'Fraunces',Georgia,serif;font-size:20px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1.1;}
.bws-canvas-sub{font-size:12.5px;color:var(--ts);margin-top:2px;}
.bws-canvas-mid{flex:1;min-width:0;}
.bws-canvas-cta-row{display:flex;gap:6px;}
.bws-canvas-cta{background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:6px 11px;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--ts);cursor:pointer;display:flex;align-items:center;gap:5px;letter-spacing:-0.005em;}
.bws-canvas-cta:hover{background:var(--s2);color:var(--tp);}
.bws-canvas-cta i{font-size:13px;}
.bws-canvas-cta.bounce{color:var(--amt);border-color:#E7CFA0;}
.bws-canvas-cta.bounce:hover{background:var(--aml);}
.bws-canvas-cta.advance{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.bws-canvas-cta.advance:hover{background:#2A2D33;}
.bws-canvas-body{padding:18px;display:flex;flex-direction:column;gap:14px;}

/* TEST step specific — outcome cards (pass/fail/issues) */
.test-outcomes{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.test-outcome{background:#FBFAF8;border:1px solid var(--cbr);border-radius:10px;padding:13px 15px;border-top:3px solid;}
.test-outcome.pass{border-top-color:var(--gn);}
.test-outcome.warn{border-top-color:var(--am);}
.test-outcome.fail{border-top-color:var(--rd);}
.test-outcome-row{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:6px;}
.test-outcome-name{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.test-outcome-val{font-family:'JetBrains Mono',monospace;font-size:16px;font-weight:700;}
.test-outcome.pass .test-outcome-val{color:var(--gnt);}
.test-outcome.warn .test-outcome-val{color:var(--amt);}
.test-outcome.fail .test-outcome-val{color:var(--rdt);}
.test-outcome-meta{font-size:11.5px;color:var(--ts);line-height:1.5;}

.test-fb-list{display:flex;flex-direction:column;gap:6px;}
.test-fb{display:grid;grid-template-columns:auto 1fr auto;gap:10px;align-items:start;padding:9px 12px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;}
.test-fb-icon{width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;margin-top:1px;}
.test-fb-icon.pass{background:var(--gnl);color:var(--gnt);}
.test-fb-icon.warn{background:var(--aml);color:var(--amt);}
.test-fb-icon.fail{background:var(--rdl);color:var(--rdt);}
.test-fb-body{min-width:0;}
.test-fb-quote{font-size:13px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;font-style:italic;}
.test-fb-attr{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;margin-top:3px;}
.test-fb-tag{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--tm);font-weight:700;background:var(--s2);padding:2px 7px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase;}
.test-fb-tag.bounce{background:var(--aml);color:var(--amt);}

/* Bounce-back banner shown on bounced steps */
.bounce-banner{background:linear-gradient(0deg,var(--aml),#FBF1DD);border:1px solid #E7CFA0;border-radius:10px;padding:12px 16px;display:flex;align-items:flex-start;gap:12px;}
.bounce-banner-icon{width:30px;height:30px;border-radius:7px;background:var(--am);color:#fff;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.bounce-banner-body{flex:1;min-width:0;}
.bws-step-bouncetag i{font-size:10px;}
.bounce-banner-title{font-size:13.5px;font-weight:700;color:var(--amt);letter-spacing:-0.005em;margin-bottom:3px;}
.bounce-banner-text{font-size:12.5px;color:#7A4A0F;line-height:1.5;letter-spacing:-0.005em;}
.bounce-banner-text strong{font-weight:700;}

/* STEP PANES — only one shows at a time */
.bws-pane{display:none;}
.bws-pane.active{display:flex;flex-direction:column;gap:14px;}

/* ====== DEFINE step content ====== */
.def-grid{display:grid;grid-template-columns:2fr 1fr;gap:14px;}
.def-userjobs{display:flex;flex-direction:column;gap:6px;}
.def-userjob{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:11px 13px;display:grid;grid-template-columns:auto 1fr;gap:11px;align-items:start;}
.def-userjob-icon{width:26px;height:26px;border-radius:6px;background:var(--al);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.def-userjob-text{font-size:13px;color:var(--tp);line-height:1.5;letter-spacing:-0.005em;}
.def-userjob-text strong{font-weight:600;}
.def-userjob-text em{font-style:italic;color:var(--at);}
.def-criteria{display:grid;grid-template-columns:repeat(2,1fr);gap:6px;}
.def-criterion{background:var(--cb);border:1px solid var(--cbr);border-radius:7px;padding:9px 11px;}
.def-criterion-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.08em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:4px;}
.def-criterion-val{font-family:'JetBrains Mono',monospace;font-size:14px;color:var(--tp);font-weight:700;letter-spacing:-0.005em;}
.def-criterion-meta{font-size:11px;color:var(--ts);margin-top:2px;line-height:1.4;}

/* ====== DESIGN step — workflow diagram ====== */

/* Template selector bar */
.tpl-bar{display:flex;align-items:center;gap:8px;padding:8px 12px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;margin-bottom:12px;flex-wrap:wrap;}
.tpl-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.tpl-chip{display:inline-flex;align-items:center;gap:5px;font-family:'Inter',sans-serif;font-size:11.5px;color:var(--ts);background:var(--cb);border:1px solid var(--cbr);border-radius:5px;padding:4px 9px;font-weight:500;cursor:pointer;letter-spacing:-0.005em;}
.tpl-chip:hover{background:var(--s2);color:var(--tp);}
.tpl-chip.active{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.tpl-chip i{font-size:11px;}
.tpl-save{margin-left:auto;display:flex;align-items:center;gap:5px;font-family:'Inter',sans-serif;font-size:11.5px;color:var(--at);background:transparent;border:1px dashed var(--cbr);border-radius:5px;padding:4px 9px;font-weight:500;cursor:pointer;letter-spacing:-0.005em;}
.tpl-save:hover{border-color:var(--ac);background:var(--lyra-bg);}
.tpl-dirty{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--amt);font-weight:700;}

/* Editable workflow nodes — show edit affordances on hover */
.wf-diagram{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:14px;overflow-x:auto;}
.wf-lanes{display:grid;grid-template-columns:80px 1fr;gap:0;}
.wf-lane-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;color:var(--tm);font-weight:700;text-transform:uppercase;padding:14px 8px 14px 0;display:flex;align-items:center;justify-content:flex-end;border-right:1px dashed var(--cbr);}
.wf-lane-lbl.human{color:var(--at);}
.wf-lane-lbl.ai{color:var(--vlt);}
.wf-lane-track{display:flex;align-items:center;gap:6px;padding:8px 0 8px 10px;overflow-x:auto;min-height:64px;}
.wf-node{flex-shrink:0;border:1px solid var(--cbr);border-radius:8px;padding:8px 11px;font-size:11.5px;color:var(--tp);line-height:1.35;letter-spacing:-0.005em;min-width:120px;max-width:170px;background:var(--cb);position:relative;cursor:pointer;transition:all .12s;}
.wf-node:hover{box-shadow:0 2px 8px rgba(15,17,21,.08);}
.wf-node.editing{outline:2px solid var(--ac);outline-offset:1px;}
.wf-node-edit{position:absolute;top:-7px;right:-7px;display:none;gap:3px;background:var(--cb);border:1px solid var(--cbr);border-radius:5px;padding:2px;box-shadow:0 2px 6px rgba(15,17,21,.08);}
.wf-node:hover .wf-node-edit{display:flex;}
.wf-node-edit-btn{background:transparent;border:none;width:18px;height:18px;display:flex;align-items:center;justify-content:center;color:var(--ts);cursor:pointer;border-radius:3px;}
.wf-node-edit-btn:hover{background:var(--s2);color:var(--tp);}
.wf-node-edit-btn.del:hover{background:var(--rdl);color:var(--rdt);}
.wf-node-edit-btn i{font-size:11px;}
.wf-node.human{background:var(--al);border-color:#CBD7FF;}
.wf-node.ai{background:var(--vll);border-color:#C6CAEC;}
.wf-node.handoff{background:#FBFAF8;border-style:dashed;color:var(--ts);font-style:italic;text-align:center;}
.wf-node-lbl{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.08em;font-weight:700;text-transform:uppercase;margin-bottom:3px;}
.wf-node.human .wf-node-lbl{color:var(--at);}
.wf-node.ai .wf-node-lbl{color:var(--vlt);}

/* Insert-step affordance — appears between nodes */
.wf-insert{flex-shrink:0;width:14px;height:30px;display:flex;align-items:center;justify-content:center;color:var(--cbr);font-size:11px;cursor:pointer;border-radius:4px;transition:all .12s;font-weight:700;}
.wf-insert:hover{background:var(--lyra-bg);color:var(--at);width:22px;}

/* Lane controls — add / change-lane */
.wf-lane-actions{display:flex;gap:4px;margin-top:6px;padding-left:10px;}
.wf-lane-add{display:inline-flex;align-items:center;gap:4px;font-family:'Inter',sans-serif;font-size:10.5px;color:var(--at);background:transparent;border:1px dashed var(--cbr);border-radius:5px;padding:3px 8px;font-weight:500;cursor:pointer;letter-spacing:-0.005em;}
.wf-lane-add:hover{border-color:var(--ac);background:var(--lyra-bg);}
.wf-lane-add i{font-size:11px;}

.wf-arrow{color:var(--cbr);font-size:14px;flex-shrink:0;}
.wf-arrow.handoff{color:var(--am);}

/* ====== VALIDATE step — three sub-modes ====== */
.val-modes{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px;}
.val-mode{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:11px 14px;cursor:pointer;transition:all .12s;border-left:3px solid var(--cbr);}
.val-mode:hover{background:#FBFAF8;}
.val-mode.active{border-color:var(--ac);border-left-color:var(--ac);background:var(--lyra-bg);}
.val-mode-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:4px;}
.val-mode-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.val-mode.active .val-mode-lbl{color:var(--at);}
.val-mode-state{font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;padding:2px 6px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase;}
.val-mode-state.pass{background:var(--gnl);color:var(--gnt);}
.val-mode-state.fail{background:var(--rdl);color:var(--rdt);}
.val-mode-state.run{background:var(--aml);color:var(--amt);}
.val-mode-state.idle{background:var(--s2);color:var(--tm);}
.val-mode-name{font-size:13.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-bottom:3px;}
.val-mode-meta{font-size:11.5px;color:var(--ts);line-height:1.4;}

/* ====== SHIP step — record update queue ====== */
.ship-queue{display:flex;flex-direction:column;gap:6px;}
.ship-q-row{display:grid;grid-template-columns:auto 1fr auto auto;gap:11px;align-items:center;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;padding:10px 13px;}
.ship-q-row.pr{border-left:3px solid var(--at);}
.ship-q-row.gtm{border-left:3px solid var(--vlt);}
.ship-q-rec{font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;padding:3px 7px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase;}
.ship-q-rec.pr{background:var(--al);color:var(--at);}
.ship-q-rec.gtm{background:var(--vll);color:var(--vlt);}
.ship-q-body{min-width:0;font-size:12.5px;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;}
.ship-q-body strong{font-weight:600;}
.ship-q-old{color:var(--ts);text-decoration:line-through;text-decoration-color:rgba(209,67,67,.4);margin-right:4px;}
.ship-q-arr{color:var(--tm);font-size:11px;margin:0 4px;}
.ship-q-new{color:var(--at);font-weight:600;}
.ship-q-state{font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;padding:2px 7px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase;}
.ship-q-state.auto{background:var(--gnl);color:var(--gnt);}
.ship-q-state.review{background:var(--aml);color:var(--amt);}
.ship-q-check{width:18px;height:18px;border-radius:4px;border:1.5px solid var(--cbr);display:flex;align-items:center;justify-content:center;cursor:pointer;}
.ship-q-check.on{background:var(--ac);border-color:var(--ac);color:#fff;}
.ship-q-check.on i{font-size:12px;}

.ship-gate{background:linear-gradient(0deg,#F4FBF6,#FBFFFB);border:1px solid #B8DBC5;border-radius:10px;padding:12px 16px;display:flex;align-items:flex-start;gap:12px;margin-bottom:14px;}
.ship-gate-icon{width:30px;height:30px;border-radius:7px;background:var(--gn);color:#fff;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.ship-gate-body{flex:1;min-width:0;}
.ship-gate-title{font-size:13.5px;font-weight:700;color:var(--gnt);letter-spacing:-0.005em;margin-bottom:2px;}
.ship-gate-text{font-size:12.5px;color:#0E4B2C;line-height:1.5;letter-spacing:-0.005em;}
.ship-gate.pending{background:linear-gradient(0deg,var(--aml),#FBF1DD);border-color:#E7CFA0;}
.ship-gate.pending .ship-gate-icon{background:var(--am);}
.ship-gate.pending .ship-gate-title{color:var(--amt);}
.ship-gate.pending .ship-gate-text{color:#7A4A0F;}

.ship-target-row{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:11px 13px;display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:center;}
.ship-target-row-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;}
.ship-target-row-val{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.ship-target-row-meta{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:600;}

/* ====== LEARN step ====== */
.learn-metric-row{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
.learn-metric{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:11px 13px;border-top:3px solid var(--cbr);}
.learn-metric.target{border-top-color:var(--gn);}
.learn-metric.warn{border-top-color:var(--am);}
.learn-metric.miss{border-top-color:var(--rd);}
.learn-metric-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.08em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:4px;}
.learn-metric-val{font-family:'JetBrains Mono',monospace;font-size:18px;color:var(--tp);font-weight:700;}
.learn-metric.target .learn-metric-val{color:var(--gnt);}
.learn-metric.warn .learn-metric-val{color:var(--amt);}
.learn-metric.miss .learn-metric-val{color:var(--rdt);}
.learn-metric-target{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;margin-top:3px;}

/* ====== PROTOTYPE step canvas — painter/brush framing ====== */
.brush-roles{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;}
.brush-role{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:13px 15px;}
.brush-role.human{border-left:3px solid var(--at);}
.brush-role.ai{border-left:3px solid var(--vlt);}
.brush-role-lbl{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;text-transform:uppercase;margin-bottom:6px;}
.brush-role.human .brush-role-lbl{color:var(--at);}
.brush-role.ai .brush-role-lbl{color:var(--vlt);}
.brush-role-text{font-size:13px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;}
.brush-role-actions{display:flex;gap:5px;flex-wrap:wrap;margin-top:9px;}
.brush-act{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--ts);background:var(--s2);border:1px solid var(--cbr);border-radius:5px;padding:3px 8px;font-weight:600;letter-spacing:-0.005em;cursor:pointer;}
.brush-act:hover{background:var(--cb);color:var(--tp);}
.brush-act i{font-size:11px;}

.bws-canvas-section-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:8px;}

/* ============ PROTOTYPE · BUILD WORKSPACE ============ */

/* PROTOTYPE HOME — entry surface with three modes */
.pt-home-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:32px;}
.pt-home-tile{background:var(--cb);border:1px solid var(--cbr);border-radius:14px;padding:22px;display:flex;flex-direction:column;gap:14px;cursor:pointer;transition:all .15s;border-top:3px solid;min-height:240px;}
.pt-home-tile:hover{transform:translateY(-3px);box-shadow:0 6px 18px rgba(15,17,21,.06);}
.pt-home-tile.releases{border-top-color:var(--ac);}
.pt-home-tile.gaps{border-top-color:var(--am);}
.pt-home-tile.sandbox{border-top-color:var(--vl);}
.pt-home-tile.releases:hover{border-color:#CBD7FF;}
.pt-home-tile.gaps:hover{border-color:#EBD9B8;}
.pt-home-tile.sandbox:hover{border-color:#C6CAEC;}
.pt-home-icon{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;}
.pt-home-tile.releases .pt-home-icon{background:var(--al);color:var(--at);}
.pt-home-tile.gaps .pt-home-icon{background:var(--aml);color:var(--amt);}
.pt-home-tile.sandbox .pt-home-icon{background:var(--vll);color:var(--vlt);}
.pt-home-icon i{font-size:22px;}
.pt-home-tile-title{font-family:'Fraunces',Georgia,serif;font-size:22px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1.1;}
.pt-home-tile-desc{font-size:13px;color:var(--ts);line-height:1.55;flex:1;}
.pt-home-tile-meta{display:flex;align-items:center;justify-content:space-between;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:600;padding-top:12px;border-top:1px solid var(--cbr);margin-top:auto;}
.pt-home-tile-num{font-family:'Fraunces',Georgia,serif;font-size:18px;color:var(--tp);font-weight:600;}

/* Drill-down panes for each home mode */
.pt-mode-pane{display:none;}
.pt-mode-pane.active{display:block;}

/* By Release — release cards with prototype slots */
.pt-rel-list{display:flex;flex-direction:column;gap:14px;}
.pt-rel-card{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.pt-rel-card-hdr{display:flex;align-items:center;gap:14px;padding:14px 18px;border-bottom:1px solid var(--cbr);background:#FBFAF8;}
.pt-rel-ver{font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:700;background:var(--tp);color:#fff;padding:3px 9px;border-radius:4px;}
.pt-rel-card-title{flex:1;font-size:14.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.pt-rel-card-date{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:600;}
.pt-rel-card-body{padding:6px;}
.pt-rel-slot{display:grid;grid-template-columns:auto 1fr auto auto;align-items:center;gap:14px;padding:10px 14px;border-radius:8px;cursor:pointer;transition:background .12s;}
.pt-rel-slot:hover{background:#FBFAF8;}
.pt-rel-slot-icon{width:30px;height:30px;border-radius:7px;background:var(--lyra-bg);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.pt-rel-slot.empty .pt-rel-slot-icon{background:var(--s2);color:var(--tm);}
.pt-rel-slot-body{min-width:0;}
.pt-rel-slot-title{font-size:13.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-bottom:2px;}
.pt-rel-slot-meta{font-size:12px;color:var(--ts);line-height:1.4;}
.pt-rel-slot-stat{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;text-align:right;}
.pt-rel-slot-tag{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;padding:3px 8px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase;}
.pt-rel-slot-tag.shipped{background:var(--gnl);color:var(--gnt);}
.pt-rel-slot-tag.active{background:var(--al);color:var(--at);}
.pt-rel-slot-tag.handoff{background:var(--aml);color:var(--amt);}
.pt-rel-slot-tag.empty{background:transparent;color:var(--at);border:1px dashed var(--ac);font-weight:600;}

/* Gaps */
.pt-gap-list{display:flex;flex-direction:column;gap:10px;}
.pt-gap-card{background:var(--cb);border:1px solid var(--cbr);border-left:3px solid var(--am);border-radius:10px;padding:14px 18px;cursor:pointer;transition:all .12s;}
.pt-gap-card:hover{border-color:var(--am);background:#FBFAF8;}
.pt-gap-hdr{display:flex;align-items:flex-start;justify-content:space-between;gap:14px;margin-bottom:8px;flex-wrap:wrap;}
.pt-gap-title{font-size:14.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;flex:1;min-width:0;}
.pt-gap-conf{font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;color:var(--amt);background:var(--aml);padding:3px 8px;border-radius:4px;}
.pt-gap-text{font-size:12.5px;color:var(--ts);line-height:1.55;margin-bottom:8px;}
.pt-gap-srcs{display:flex;gap:6px;flex-wrap:wrap;}
.pt-gap-src{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--ts);background:var(--s2);border-radius:4px;padding:3px 7px;}

/* Sandbox starting prompts */
.pt-sandbox-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px;}
.pt-sb-card{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:16px 18px;cursor:pointer;transition:all .12s;display:flex;flex-direction:column;gap:8px;}
.pt-sb-card:hover{border-color:var(--vl);background:#FBFAF8;}
.pt-sb-card-icon{width:30px;height:30px;border-radius:7px;background:var(--vll);color:var(--vlt);display:flex;align-items:center;justify-content:center;font-size:14px;}
.pt-sb-card-title{font-size:13.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.pt-sb-card-text{font-size:12.5px;color:var(--ts);line-height:1.5;}

/* Mode tabs (Releases / Gaps / Sandbox / Recent) */
.pt-mode-tabs{display:flex;border-bottom:1px solid var(--cbr);gap:0;margin-bottom:22px;}
.pt-mode-tab{background:transparent;border:none;padding:11px 18px 13px;font-size:13.5px;font-weight:500;color:var(--tm);cursor:pointer;font-family:'Inter',sans-serif;letter-spacing:-0.005em;border-bottom:2px solid transparent;margin-bottom:-1px;display:flex;align-items:center;gap:7px;}
.pt-mode-tab:hover{color:var(--ts);}
.pt-mode-tab.active{color:var(--tp);font-weight:600;border-bottom-color:var(--tp);}
.pt-mode-tab i{font-size:14px;}
.pt-mode-tab span.tabular{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);}
.pt-mode-tab.active span.tabular{color:var(--at);}

.pt-list-cards{display:flex;flex-direction:column;gap:10px;}
.pt-row{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:13px 18px;display:grid;grid-template-columns:auto 1fr auto auto;gap:18px;align-items:center;cursor:pointer;transition:all .12s;}
.pt-row:hover{border-color:#D9D5CC;background:#FBFAF8;}
.pt-row-icon{width:34px;height:34px;border-radius:8px;background:var(--lyra-bg);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:16px;}
.pt-row-body{min-width:0;}
.pt-row-title{font-size:14px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-bottom:3px;}
.pt-row-meta{font-size:12px;color:var(--ts);line-height:1.4;}
.pt-row-stat{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;text-align:right;}
.pt-row-tag{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;padding:3px 8px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase;}
.pt-row-tag.active{background:var(--gnl);color:var(--gnt);}
.pt-row-tag.handoff{background:var(--aml);color:var(--amt);}
.pt-row-tag.idle{background:var(--s2);color:var(--tm);}

/* WORKSPACE LAYOUT — when an active prototype is open */
/* WORKSPACE LAYOUT — single-column, preview is the focus */
.pt-ws{display:flex;flex-direction:column;gap:12px;}

.pt-ws-main{display:flex;flex-direction:column;gap:14px;min-width:0;}

/* TARGET picker bar */
.pt-target-bar{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:12px 16px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.pt-target-bar-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--tm);font-weight:700;}
.pt-target-chip{display:flex;align-items:center;gap:7px;padding:5px 11px;background:var(--al);border:1px solid #CBD7FF;border-radius:7px;font-size:12.5px;font-weight:600;color:var(--at);letter-spacing:-0.005em;}
.pt-target-chip i{font-size:13px;}
.pt-target-arrow{color:var(--tm);font-size:13px;}
.pt-target-name{font-size:13.5px;font-weight:600;color:var(--tp);letter-spacing:-0.01em;}

/* INTENT box → connected to preview */
.pt-controller{position:relative;background:var(--cb);border:1.5px solid var(--lyra-bd);border-radius:12px;padding:16px 18px;}
.pt-controller-header{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.pt-controller-icon{width:30px;height:30px;border-radius:8px;background:var(--lyra-bg);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.pt-controller-titles{flex:1;}
.pt-controller-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--at);font-weight:700;}
.pt-controller-sub{font-size:12.5px;color:var(--ts);font-weight:500;margin-top:1px;}
.pt-controller-arrow-hint{display:inline-flex;align-items:center;gap:5px;font-size:11.5px;color:var(--at);font-weight:600;font-family:'JetBrains Mono',monospace;}
.pt-controller-arrow-hint i{font-size:12px;}

.pt-intent-text{width:100%;background:transparent;border:none;outline:none;font-family:'Inter',sans-serif;font-size:15px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;resize:vertical;min-height:54px;}
.pt-intent-text::placeholder{color:var(--tm);}
.pt-intent-foot{display:flex;justify-content:space-between;align-items:center;padding-top:10px;margin-top:10px;border-top:1px dashed var(--cbr);}
.pt-intent-hints{display:flex;gap:6px;flex-wrap:wrap;}
.pt-intent-hint{background:var(--s2);border:1px solid var(--cbr);border-radius:6px;padding:4px 9px;font-size:11.5px;font-weight:500;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;}
.pt-intent-hint:hover{background:var(--al);color:var(--at);border-color:#CBD7FF;}
.pt-intent-go{background:var(--ac);color:#fff;border:none;border-radius:7px;padding:8px 16px;font-family:'Inter',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;letter-spacing:-0.005em;}
.pt-intent-go:hover{background:#4A77E8;}
.pt-intent-go i{font-size:14px;}

/* Visual connector — arrow between controller and preview */
.pt-flow-arrow{display:flex;align-items:center;justify-content:center;gap:8px;padding:4px 0;color:var(--at);font-family:'JetBrains Mono',monospace;font-size:10.5px;font-weight:700;letter-spacing:.1em;}
.pt-flow-arrow-line{flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--lyra-bd) 20%,var(--lyra-bd) 80%,transparent);}
.pt-flow-arrow-icon{display:flex;align-items:center;justify-content:center;width:24px;height:24px;background:var(--lyra-bg);border:1.5px solid var(--lyra-bd);border-radius:50%;color:var(--at);font-size:14px;}

/* PREVIEW CANVAS */
.pt-preview{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;overflow:hidden;}
.pt-preview-banner{background:linear-gradient(0deg,var(--gnl),#F5FAF7);border-bottom:1px solid #B8DBC5;padding:8px 14px;display:flex;align-items:center;gap:10px;}
.pt-preview-banner-dot{width:8px;height:8px;border-radius:50%;background:var(--gn);animation:pulse 1.6s infinite;}
.pt-preview-banner-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--gnt);font-weight:700;}
.pt-preview-banner-text{font-size:12px;color:var(--gnt);font-weight:600;letter-spacing:-0.005em;}
.pt-preview-banner-text strong{color:#0E4B2C;}
.pt-preview-bar{padding:8px 12px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--cbr);background:#FBFAF8;}
.pt-preview-mode{display:flex;background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:2px;gap:1px;}
.pt-preview-mode-btn{background:transparent;border:none;border-radius:4px;padding:5px 10px;font-size:11.5px;font-weight:500;color:var(--ts);cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:5px;letter-spacing:-0.005em;}
.pt-preview-mode-btn:hover{color:var(--tp);}
.pt-preview-mode-btn.active{background:var(--tp);color:#fff;font-weight:600;}
.pt-preview-mode-btn i{font-size:12px;}
.pt-preview-meta{flex:1;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}
.pt-preview-actions{display:flex;gap:6px;}
.pt-preview-act{background:transparent;border:1px solid var(--cbr);border-radius:6px;width:28px;height:28px;display:flex;align-items:center;justify-content:center;color:var(--ts);cursor:pointer;}
.pt-preview-act:hover{background:var(--s2);color:var(--tp);}
.pt-preview-act i{font-size:13px;}
.pt-preview-canvas{background:#F5F5F1;padding:24px;min-height:380px;display:flex;align-items:flex-start;justify-content:center;}
/* mock preview surface */
.pt-mock{width:100%;max-width:760px;background:var(--cb);border:1px solid var(--cbr);border-radius:10px;box-shadow:0 4px 16px rgba(15,17,21,.06);overflow:hidden;}
.pt-mock-bar{height:36px;background:#FBFAF8;border-bottom:1px solid var(--cbr);display:flex;align-items:center;padding:0 12px;gap:8px;}
.pt-mock-dot{width:9px;height:9px;border-radius:50%;background:#E0DDD7;}
.pt-mock-url{flex:1;text-align:center;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);}
.pt-mock-body{padding:20px;}
.pt-mock-title{font-size:18px;font-weight:700;color:var(--tp);margin-bottom:14px;letter-spacing:-0.015em;}
.pt-mock-inbox-item{display:flex;gap:12px;padding:11px 12px;border-radius:8px;border:1px solid var(--cbr);margin-bottom:8px;background:#FBFAF8;}
.pt-mock-inbox-item.new{background:var(--al);border-color:#CBD7FF;}
.pt-mock-inbox-icon{width:28px;height:28px;border-radius:6px;background:var(--cb);border:1px solid var(--cbr);display:flex;align-items:center;justify-content:center;color:var(--at);flex-shrink:0;}
.pt-mock-inbox-icon i{font-size:13px;}
.pt-mock-inbox-body{flex:1;min-width:0;}
.pt-mock-inbox-title{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;margin-bottom:2px;}
.pt-mock-inbox-text{font-size:12px;color:var(--ts);line-height:1.45;}
.pt-mock-inbox-when{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);flex-shrink:0;}
.pt-mock-controls{display:flex;gap:8px;margin-top:14px;padding-top:14px;border-top:1px dashed var(--cbr);}
.pt-mock-toggle{display:flex;align-items:center;gap:8px;padding:7px 11px;background:var(--s2);border:1px solid var(--cbr);border-radius:7px;font-size:11.5px;color:var(--ts);font-weight:500;}
.pt-mock-toggle.on{background:var(--gnl);color:var(--gnt);border-color:#B8DBC5;}
.pt-mock-toggle-sw{width:22px;height:12px;background:var(--cbr);border-radius:8px;position:relative;}
.pt-mock-toggle-sw::after{content:'';position:absolute;width:8px;height:8px;background:#fff;border-radius:50%;top:2px;left:2px;transition:left .15s;}
.pt-mock-toggle.on .pt-mock-toggle-sw{background:var(--gn);}
.pt-mock-toggle.on .pt-mock-toggle-sw::after{left:12px;}

/* CONVERSATION dock */
.pt-conv{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:14px 16px;display:flex;flex-direction:column;gap:12px;}
.pt-conv-msgs{display:flex;flex-direction:column;gap:10px;max-height:240px;overflow-y:auto;}
.pt-conv-msg{display:flex;gap:10px;align-items:flex-start;}
.pt-conv-msg-avatar{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;}
.pt-conv-msg-avatar.lyra{background:var(--lyra-bg);color:var(--at);}
.pt-conv-msg-avatar.user{background:var(--s2);color:var(--tp);}
.pt-conv-msg-body{flex:1;min-width:0;}
.pt-conv-msg-who{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.1em;font-weight:700;color:var(--tm);margin-bottom:3px;text-transform:uppercase;}
.pt-conv-msg-who.lyra{color:var(--at);}
.pt-conv-msg-text{font-size:13px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;}
.pt-conv-applied{display:inline-flex;align-items:center;gap:4px;margin-top:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--at);background:var(--al);padding:3px 8px;border-radius:4px;font-weight:600;}
.pt-conv-input{display:flex;gap:8px;padding-top:10px;border-top:1px dashed var(--cbr);}
.pt-conv-input input{flex:1;background:#FBFAF8;border:1px solid var(--cbr);border-radius:7px;padding:9px 12px;font-family:'Inter',sans-serif;font-size:13px;color:var(--tp);outline:none;letter-spacing:-0.005em;}
.pt-conv-input input:focus{border-color:var(--ac);background:var(--cb);}
.pt-conv-input button{background:var(--ac);border:none;border-radius:7px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:#fff;cursor:pointer;flex-shrink:0;}

/* RIGHT rail — context */
.pt-rail{display:flex;flex-direction:column;gap:14px;min-width:0;}
.pt-rail-card{background:var(--cb);border:1px solid var(--cbr);border-radius:10px;overflow:hidden;}
.pt-rail-hdr{padding:10px 14px;background:#FBFAF8;border-bottom:1px solid var(--cbr);font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--tm);font-weight:700;display:flex;align-items:center;gap:6px;}
.pt-rail-hdr i{font-size:12px;}
.pt-rail-body{padding:8px;}
.pt-rail-item{display:flex;align-items:flex-start;gap:9px;padding:8px 10px;border-radius:7px;cursor:pointer;transition:background .12s;}
.pt-rail-item:hover{background:#FBFAF8;}
.pt-rail-item-icon{width:22px;height:22px;border-radius:5px;background:var(--s2);color:var(--ts);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;margin-top:1px;}
.pt-rail-item-body{flex:1;min-width:0;}
.pt-rail-item-title{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;line-height:1.3;}
.pt-rail-item-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);margin-top:2px;}
.pt-rail-add{width:calc(100% - 16px);background:transparent;border:1px dashed var(--cbr);border-radius:7px;padding:7px;font-family:'Inter',sans-serif;font-size:11.5px;font-weight:500;color:var(--at);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;margin:6px 8px 8px;}
.pt-rail-add:hover{border-color:var(--ac);background:var(--lyra-bg);}

/* UNIFIED CHAT-CONTROLLER (replaces controller + conversation) */
.pt-chat{background:var(--cb);border:1.5px solid var(--lyra-bd);border-radius:12px;display:flex;flex-direction:column;overflow:hidden;}
.pt-chat-hdr{background:linear-gradient(0deg,var(--lyra-bg),#F5F8FF);border-bottom:1px solid var(--lyra-bd);padding:10px 14px;display:flex;align-items:center;gap:10px;}
.pt-chat-hdr-icon{width:28px;height:28px;border-radius:7px;background:var(--cb);border:1px solid var(--lyra-bd);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.pt-chat-hdr-titles{flex:1;min-width:0;}
.pt-chat-hdr-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--at);font-weight:700;}
.pt-chat-hdr-sub{font-size:11.5px;color:var(--ts);font-weight:500;margin-top:1px;}
.pt-chat-msgs{display:flex;flex-direction:column;gap:11px;padding:14px;max-height:280px;overflow-y:auto;}
.pt-chat-controls{display:flex;gap:6px;padding:8px 14px;border-top:1px solid var(--cbr);background:#FBFAF8;flex-wrap:wrap;}
.pt-chat-tool{background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:5px 10px;font-family:'Inter',sans-serif;font-size:11.5px;font-weight:500;color:var(--ts);cursor:pointer;display:flex;align-items:center;gap:5px;letter-spacing:-0.005em;}
.pt-chat-tool:hover{background:var(--al);color:var(--at);border-color:#CBD7FF;}
.pt-chat-tool i{font-size:13px;}
.pt-chat-input{display:flex;gap:8px;padding:10px 14px 14px;border-top:1px solid var(--cbr);background:var(--cb);}
.pt-chat-input input{flex:1;background:#FBFAF8;border:1px solid var(--cbr);border-radius:8px;padding:10px 13px;font-family:'Inter',sans-serif;font-size:13.5px;color:var(--tp);outline:none;letter-spacing:-0.005em;}
.pt-chat-input input:focus{border-color:var(--ac);background:var(--cb);box-shadow:0 0 0 3px rgba(94,138,255,.08);}
.pt-chat-send{background:var(--ac);border:none;border-radius:8px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;color:#fff;cursor:pointer;flex-shrink:0;}
.pt-chat-send:hover{background:#4A77E8;}

/* HANDOFF actions bar */
.pt-handoff{background:var(--cb);border:1px solid var(--cbr);border-radius:12px;padding:14px 18px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.pt-handoff-left{flex:1;min-width:0;}
.pt-handoff-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--tm);font-weight:700;margin-bottom:3px;}
.pt-handoff-status{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.pt-handoff-status strong{color:var(--gnt);}
.pt-handoff-actions{display:flex;gap:8px;flex-wrap:wrap;}
.pt-handoff-btn{background:var(--cb);border:1px solid var(--cbr);border-radius:7px;padding:8px 14px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:var(--ts);cursor:pointer;display:flex;align-items:center;gap:7px;letter-spacing:-0.005em;flex-direction:column;align-items:flex-start;}
.pt-handoff-btn:hover{background:var(--s2);color:var(--tp);}
.pt-handoff-btn-row{display:flex;align-items:center;gap:6px;font-weight:600;}
.pt-handoff-btn-sub{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:500;color:var(--tm);text-transform:uppercase;letter-spacing:.06em;margin-top:1px;}
.pt-handoff-btn:hover .pt-handoff-btn-sub{color:var(--ts);}
.pt-handoff-btn i{font-size:14px;}
.pt-handoff-btn.export{background:var(--cb);}
.pt-handoff-btn.build{background:var(--tp);color:#fff;border-color:var(--tp);}
.pt-handoff-btn.build:hover{background:#2A2D33;color:#fff;}
.pt-handoff-btn.build .pt-handoff-btn-sub{color:#9BA0AB;}
.pt-handoff-btn.build:hover .pt-handoff-btn-sub{color:#C8D0D9;}

/* Versions strip */
.pt-versions{display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.pt-version{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);background:var(--s2);border:1px solid var(--cbr);border-radius:5px;padding:3px 8px;cursor:pointer;}
.pt-version:hover{background:var(--al);color:var(--at);border-color:#CBD7FF;}
.pt-version.active{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:700;}

/* BUILD SESSION OVERLAY — what happens after "Build with Claude" */
.bs-back{position:fixed;inset:0;background:rgba(15,17,21,.55);z-index:50;opacity:0;pointer-events:none;transition:opacity .2s;}
.bs-back.open{opacity:1;pointer-events:auto;}
.bs-pane{position:fixed;top:0;right:0;bottom:0;width:min(860px,90vw);background:var(--bg);z-index:51;transform:translateX(100%);transition:transform .25s;display:flex;flex-direction:column;}
.bs-pane.open{transform:translateX(0);box-shadow:-12px 0 32px rgba(15,17,21,.18);}
.bs-hdr{background:#0F1115;color:#fff;padding:14px 22px;display:flex;align-items:center;gap:14px;flex-shrink:0;}
.bs-hdr-icon{width:32px;height:32px;border-radius:7px;background:var(--ac);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.bs-hdr-titles{flex:1;}
.bs-hdr-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:#9BA0AB;font-weight:700;}
.bs-hdr-title{font-size:14px;font-weight:600;color:#fff;letter-spacing:-0.005em;margin-top:2px;}
.bs-hdr-status{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--ac);font-weight:600;}
.bs-hdr-status-dot{width:7px;height:7px;border-radius:50%;background:var(--ac);animation:pulse 1.6s infinite;}
.bs-close{background:transparent;border:1px solid #2A2D33;border-radius:7px;width:34px;height:34px;display:flex;align-items:center;justify-content:center;color:#9BA0AB;cursor:pointer;}
.bs-close:hover{background:#2A2D33;color:#fff;}
.bs-body{flex:1;display:grid;grid-template-columns:1fr 280px;overflow:hidden;min-height:0;}
.bs-stream{background:#0F1115;color:#C8D0D9;font-family:'JetBrains Mono',monospace;font-size:12px;line-height:1.65;padding:18px 22px;overflow-y:auto;border-right:1px solid #2A2D33;}
.bs-stream-line{display:flex;gap:10px;padding:2px 0;}
.bs-stream-line.cmd{color:var(--ac);}
.bs-stream-line.ok{color:#7AC987;}
.bs-stream-line.warn{color:#E0B96C;}
.bs-stream-line.info{color:#C8D0D9;}
.bs-stream-line.dim{color:#5A5F6B;}
.bs-stream-marker{flex-shrink:0;color:#5A5F6B;width:14px;}
.bs-stream-section{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;letter-spacing:.12em;color:#5A5F6B;margin:14px 0 6px;text-transform:uppercase;}
.bs-stream-section:first-child{margin-top:0;}
.bs-cursor{display:inline-block;width:8px;height:13px;background:var(--ac);animation:blink 1s infinite;margin-left:2px;vertical-align:middle;}
.bs-side{background:#FBFAF8;padding:18px 16px;overflow-y:auto;display:flex;flex-direction:column;gap:14px;}
.bs-side-card{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:11px 14px;}
.bs-side-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:6px;}
.bs-side-step{display:flex;align-items:center;gap:9px;padding:6px 0;font-size:12px;color:var(--ts);}
.bs-side-step i{font-size:13px;}
.bs-side-step.done{color:var(--gnt);}
.bs-side-step.done i{color:var(--gn);}
.bs-side-step.active{color:var(--tp);font-weight:600;}
.bs-side-step.active i{color:var(--ac);animation:pulse 1.6s infinite;}
.bs-side-step.pending{color:var(--tm);}
.bs-side-files{display:flex;flex-direction:column;gap:3px;}
.bs-side-file{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--ts);display:flex;align-items:center;gap:6px;padding:3px 0;}
.bs-side-file i{font-size:12px;flex-shrink:0;}
.bs-side-file.new i{color:var(--gn);}
.bs-side-file.mod i{color:var(--am);}
.bs-side-actions{display:flex;flex-direction:column;gap:6px;}
.bs-side-btn{background:var(--cb);border:1px solid var(--cbr);border-radius:7px;padding:8px 12px;font-family:'Inter',sans-serif;font-size:12.5px;font-weight:500;color:var(--ts);cursor:pointer;display:flex;align-items:center;gap:7px;letter-spacing:-0.005em;width:100%;}
.bs-side-btn:hover{background:var(--s2);color:var(--tp);}
.bs-side-btn.prim{background:var(--ac);color:#fff;border-color:var(--ac);font-weight:600;}
.bs-side-btn.prim:hover{background:#4A77E8;color:#fff;}

/* SHIP MODULE PLACEHOLDERS */
.ship-empty{background:var(--cb);border:1px dashed var(--cbr);border-radius:12px;padding:48px 32px;text-align:center;max-width:680px;margin:0 auto;}
.ship-empty-icon{width:52px;height:52px;border-radius:12px;background:var(--lyra-bg);color:var(--at);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;}
.ship-empty-icon i{font-size:24px;}
.ship-empty-title{font-family:'Fraunces',Georgia,serif;font-size:22px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;margin-bottom:8px;}
.ship-empty-text{font-size:13.5px;color:var(--ts);line-height:1.6;margin-bottom:20px;}
.ship-empty-srcs{display:flex;justify-content:center;gap:8px;flex-wrap:wrap;}
.ship-empty-src{display:inline-flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--ts);background:var(--s2);border:1px solid var(--cbr);border-radius:5px;padding:5px 10px;}
.ship-empty-src i{font-size:12px;}

/* ============ PROPOSAL DRILL-DOWN OVERLAY ============ */
.pd-back{position:fixed;inset:0;background:rgba(15,17,21,.35);z-index:50;opacity:0;pointer-events:none;transition:opacity .2s;}
.pd-back.open{opacity:1;pointer-events:auto;}
.pd-pane{position:fixed;top:0;right:0;bottom:0;width:min(720px,80vw);background:var(--bg);z-index:51;transform:translateX(100%);transition:transform .25s, right .25s;display:flex;flex-direction:column;}
.pd-pane.open{transform:translateX(0);box-shadow:-12px 0 32px rgba(15,17,21,.18);}

/* ALWAYS-VISIBLE close button — floats above all pane content, can never scroll away */
.pd-floating-close{position:absolute;top:14px;right:14px;width:38px;height:38px;border-radius:8px;background:var(--cb);border:1px solid var(--cbr);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--tp);z-index:60;box-shadow:0 2px 8px rgba(15,17,21,.08);font-size:18px;}
.pd-floating-close:hover{background:var(--s2);}
.pd-floating-close i{font-size:18px;}
/* When Lyra panel is open, slide the proposal pane left so they coexist */
body.lyra-open .pd-pane{right:clamp(300px,24vw,400px);}
body.lyra-open .pd-back{right:clamp(300px,24vw,400px);}

.pd-hdr{background:var(--cb);border-bottom:1px solid var(--cbr);padding:14px 22px;display:flex;align-items:center;gap:14px;flex-shrink:0;}
.pd-hdr-eyebrow{display:flex;align-items:center;gap:7px;font-family:'JetBrains Mono',monospace;font-size:10.5px;letter-spacing:.12em;color:var(--at);font-weight:700;}
.pd-hdr-eyebrow i{font-size:13px;}
.pd-hdr-sep{color:var(--cbr);}
.pd-hdr-branch{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);font-weight:600;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.pd-hdr-sp{flex:1;min-width:0;}
.pd-conf{display:flex;align-items:center;gap:6px;font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;flex-shrink:0;}
.pd-conf-dot{width:7px;height:7px;border-radius:50%;background:var(--gn);}
.pd-conf.high{color:var(--gnt);}
.pd-close{background:transparent;border:1px solid var(--cbr);border-radius:7px;width:34px;height:34px;display:flex;align-items:center;justify-content:center;color:var(--ts);cursor:pointer;flex-shrink:0;}
.pd-close:hover{background:var(--s2);color:var(--tp);}

.pd-title-bar{padding:18px 22px 16px;background:var(--cb);border-bottom:1px solid var(--cbr);flex-shrink:0;}
.pd-title{font-family:'Fraunces',Georgia,serif;font-size:22px;font-weight:600;color:var(--tp);letter-spacing:-0.02em;line-height:1.25;}

.pd-body{flex:1;display:grid;grid-template-columns:1fr 320px;overflow:hidden;min-height:0;}
.pd-center{display:flex;flex-direction:column;overflow:hidden;min-height:0;border-right:1px solid var(--cbr);}
.pd-center-scroll{flex:1;overflow-y:auto;padding:18px 22px;}
.pd-right{display:flex;flex-direction:column;overflow:hidden;background:#FBFAF8;min-height:0;}
.pd-right-scroll{flex:1;overflow-y:auto;padding:16px 18px;}

.pd-sect-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--tm);font-weight:700;text-transform:uppercase;margin-bottom:10px;}
.pd-sect-lbl:not(:first-child){margin-top:22px;}
.pd-target{display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--cb);border:1px solid var(--cbr);border-radius:8px;margin-bottom:14px;}
.pd-target-icon{width:28px;height:28px;border-radius:6px;background:var(--s2);color:var(--tp);display:flex;align-items:center;justify-content:center;font-size:14px;}
.pd-target-body{flex:1;min-width:0;}
.pd-target-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.12em;color:var(--tm);font-weight:600;margin-bottom:2px;}
.pd-target-name{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}

.pd-diff{display:grid;grid-template-columns:1fr 28px 1fr;gap:0;align-items:stretch;margin-bottom:18px;}
.pd-diff-col{display:flex;flex-direction:column;gap:7px;background:var(--cb);border:1px solid var(--cbr);border-radius:10px;padding:13px 14px;}
.pd-diff-col.old{}
.pd-diff-col.new{border-color:#CBD7FF;background:#F5F8FF;}
.pd-diff-col-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.14em;font-weight:700;}
.pd-diff-col.old .pd-diff-col-lbl{color:var(--rdt);}
.pd-diff-col.new .pd-diff-col-lbl{color:var(--at);}
.pd-diff-val{font-size:13px;line-height:1.55;color:var(--tp);}
.pd-diff-val.old{color:var(--ts);text-decoration:line-through;text-decoration-color:rgba(209,67,67,.35);}
.pd-diff-arrow{display:flex;align-items:center;justify-content:center;color:var(--tm);font-size:18px;}

/* Direct edit textarea */
.pd-edit{display:flex;flex-direction:column;gap:6px;}
.pd-edit-lbl{display:flex;align-items:center;justify-content:space-between;}
.pd-edit-lbl-text{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.14em;color:var(--tm);font-weight:700;}
.pd-edit-revert{background:transparent;border:none;color:var(--at);font-size:11.5px;font-weight:500;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:4px;}
.pd-edit-revert:hover{text-decoration:underline;}
.pd-edit-revert i{font-size:12px;}
.pd-textarea{width:100%;min-height:110px;background:var(--cb);border:1.5px solid #CBD7FF;border-radius:10px;padding:12px 14px;font-family:'Inter',sans-serif;font-size:14px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;resize:vertical;outline:none;transition:border-color .12s;}
.pd-textarea:focus{border-color:var(--ac);box-shadow:0 0 0 3px rgba(94,138,255,.12);}
.pd-edit-meta{display:flex;align-items:center;gap:14px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);margin-top:4px;}
.pd-edit-meta i{font-size:12px;}

/* Why panel */
.pd-why{background:var(--cb);border:1px solid var(--cbr);border-left:3px solid var(--ac);border-radius:8px;padding:12px 14px;}
.pd-why-text{font-size:13px;color:var(--ts);line-height:1.55;}
.pd-why-text strong{color:var(--tp);font-weight:600;}

/* Cascade / impact pills */
.pd-cascade-list{display:flex;flex-direction:column;gap:6px;}
.pd-cascade-item{display:flex;align-items:center;gap:9px;padding:8px 12px;background:var(--cb);border:1px solid var(--cbr);border-radius:7px;font-size:12.5px;color:var(--ts);letter-spacing:-0.005em;}
.pd-cascade-item i{font-size:13px;color:var(--at);flex-shrink:0;}
.pd-cascade-item strong{color:var(--tp);font-weight:600;}

/* Conversation dock */
.pd-conv{background:var(--cb);border-top:1px solid var(--cbr);padding:14px 22px;display:flex;flex-direction:column;gap:10px;flex-shrink:0;max-height:280px;overflow-y:auto;}
.pd-conv-msgs{display:flex;flex-direction:column;gap:10px;}
.pd-conv-msg{display:flex;gap:10px;align-items:flex-start;}
.pd-conv-msg-avatar{width:24px;height:24px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;}
.pd-conv-msg-avatar.lyra{background:var(--lyra-bg);color:var(--at);}
.pd-conv-msg-avatar.user{background:var(--s2);color:var(--tp);}
.pd-conv-msg-body{flex:1;min-width:0;}
.pd-conv-msg-who{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.1em;font-weight:700;color:var(--tm);margin-bottom:3px;text-transform:uppercase;}
.pd-conv-msg-who.lyra{color:var(--at);}
.pd-conv-msg-text{font-size:13px;color:var(--tp);line-height:1.55;letter-spacing:-0.005em;}
.pd-conv-msg-text.applied{display:inline-block;margin-top:5px;font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--at);background:var(--al);padding:2px 7px;border-radius:4px;font-weight:600;}
.pd-conv-input{display:flex;gap:8px;border-top:1px dashed var(--cbr);padding-top:10px;}
.pd-conv-input input{flex:1;background:#FBFAF8;border:1px solid var(--cbr);border-radius:7px;padding:9px 12px;font-family:'Inter',sans-serif;font-size:13px;color:var(--tp);outline:none;letter-spacing:-0.005em;}
.pd-conv-input input:focus{border-color:var(--ac);background:var(--cb);}
.pd-conv-input button{background:var(--ac);border:none;border-radius:7px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:#fff;cursor:pointer;flex-shrink:0;}

/* Right rail sources */
.pd-src{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:11px 13px;margin-bottom:8px;cursor:pointer;transition:all .12s;}
.pd-src:hover{border-color:#CBD7FF;background:#F5F8FF;}
.pd-src-hdr{display:flex;align-items:center;gap:8px;margin-bottom:5px;}
.pd-src-icon{width:22px;height:22px;border-radius:5px;background:var(--s2);color:var(--ts);display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;}
.pd-src-kind{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;color:var(--at);font-weight:700;text-transform:uppercase;flex:1;}
.pd-src-weight{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);font-weight:600;}
.pd-src-text{font-size:12px;color:var(--ts);line-height:1.5;letter-spacing:-0.005em;}
.pd-src-text strong{color:var(--tp);font-weight:600;}
.pd-add-src{width:100%;background:transparent;border:1px dashed var(--cbr);border-radius:8px;padding:10px;font-family:'Inter',sans-serif;font-size:12.5px;font-weight:500;color:var(--at);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;margin-top:8px;letter-spacing:-0.005em;}
.pd-add-src:hover{border-color:var(--ac);background:var(--lyra-bg);}
.pd-add-src i{font-size:14px;}

/* Action bar */
.pd-actions{background:var(--cb);border-top:1px solid var(--cbr);padding:12px 22px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.pd-actions-left{display:flex;align-items:center;gap:10px;font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--tm);}
.pd-actions-right{display:flex;gap:8px;}
.pd-btn{background:var(--cb);border:1px solid var(--cbr);border-radius:7px;padding:8px 14px;font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:var(--ts);cursor:pointer;letter-spacing:-0.005em;display:flex;align-items:center;gap:5px;}
.pd-btn:hover{background:var(--s2);color:var(--tp);}
.pd-btn.rej:hover{color:var(--rdt);border-color:#E8B5B5;background:var(--rdl);}
.pd-btn.acc{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.pd-btn.acc:hover{background:#2A2D33;color:#fff;}
.pd-btn i{font-size:14px;}

/* PROPOSAL PANE V2 — single column, cleaner sections */
