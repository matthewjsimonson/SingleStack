function setPersona(id){
  var p = personaMeta[id] || personaMeta.lyra;
  currentPersona = id;
  var panel = document.getElementById('lyp');
  if(panel){
    panel.style.setProperty('--persona-accent', p.accent);
    panel.classList.remove('persona-lyra','persona-cpo','persona-cro','persona-ceo');
    panel.classList.add('persona-' + p.cls);
  }
  // Trigger button — Lyra style or agent style
  var btn = document.getElementById('lbt');
  var btnLabel = document.getElementById('lbt-label');
  if(btn){
    if(id === 'lyra'){
      btn.style.color = '';
      btn.style.borderColor = '';
      if(btnLabel) btnLabel.textContent = 'Lyra';
    } else {
      btn.style.color = p.accent;
      btn.style.borderColor = p.accent;
      if(btnLabel) btnLabel.textContent = p.avatar;
    }
  }
  // Chat input placeholder
  var inp = document.getElementById('lypinp');
  if(inp) inp.placeholder = p.placeholder;

  if(id === 'lyra'){
    // Lyra mode — restore scope text
    var t = document.getElementById('lyraScope');
    if(t && window._lastLyraScope) t.textContent = window._lastLyraScope;
  } else {
    // Agent mode — populate identity + content
    document.getElementById('lyp-agent-av').textContent = p.avatar;
    document.getElementById('lyp-agent-role').textContent = p.role;
    document.getElementById('lyp-agent-name').textContent = p.name;
    document.getElementById('lyp-agent-now-text').innerHTML = p.now;
    // Actions
    var actEl = document.getElementById('lyp-agent-actions');
    if(actEl){
      actEl.innerHTML = p.actions.map(a =>
        '<button class="lyp-agent-act">'+
          '<div class="lyp-agent-act-ic"><i class="ti ti-'+a.ic+'"></i></div>'+
          '<div class="lyp-agent-act-body">'+
            '<div class="lyp-agent-act-name">'+a.name+'</div>'+
            '<div class="lyp-agent-act-meta">'+a.meta+'</div>'+
          '</div>'+
          '<i class="ti ti-chevron-right lyp-agent-act-arr"></i>'+
        '</button>'
      ).join('');
    }
    // Recent
    var recEl = document.getElementById('lyp-agent-recent');
    if(recEl){
      recEl.innerHTML = p.recent.map(r =>
        '<div class="lyp-agent-rec-item">'+
          '<div class="lyp-agent-rec-top">'+
            '<span class="lyp-agent-rec-text"><strong>'+r.title+'</strong></span>'+
            '<span class="lyp-agent-rec-time">'+r.time+'</span>'+
          '</div>'+
          '<span class="lyp-agent-rec-text" style="color:#9BA0AB">'+r.sub+'</span>'+
        '</div>'
      ).join('');
    }
  }
}

