  var ws = document.getElementById('v-cm-ws');
  if(list) list.style.display = '';
  if(ws) ws.style.display = 'none';
}
function setCampaignStep(step){
  // Update stepbar active state — only toggle .active, leave .done alone
  document.querySelectorAll('.cm-step').forEach(b => {
    var oc = b.getAttribute('onclick') || '';
    if(oc.indexOf("'"+step+"'") !== -1){
      b.classList.add('active');
    } else {
      b.classList.remove('active');
    }
  });
  // Hide all flow panes, show the selected one
  document.querySelectorAll('.cm-flow-pane').forEach(p => p.style.display = 'none');
  var pane = document.getElementById('cm-flow-'+step);
  if(pane) pane.style.display = '';
  // Scroll to top of step
  window.scrollTo({top:0,behavior:'smooth'});
}
