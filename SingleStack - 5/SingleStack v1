.pd-textarea{width:100%;background:#FBFAF8;border:1px solid var(--cbr);border-radius:6px;padding:9px 11px;font-family:'Inter',sans-serif;font-size:13.5px;color:var(--tp);outline:none;letter-spacing:-0.005em;line-height:1.55;resize:vertical;min-height:60px;}
.pd-textarea:focus{border-color:var(--ac);background:var(--cb);}

.pd-why-v2{background:var(--cb);border:1px solid var(--cbr);border-radius:8px;padding:12px 14px;font-size:13px;color:var(--tp);line-height:1.6;letter-spacing:-0.005em;}

.pd-ev-v2{display:flex;flex-direction:column;gap:4px;}
.pd-ev-row{display:grid;grid-template-columns:auto 1fr auto;gap:11px;align-items:center;padding:8px 11px;background:#FBFAF8;border:1px solid var(--cbr);border-radius:7px;cursor:pointer;transition:background .12s;}
.pd-ev-row:hover{background:var(--cb);border-color:#CBD7FF;}
.pd-ev-row-text{font-size:12.5px;color:var(--tp);letter-spacing:-0.005em;line-height:1.4;}
.pd-ev-row-text strong{font-weight:600;}
.pd-ev-row-w{font-family:'JetBrains Mono',monospace;font-size:10.5px;color:var(--tm);font-weight:600;}

.pd-casc-v2{display:flex;flex-wrap:wrap;gap:6px;}
.pd-casc-chip{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--ts);background:var(--s2);border:1px solid var(--cbr);border-radius:6px;padding:5px 10px;letter-spacing:-0.005em;cursor:pointer;}
.pd-casc-chip:hover{background:var(--al);color:var(--at);border-color:#CBD7FF;}
.pd-casc-chip i{font-size:12px;color:var(--at);}

.pd-lyra-hint{display:flex;align-items:center;gap:12px;padding:11px 14px;background:linear-gradient(0deg,var(--lyra-bg),#F5F8FF);border:1px solid var(--lyra-bd);border-radius:10px;cursor:pointer;transition:all .12s;}
.pd-lyra-hint:hover{background:#E5EBFF;}
.pd-lyra-hint-icon{width:30px;height:30px;border-radius:7px;background:var(--cb);border:1px solid var(--lyra-bd);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.pd-lyra-hint-body{flex:1;min-width:0;}
.pd-lyra-hint-title{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.pd-lyra-hint-text{font-size:11.5px;color:var(--ts);margin-top:1px;}
.pd-lyra-hint-arrow{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--at);font-weight:600;display:flex;align-items:center;gap:5px;}
.pd-lyra-hint-arrow i{font-size:13px;}

/* LYRA PANEL */
.lyp{position:fixed;top:0;right:0;bottom:0;width:clamp(320px,28vw,420px);background:var(--sb);border-left:1px solid var(--sbb);display:flex;flex-direction:column;z-index:70;transform:translateX(100%);transition:transform .25s;}
.lyp.open{transform:translateX(0);}
.lyph{padding:16px 20px;border-bottom:1px solid var(--sbb);display:flex;align-items:center;gap:10px;}
.lypt{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:700;color:var(--ac);letter-spacing:.1em;flex:1;}
.lypc{background:#252A2E;border:1px solid var(--sbb);border-radius:8px;color:#C8D0D9;cursor:pointer;font-size:18px;padding:0;width:34px;height:34px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.lypc:hover{background:#2F353B;color:#fff;}
.lypb{flex:1;padding:18px 20px;overflow-y:auto;}

/* Lyra activity feed inside panel */
/* PROTOTYPE WORKSPACE — thin status strip + lyra hint */
.pt-status-strip{display:flex;align-items:center;gap:14px;padding:8px 12px;background:var(--cb);border:1px solid var(--cbr);border-radius:8px;}
.pt-status-left{display:flex;align-items:center;gap:10px;flex:1;min-width:0;}
.pt-status-name{font-size:13px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.pt-status-ver{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--tm);background:var(--s2);padding:2px 6px;border-radius:4px;font-weight:700;}
.pt-status-tag{font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;padding:2px 7px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase;}
.pt-status-tag.handoff{background:var(--aml);color:var(--amt);}
.pt-status-tag.active{background:var(--gnl);color:var(--gnt);}
.pt-status-right{display:flex;gap:6px;}
.pt-status-btn{background:var(--cb);border:1px solid var(--cbr);border-radius:6px;padding:6px 11px;font-family:'Inter',sans-serif;font-size:12px;font-weight:500;color:var(--ts);cursor:pointer;display:flex;align-items:center;gap:5px;letter-spacing:-0.005em;}
.pt-status-btn:hover{background:var(--s2);color:var(--tp);}
.pt-status-btn i{font-size:13px;}
.pt-status-btn.export{}
.pt-status-btn.build{background:var(--tp);color:#fff;border-color:var(--tp);font-weight:600;}
.pt-status-btn.build:hover{background:#2A2D33;color:#fff;}

.pt-lyra-hint{display:flex;align-items:center;gap:12px;padding:11px 14px;background:linear-gradient(0deg,var(--lyra-bg),#F5F8FF);border:1px solid var(--lyra-bd);border-radius:10px;cursor:pointer;transition:all .12s;}
.pt-lyra-hint:hover{background:#E5EBFF;}
.pt-lyra-hint-icon{width:30px;height:30px;border-radius:7px;background:var(--cb);border:1px solid var(--lyra-bd);color:var(--at);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.pt-lyra-hint-body{flex:1;min-width:0;}
.pt-lyra-hint-title{font-size:12.5px;font-weight:600;color:var(--tp);letter-spacing:-0.005em;}
.pt-lyra-hint-text{font-size:11.5px;color:var(--ts);margin-top:1px;}
.pt-lyra-hint-text em{font-style:italic;color:var(--at);}
.pt-lyra-hint-arrow{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--at);font-weight:600;display:flex;align-items:center;gap:5px;}
.pt-lyra-hint-arrow i{font-size:13px;}

/* LYRA PANEL · prototype-scoped context cards */
.lyra-pt-card{background:#252A2E;border:1px solid var(--sbb);border-radius:8px;padding:11px 13px;margin-bottom:10px;}
.lyra-pt-card-hdr{display:flex;align-items:center;gap:7px;margin-bottom:8px;}
.lyra-pt-card-hdr i{font-size:12px;color:var(--ac);}
.lyra-pt-card-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:#9BA0AB;font-weight:700;flex:1;text-transform:uppercase;}
.lyra-pt-card-count{font-family:'JetBrains Mono',monospace;font-size:10px;color:#5A5F6B;font-weight:600;}
.lyra-pt-chip{display:inline-flex;align-items:center;gap:6px;font-size:11.5px;color:#C8D0D9;background:#1A1D22;border:1px solid #2A2F35;border-radius:5px;padding:4px 9px;margin:0 4px 4px 0;letter-spacing:-0.005em;cursor:pointer;transition:all .12s;}
.lyra-pt-chip:hover{background:#0F1115;color:#fff;border-color:var(--ac);}
.lyra-pt-chip i{font-size:11px;color:var(--ac);}
.lyra-pt-add{width:100%;background:transparent;border:1px dashed #2A2F35;border-radius:6px;padding:6px;font-family:'Inter',sans-serif;font-size:11px;font-weight:500;color:var(--ac);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;margin-top:4px;}
.lyra-pt-add:hover{background:#1A1D22;border-color:var(--ac);}

/* LYRA PANEL · conversation messages (dark theme variant) */
.lyra-conv-msgs{display:flex;flex-direction:column;gap:10px;margin-bottom:14px;}
.lyra-conv-msg{display:flex;gap:8px;align-items:flex-start;}
.lyra-conv-msg-avatar{width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;}
.lyra-conv-msg-avatar.lyra{background:var(--ac);color:#fff;}
.lyra-conv-msg-avatar.user{background:#2A2F35;color:#C8D0D9;}
.lyra-conv-msg-body{flex:1;min-width:0;}
.lyra-conv-msg-who{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.1em;font-weight:700;color:#5A5F6B;margin-bottom:3px;text-transform:uppercase;}
.lyra-conv-msg-who.lyra{color:var(--ac);}
.lyra-conv-msg-text{font-size:12px;color:#C8D0D9;line-height:1.5;letter-spacing:-0.005em;}
.lyra-conv-applied{display:inline-flex;align-items:center;gap:4px;margin-top:5px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ac);background:rgba(94,138,255,.12);padding:2px 7px;border-radius:4px;font-weight:600;}

.lyra-tool-row{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:12px;}
.lyra-tool{background:#1A1D22;border:1px solid #2A2F35;border-radius:5px;padding:4px 8px;font-family:'Inter',sans-serif;font-size:11px;font-weight:500;color:#C8D0D9;cursor:pointer;display:flex;align-items:center;gap:4px;letter-spacing:-0.005em;}
.lyra-tool:hover{background:var(--ac);color:#fff;border-color:var(--ac);}
.lyra-tool i{font-size:12px;}

.lyra-act{display:flex;flex-direction:column;gap:12px;margin-bottom:18px;}
.lyra-act-lbl{font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;color:var(--sbl);letter-spacing:.12em;margin-bottom:4px;}

/* Lyra scope label at top of panel — shows what Lyra is doing scoped to current view */
.lyra-scope{background:#252A2E;border:1px solid var(--sbb);border-radius:8px;padding:10px 13px;margin-bottom:14px;display:flex;align-items:center;gap:9px;}
.lyra-scope-icon{width:22px;height:22px;border-radius:5px;background:var(--lyra-bg);color:var(--at);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:12px;}
.lyra-scope-body{flex:1;min-width:0;}
.lyra-scope-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:.12em;color:var(--sbl);font-weight:700;text-transform:uppercase;}
.lyra-scope-view{font-size:12px;font-weight:600;color:#C8D0D9;letter-spacing:-0.005em;margin-top:1px;}
.lyra-act-item{background:#252A2E;border:1px solid var(--sbb);border-radius:8px;padding:11px 13px;display:flex;flex-direction:column;gap:6px;}
.lyra-act-item-hdr{display:flex;align-items:center;gap:8px;font-size:11.5px;color:#C8D0D9;}
.lyra-act-item-hdr i{font-size:12px;color:var(--ac);}
.lyra-act-item-hdr-sp{flex:1;}
.lyra-act-item-age{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--sbl);}
.lyra-act-item-text{font-size:12.5px;color:#9BA0AB;line-height:1.5;}
.lyra-act-item-text strong{color:#C8D0D9;font-weight:600;}

.lype{color:var(--sbt);font-size:13px;line-height:1.6;padding-top:8px;border-top:1px solid var(--sbb);}

.lypi{padding:12px 20px;border-top:1px solid var(--sbb);display:flex;gap:8px;}
.lypinp{flex:1;background:#252A2E;border:1px solid var(--sbb);border-radius:6px;padding:9px 12px;font-size:13px;color:#C8D0D9;font-family:'Inter',sans-serif;outline:none;}
.lypinp::placeholder{color:var(--sbl);}
.lyps{background:var(--ac);border:none;border-radius:6px;width:36px;height:36px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:#fff;flex-shrink:0;}

/* ============ AGENT PANEL MODE — clean, minimal ============ */
/* Show/hide content blocks based on active persona */
.lyp.persona-lyra .lyp-agent-content{display:none;}
.lyp:not(.persona-lyra) .lyp-lyra-content{display:none;}

/* Agent persona accent — applied via persona-X classes */
.lyp.persona-cpo{--persona-accent:#5E8AFF;--persona-bg:rgba(94,138,255,.08);--persona-letter:CPO;}
.lyp.persona-cro{--persona-accent:#8E94EC;--persona-bg:rgba(142,148,236,.08);}
.lyp.persona-ceo{--persona-accent:#4AA66C;--persona-bg:rgba(74,166,108,.08);}

/* Agent panel HEADER override — bigger, identity-forward */
.lyp:not(.persona-lyra) .lyph{padding:18px 20px 14px;border-bottom:1px solid var(--sbb);position:relative;}
.lyp:not(.persona-lyra) .lyph::after{content:"";position:absolute;left:0;right:0;bottom:-1px;height:2px;background:var(--persona-accent);opacity:.6;}
.lyp:not(.persona-lyra) .lyph .ti-sparkles{display:none;}
.lyp:not(.persona-lyra) .lypt{display:none;}

/* Agent identity block in header */
.lyp-agent-hdr{display:none;align-items:center;gap:11px;flex:1;}
.lyp:not(.persona-lyra) .lyp-agent-hdr{display:flex;}
.lyp-agent-av{width:34px;height:34px;border-radius:8px;background:var(--persona-bg);color:var(--persona-accent);display:flex;align-items:center;justify-content:center;font-family:'Fraunces',Georgia,serif;font-size:17px;font-weight:600;flex-shrink:0;letter-spacing:-0.02em;}
.lyp-agent-id{flex:1;min-width:0;}
.lyp-agent-role{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.14em;color:var(--sbl);font-weight:700;text-transform:uppercase;line-height:1;}
.lyp-agent-name{font-family:'Fraunces',Georgia,serif;font-size:15px;font-weight:600;color:#F2F4F8;letter-spacing:-0.02em;line-height:1.15;margin-top:3px;}
.lyp-agent-live{display:flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:.12em;color:var(--persona-accent);font-weight:700;text-transform:uppercase;}
.lyp-agent-live-dot{width:5px;height:5px;border-radius:50%;background:var(--persona-accent);animation:ag-pulse 2.2s ease-in-out infinite;}

/* Agent panel BODY */
.lyp-agent-content{display:flex;flex-direction:column;gap:14px;}

/* Now-doing one-liner */
.lyp-agent-now{display:flex;align-items:center;gap:8px;padding:10px 13px;background:var(--persona-bg);border:1px solid var(--persona-accent);border-radius:8px;border-color:transparent;border-left:2px solid var(--persona-accent);}
.lyp-agent-now-ic{font-size:13px;color:var(--persona-accent);flex-shrink:0;}
.lyp-agent-now-text{font-size:12px;color:#C8D0D9;line-height:1.5;letter-spacing:-0.005em;}
.lyp-agent-now-text strong{color:#F2F4F8;font-weight:600;}

/* Section label */
.lyp-agent-lbl{font-family:'JetBrains Mono',monospace;font-size:9.5px;font-weight:700;color:var(--sbl);letter-spacing:.14em;text-transform:uppercase;margin-bottom:6px;}

/* Quick-action chips — things this agent can do */
.lyp-agent-actions{display:flex;flex-direction:column;gap:5px;}
.lyp-agent-act{display:grid;grid-template-columns:auto 1fr auto;gap:9px;align-items:center;background:#252A2E;border:1px solid var(--sbb);border-radius:7px;padding:9px 11px;cursor:pointer;transition:all .12s;text-align:left;font-family:'Inter',sans-serif;}
.lyp-agent-act:hover{background:#2A2F35;border-color:var(--persona-accent);}
.lyp-agent-act-ic{width:22px;height:22px;border-radius:5px;background:var(--persona-bg);color:var(--persona-accent);display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0;}
.lyp-agent-act-body{min-width:0;}
.lyp-agent-act-name{font-size:11.5px;font-weight:600;color:#F2F4F8;letter-spacing:-0.005em;line-height:1.3;}
.lyp-agent-act-meta{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--sbl);font-weight:600;margin-top:2px;}
.lyp-agent-act-arr{color:var(--sbl);font-size:14px;}
.lyp-agent-act:hover .lyp-agent-act-arr{color:var(--persona-accent);}

/* Recent activity — minimal */
.lyp-agent-recent{display:flex;flex-direction:column;gap:7px;}
.lyp-agent-rec-item{display:flex;flex-direction:column;gap:2px;padding-left:10px;border-left:2px solid var(--persona-accent);}
.lyp-agent-rec-top{display:flex;align-items:baseline;justify-content:space-between;gap:8px;}
.lyp-agent-rec-text{font-size:11.5px;color:#C8D0D9;line-height:1.45;letter-spacing:-0.005em;}
.lyp-agent-rec-text strong{color:#F2F4F8;font-weight:600;}
.lyp-agent-rec-time{font-family:'JetBrains Mono',monospace;font-size:9.5px;color:var(--sbl);font-weight:600;flex-shrink:0;}

/* Input override — accent send button on agent mode */
.lyp:not(.persona-lyra) .lyps{background:var(--persona-accent);}
.lyp:not(.persona-lyra) .lypinp:focus{border-color:var(--persona-accent);}
</style>
