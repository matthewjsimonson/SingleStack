function openCampaign(id){
  var c = campaignMeta[id] || campaignMeta['v44-major'];
  // Swap header content
  var name = document.getElementById('cm-sheet-name');
  var meta = document.getElementById('cm-sheet-meta');
  var bbmeta = document.getElementById('cm-sheet-bbmeta');
  var crumb = document.getElementById('cm-sheet-crumb');
  var hdr = document.getElementById('cm-sheet-hdr');
  var stateEl = document.getElementById('cm-sheet-state');
  if(name) name.textContent = c.name.replace('&amp;', '&');
  if(meta) meta.innerHTML = '<span class="cm-playbook '+c.playbookCls+'">'+c.playbookLabel+'</span>'+c.metaLine;
  if(bbmeta) bbmeta.textContent = c.bbmeta;
  if(crumb) crumb.textContent = c.name.replace('&amp;', '&');
  if(hdr){
    hdr.classList.remove('major','minor','response','abm','bugfix');
    hdr.classList.add(c.playbookCls);
