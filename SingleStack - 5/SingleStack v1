.pd-edit-v2-revert{background:transparent;border:1px solid var(--cbr);border-radius:5px;padding:3px 8px;font-family:'Inter',sans-serif;font-size:11px;font-weight:500;color:var(--ts);cursor:pointer;display:flex;align-items:center;gap:4px;letter-spacing:-0.005em;}
