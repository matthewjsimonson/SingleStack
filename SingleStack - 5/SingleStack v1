// Prototype home mode tabs (Releases / Gaps / Sandbox / Recent)
function ptMode(mode, btn){
  document.querySelectorAll('.pt-mode-pane').forEach(p => p.classList.remove('active'));
  var pane = document.getElementById('pt-mode-' + mode);
  if(pane) pane.classList.add('active');
  document.querySelectorAll('.pt-mode-tab').forEach(t => t.classList.remove('active'));
  if(btn){
    btn.classList.add('active');
  } else {
    // Activate tab matching mode (when called from a tile)
    var match = Array.from(document.querySelectorAll('.pt-mode-tab')).find(t => t.textContent.toLowerCase().includes(mode === 'releases' ? 'release' : mode === 'gaps' ? 'gaps' : mode === 'sandbox' ? 'sandbox' : 'recent'));
    if(match) match.classList.add('active');
  }
  // Scroll to mode tabs so user sees the switch
  var tabs = document.querySelector('.pt-mode-tabs');
  if(tabs && btn) tabs.scrollIntoView({behavior:'smooth', block:'start'});
}

// Build session overlay
function openBuildSession(){
  document.getElementById('bsBack').classList.add('open');
  document.getElementById('bsPane').classList.add('open');
}
function closeBuildSession(){
  document.getElementById('bsBack').classList.remove('open');
  document.getElementById('bsPane').classList.remove('open');
}

// Preview mode toggle (Desktop / Mobile / Code)
document.addEventListener('DOMContentLoaded', function(){
  document.querySelectorAll('.pt-preview-mode-btn').forEach(btn => {
    btn.addEventListener('click', function(){
      var parent = this.parentElement;
      parent.querySelectorAll('.pt-preview-mode-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
    });
  });
  document.querySelectorAll('.pt-version').forEach(v => {
    v.addEventListener('click', function(){
      var parent = this.parentElement;
      parent.querySelectorAll('.pt-version').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
    });
  });
});
// Stop inner action buttons from triggering the card-level click
document.addEventListener('DOMContentLoaded', function(){
  document.querySelectorAll('.sig-card .sig-act').forEach(btn => {
    btn.addEventListener('click', e => e.stopPropagation());
  });
});

// Lyra panel
function toggleLyra(){
  var p = document.getElementById('lyp');
  var m = document.getElementById('main');
  var b = document.getElementById('lbt');
  var o = p.classList.contains('open');
  p.classList.toggle('open');
  m.classList.toggle('lo');
  b.classList.toggle('open', !o);
  // Body class so the proposal pane (and other fixed-position overlays) can react
  document.body.classList.toggle('lyra-open', !o);
}
function openLyra(){
  // Talking to Lyra is a focused mode — close any open proposal drill-down first
  closeProposal();
  var p = document.getElementById('lyp');
  if(!p || p.classList.contains('open')) return;
  toggleLyra();
}

// Initialize panel as Lyra persona on load
document.addEventListener('DOMContentLoaded', function(){
  setPersona('lyra');
  // Force-close any overlays that might be in a stale state
  closeProposal();
});

// ESC key — closes the proposal pane first, then the Lyra/agent panel if no proposal
document.addEventListener('keydown', function(e){
  if(e.key === 'Escape' || e.keyCode === 27){
    var pane = document.getElementById('pdPane');
    if(pane && pane.classList.contains('open')){
      closeProposal();
      return;
    }
    var lyp = document.getElementById('lyp');
    if(lyp && lyp.classList.contains('open')){
      toggleLyra();
    }
  }
});
</script>
