.pd-diff-row-lbl.new{color:var(--at);}
.pd-diff-row-val{font-size:13.5px;line-height:1.5;letter-spacing:-0.005em;}
.pd-diff-row-val.old{color:var(--ts);text-decoration:line-through;text-decoration-color:rgba(209,67,67,.4);}
.pd-diff-row-val.new{color:var(--tp);font-weight:500;}

.pd-edit-v2{background:var(--cb);border:1.5px solid var(--lyra-bd);border-radius:8px;padding:11px 13px;}
