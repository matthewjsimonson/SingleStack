function sv(v){
  // Always close the proposal pane on navigation — it must not persist across pages
  if(typeof closeProposal === 'function') closeProposal();

  // When leaving Agents, reset to list view
  if(v !== 'ag'){
    var prof = document.getElementById('v-ag-prof');
    var list = document.getElementById('v-ag-list');
    if(prof) prof.style.display = 'none';
    if(list) list.style.display = '';
  }
  // When leaving Campaigns, reset to list view
  if(v !== 'cm'){
    var cmws = document.getElementById('v-cm-ws');
    var cmls = document.getElementById('v-cm-list');
    if(cmws) cmws.style.display = 'none';
    if(cmls) cmls.style.display = '';
  }
  // When leaving Build, reset to list view
  if(v !== 'bl' && v !== 'pt'){
    var blws = document.getElementById('v-bl-ws');
    var blls = document.getElementById('v-bl-list');
    if(blws) blws.style.display = 'none';
    if(blls) blls.style.display = '';
  }
  // When leaving Content, reset to list view
  if(v !== 'ct'){
    var ctws = document.getElementById('v-ct-draft');
    var ctls = document.getElementById('v-ct-list');
    if(ctws) ctws.style.display = 'none';
    if(ctls) ctls.style.display = '';
  }
  views.forEach(id => {
    var el = document.getElementById('v-'+id);
    if(el) el.style.display = id===v ? '' : 'none';
  });
  Object.values(navMap).forEach(n => {
    var el = document.getElementById(n);
    if(el) el.classList.remove('active');
  });
  if(navMap[v]){
    var nav = document.getElementById(navMap[v]);
    if(nav) nav.classList.add('active');
  }
  setLyraScope(v);
}

// Cornerstone view switching (Structure / Signals / Incoming)
function csvView(btn, record, view){
  // record is 'pr' or 'gr'
  var nav = document.querySelector('#v-'+record+' .csv-nav');
  if(btn && nav){
    nav.querySelectorAll('.csv-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  } else if(!btn && nav){
    // Programmatic switch — find tab by view name in its onclick
    nav.querySelectorAll('.csv-btn').forEach(b => {
      b.classList.remove('active');
      var oc = b.getAttribute('onclick') || '';
      if(oc.indexOf("'"+view+"'") !== -1) b.classList.add('active');
    });
  }
  var cls = record+'-view';
  document.querySelectorAll('.'+cls).forEach(v => v.style.display = 'none');
  var t = document.getElementById(record+'-view-'+view);
  if(t) t.style.display = '';
}

