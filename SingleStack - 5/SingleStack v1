// Proposal drill-down
function openProposal(title, branch){
  if(title) document.getElementById('pdTitle').textContent = title;
  if(branch) document.getElementById('pdBranch').textContent = branch;
  var back = document.getElementById('pdBack');
  var pane = document.getElementById('pdPane');
  if(back){ back.classList.add('open'); back.style.opacity=''; back.style.pointerEvents=''; }
  if(pane){ pane.classList.add('open'); pane.style.transform=''; }
}
function closeProposal(){
  var back = document.getElementById('pdBack');
  var pane = document.getElementById('pdPane');
  if(back){
    back.classList.remove('open');
    back.style.opacity = '0';
    back.style.pointerEvents = 'none';
  }
  if(pane){
    pane.classList.remove('open');
    // Force the transform so the pane slides off even if class removal is suppressed somehow
    pane.style.transform = 'translateX(100%)';
  }
}

